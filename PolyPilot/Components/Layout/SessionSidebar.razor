    private string? externalResumeError;
    private readonly Dictionary<string, string> _externalInputs = new();

    private bool HasExternalInput(string sessionId) =>
        _externalInputs.TryGetValue(sessionId, out var v) && !string.IsNullOrWhiteSpace(v);

    private async Task HandleExternalKeyUp(KeyboardEventArgs e, ExternalSessionInfo ext)
    {
        if (e.Key == "Enter" && HasExternalInput(ext.SessionId))
            await SendExternalMessage(ext);
    }

    private async Task SendExternalMessage(ExternalSessionInfo ext)
    {
        if (!_externalInputs.TryGetValue(ext.SessionId, out var prompt) || string.IsNullOrWhiteSpace(prompt))
            return;

        isExternalResuming = true;
        externalResumeError = null;
        confirmExternalResumeId = ext.SessionId; // track which session shows error
        try
        {
            _externalInputs[ext.SessionId] = "";
            await CopilotService.ResumeExternalAndSendAsync(ext, prompt.Trim());
            confirmExternalResumeId = null;
            await OnSessionSelected.InvokeAsync();
            if (currentPage != "/") Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            externalResumeError = ex.Message.Length > 120 ? ex.Message[..120] + "…" : ex.Message;
        }
        finally
        {
            isExternalResuming = false;
        }
    }

