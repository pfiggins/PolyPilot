    private async Task SaveAndApply()
    {
        settings.RepositoryStorageRoot = ConnectionSettings.NormalizeRepositoryStorageRoot(settings.RepositoryStorageRoot);
        if (!IsStorageRootValid(settings.RepositoryStorageRoot))
        {
            ShowStatus("Repository storage root must be an absolute path", "error", 5000);
            return;
        }

        if (settings.Mode == ConnectionMode.Persistent && !serverAlive)
        {
            ShowStatus("Start the persistent server first", "error", 5000);
            return;
        }

        if (settings.Mode == ConnectionMode.Remote && string.IsNullOrWhiteSpace(settings.RemoteUrl) && string.IsNullOrWhiteSpace(settings.LanUrl))
        {
            ShowStatus("Enter a remote server URL", "error", 5000);
            return;
        }

        // Normalize URL before saving (adds http:// if no scheme)
        if (settings.Mode == ConnectionMode.Remote)
            settings.RemoteUrl = ConnectionSettings.NormalizeRemoteUrl(settings.RemoteUrl);

        settings.Save();
        RepoManager.InvalidateStorageRoot();
        ShowStatus("Settings saved. Reconnecting...", "", 0);

        try
        {
            await CopilotService.ReconnectAsync(settings);
            _initialMode = settings.Mode;
            _initialCliSource = settings.CliSource;
            _initialRepositoryStorageRoot = NormalizePathForCompare(settings.RepositoryStorageRoot);
            cliSourceChanged = false;
            ShowStatus("Connected!", "success");
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            ShowStatus($"Connection failed: {Models.ErrorMessageHelper.Humanize(ex)}", "error", 8000);
        }
    }

    // --- Direct Connection Sharing ---

    private void StartDirectSharing()
    {
        if (string.IsNullOrWhiteSpace(settings.ServerPassword)) return;
        WsBridgeServer.ServerPassword = settings.ServerPassword;
        WsBridgeServer.SetCopilotService(CopilotService);
        WsBridgeServer.Start(DevTunnelService.BridgePort, settings.Port);
        if (!WsBridgeServer.IsRunning)
        {
            ShowStatus($"Failed to start bridge server on port {DevTunnelService.BridgePort} — the port may already be in use.", "error", 10000);
            return;
        }

        if (!WsBridgeServer.SupportsRemoteConnections)
        {
            WsBridgeServer.Stop();
            directQrCodeDataUri = null;
            fiestaPairingString = null;
            ShowStatus("Direct sharing could only bind to localhost, so phones and other PCs cannot connect directly. Use Tunnel instead.", "error", 10000);
            return;
        }

        settings.DirectSharingEnabled = true;
        settings.Save();
        GenerateDirectQrCode();
        TryGenerateFiestaPairingString();
        StateHasChanged();
    }

    private void StopDirectSharing()
    {
        WsBridgeServer.Stop();
        settings.DirectSharingEnabled = false;
        settings.Save();
        directQrCodeDataUri = null;
        fiestaPairingString = null;
        StateHasChanged();
    }

    private async Task CopyDirectUrl()
    {
        var host = TailscaleService.MagicDnsName ?? TailscaleService.TailscaleIp ?? localIps.FirstOrDefault() ?? "localhost";
        var url = $"http://{host}:{DevTunnelService.BridgePort}";
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
        ShowStatus("URL copied!", "success", 2000);
    }

    private void DiscoverLocalIps()
    {
        localIps.Clear();
        try
        {
            foreach (var ni in System.Net.NetworkInformation.NetworkInterface.GetAllNetworkInterfaces())
            {
                if (ni.OperationalStatus != System.Net.NetworkInformation.OperationalStatus.Up) continue;
                if (ni.NetworkInterfaceType == System.Net.NetworkInformation.NetworkInterfaceType.Loopback) continue;
                foreach (var addr in ni.GetIPProperties().UnicastAddresses)
                {
                    if (addr.Address.AddressFamily == System.Net.Sockets.AddressFamily.InterNetwork)
                        localIps.Add(addr.Address.ToString());
                }
            }
        }
        catch { }
    }

    private void GenerateDirectQrCode()
    {
        directQrCodeDataUri = null;
        if (!WsBridgeServer.SupportsRemoteConnections)
            return;

        var host = TailscaleService.MagicDnsName ?? TailscaleService.TailscaleIp ?? localIps.FirstOrDefault();
        if (host == null) return;

        var payload = ConnectionSettings.BuildDirectQrPayload(
            host,
            DevTunnelService.BridgePort,
            settings.ServerPassword,
            allowLan: WsBridgeServer.SupportsRemoteConnections,
            tunnelUrl: DevTunnelService.State == TunnelState.Running ? DevTunnelService.TunnelUrl : null,
            tunnelToken: DevTunnelService.State == TunnelState.Running ? DevTunnelService.AccessToken : null);
        if (payload.Count == 0) return;

        var json = System.Text.Json.JsonSerializer.Serialize(payload);
        try
        {
            using var qr = new QRCoder.QRCodeGenerator();
            using var data = qr.CreateQrCode(json, QRCoder.QRCodeGenerator.ECCLevel.M);
            using var png = new QRCoder.PngByteQRCode(data);
            var bytes = png.GetGraphic(12, new byte[] { 0, 0, 0 }, new byte[] { 255, 255, 255 });
            directQrCodeDataUri = $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
        }
        catch { }
    }

    // ── Plugin Management ───────────────────────────────────

    private void ScanPlugins()
    {
        try
        {
            discoveredPlugins = PluginLoader.DiscoverPlugins();
        }
        catch
        {
            discoveredPlugins = new();
        }
    }

    private void EnablePlugin(DiscoveredPlugin plugin)
    {
        // Remove from disabled list if present
        settings.Plugins.Disabled.RemoveAll(d => d.Path == plugin.Path);

        // Remove existing enabled entry (in case of re-approval after hash change)
        settings.Plugins.Enabled.RemoveAll(e => e.Path == plugin.Path);

        settings.Plugins.Enabled.Add(new EnabledPlugin
        {
            Path = plugin.Path,
            Hash = plugin.Hash,
            EnabledAt = DateTime.UtcNow,
            DisplayName = plugin.Name
        });

        settings.Save();
        ShowStatus("Plugin enabled. Restart PolyPilot to load it.", "success");
    }

    private void DisablePlugin(DiscoveredPlugin plugin)
    {
        var enabled = settings.Plugins.Enabled.FirstOrDefault(e => e.Path == plugin.Path);
        settings.Plugins.Enabled.RemoveAll(e => e.Path == plugin.Path);

        settings.Plugins.Disabled.Add(new DisabledPlugin
        {
            Path = plugin.Path,
            Reason = "user_disabled",
            LastKnownHash = enabled?.Hash ?? plugin.Hash
        });

        settings.Save();
        ShowStatus("Plugin disabled. Restart PolyPilot to unload it.", "success");
    }
