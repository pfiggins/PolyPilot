    private void OnTunnelStateChanged()
    {
        InvokeAsync(() =>
        {
            if (DevTunnelService.State == TunnelState.Running && DevTunnelService.TunnelUrl != null)
                GenerateQrCode(DevTunnelService.TunnelUrl, DevTunnelService.AccessToken);
            else
                qrCodeDataUri = null;
            StateHasChanged();
        });
    }

    private void GenerateQrCode(string url, string? token)
    {
        try
        {
            var lanHost = TailscaleService.MagicDnsName ?? TailscaleService.TailscaleIp ?? localIps.FirstOrDefault();
            var payload = ConnectionSettings.BuildTunnelQrPayload(
                url,
                token,
                lanHost,
                DevTunnelService.BridgePort,
                settings.ServerPassword,
                allowLan: WsBridgeServer.SupportsRemoteConnections);

            var json = System.Text.Json.JsonSerializer.Serialize(payload);
            Console.WriteLine($"[QR] Generating QR code: url={url}, hasLan={payload.ContainsKey("lanUrl")}, payloadLen={json.Length}");

            using var qrGenerator = new QRCoder.QRCodeGenerator();
            using var qrCodeData = qrGenerator.CreateQrCode(json, QRCoder.QRCodeGenerator.ECCLevel.L);
            using var qrCode = new QRCoder.PngByteQRCode(qrCodeData);
            var pngBytes = qrCode.GetGraphic(4, new byte[] { 0, 0, 0 }, new byte[] { 255, 255, 255 });
            qrCodeDataUri = $"data:image/png;base64,{Convert.ToBase64String(pngBytes)}";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[QR] Error generating QR code: {ex.Message}");
        }
    }

