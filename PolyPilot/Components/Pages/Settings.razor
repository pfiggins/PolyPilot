    <div id="settings-plugins" class="settings-group @(GroupVisible("plugins") ? "" : "search-hidden")">
        <h2 class="group-title">Plugins</h2>

        <div class="settings-section @(SectionVisible("plugins provider extension dll assembly") ? "" : "search-hidden")">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                <h3 style="margin:0;">Installed Plugins</h3>
                <button class="plugin-scan-btn" @onclick="ScanPlugins">🔍 Scan</button>
            </div>

            @if (discoveredPlugins.Count == 0)
            {
                <p class="section-desc" style="color: var(--text-tertiary);">
                    No plugins found. Place plugin folders in <code>~/.polypilot/plugins/</code> — each folder should contain a <code>plugin.json</code> manifest.
                </p>
            }
            else
            {
                @foreach (var plugin in discoveredPlugins)
                {
                    var enabled = settings.Plugins.Enabled.FirstOrDefault(e => e.Path == plugin.Path);
                    var disabled = settings.Plugins.Disabled.FirstOrDefault(d => d.Path == plugin.Path);
                    var hashChanged = enabled != null && !string.Equals(enabled.Hash, plugin.Hash, StringComparison.OrdinalIgnoreCase);

                    <div class="plugin-card" style="border-left: 3px solid @(enabled != null && !hashChanged ? "var(--accent-success)" : hashChanged ? "var(--accent-warning, orange)" : "var(--border-primary)");">
                        <div class="plugin-header">
                            <span class="plugin-status">@(enabled != null && !hashChanged ? "✅" : hashChanged ? "⚠️" : "🆕")</span>
                            <strong>@plugin.Name</strong>
                            @if (!string.IsNullOrEmpty(plugin.Version))
                            {
                                <span style="font-size:var(--type-caption1); color:var(--text-secondary); margin-left:6px;">v@plugin.Version</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(plugin.Description))
                        {
                            <div style="font-size:var(--type-callout); margin:4px 0;">@plugin.Description</div>
                        }
                        <div class="plugin-details" style="font-size:var(--type-footnote); color:var(--text-secondary); margin:4px 0;">
                            <div>📦 @plugin.DirectoryName / @plugin.FileName</div>
                            <div>🔒 SHA-256: @plugin.Hash[..Math.Min(16, plugin.Hash.Length)]…</div>
                            @if (enabled != null && !hashChanged)
                            {
                                <div>Enabled: @enabled.EnabledAt.ToString("MMM d, yyyy")</div>
                            }
                            @if (hashChanged)
                            {
                                <div style="color:var(--accent-warning, orange);">DLL was replaced — re-approve to load</div>
                            }
                        </div>
                        <div class="plugin-actions" style="margin-top:6px;">
                            @if (enabled != null && !hashChanged)
                            {
                                <button class="plugin-btn plugin-btn-danger" @onclick="() => DisablePlugin(plugin)">Disable</button>
                            }
                            else
                            {
                                <button class="plugin-btn" @onclick="() => EnablePlugin(plugin)">Enable</button>
                            }
                        </div>
                    </div>
                }
            }

            <p class="section-desc" style="margin-top:12px; font-size:var(--type-footnote); color:var(--text-tertiary);">
                ℹ️ Enabling a plugin loads its code into PolyPilot. Only enable plugins you trust. A restart is required after enabling or disabling plugins.
            </p>
        </div>
    </div>
    }

