    // --- Status filter ---
    private enum SessionStatusFilter { All, Processing, NeedsAttention, Stuck, Idle }
    private SessionStatusFilter _statusFilter = SessionStatusFilter.All;

    private static SessionStatusFilter GetSessionStatus(AgentSessionInfo session)
    {
        if (session.IsProcessing) return SessionStatusFilter.Processing;
        if (session.ConsecutiveStuckCount >= 1 || session.HasPermissionIssue) return SessionStatusFilter.Stuck;
        if (session.UnreadCount > 0) return SessionStatusFilter.NeedsAttention;
        return SessionStatusFilter.Idle;
    }

    private List<AgentSessionInfo> ApplyStatusFilter(List<AgentSessionInfo> all)
    {
        if (_statusFilter == SessionStatusFilter.All) return all;
        return all.Where(s => GetSessionStatus(s) == _statusFilter).ToList();
    }

    private int CountByStatus(SessionStatusFilter filter)
    {
        if (filter == SessionStatusFilter.All) return sessions.Count;
        return sessions.Count(s => GetSessionStatus(s) == filter);
    }

    private sealed record GroupRenderModel(
        SessionGroup Group,
        List<AgentSessionInfo> AllSessions,
        List<AgentSessionInfo> PinnedSessions,
        List<AgentSessionInfo> UnpinnedSessions,
        bool ShowUnpinnedToggle,
        int UnpinnedCount);

    private List<GroupRenderModel> _regularGroupModels = new();
    private List<(SessionGroup Group, List<AgentSessionInfo> Sessions)> _codespaceGroups = new();
    private bool _showGroupHeaders;

    // RenderFilterBar runs first in the template, before the session list reads
    // _regularGroupModels/_codespaceGroups. This ordering is load-bearing: the
    // auto-reset path below rebuilds rendered groups so the session list sees the
    // updated filter in the same synchronous render pass.
    private RenderFragment RenderFilterBar => __builder =>
    {
        var processingCount = CountByStatus(SessionStatusFilter.Processing);
        var attentionCount  = CountByStatus(SessionStatusFilter.NeedsAttention);
        var stuckCount      = CountByStatus(SessionStatusFilter.Stuck);

            // Only show when there are interesting non-idle sessions
            if (processingCount == 0 && attentionCount == 0 && stuckCount == 0)
            {
                // Auto-reset the filter so the sidebar doesn't show zero results with no recovery path
                if (_statusFilter != SessionStatusFilter.All)
                {
                    _statusFilter = SessionStatusFilter.All;
                    RebuildRenderedGroups();
                }
                return;
            }

        <div class="status-filter-bar">
            <button class="filter-chip filter-chip-all @(_statusFilter == SessionStatusFilter.All ? "active" : "")"
                    @onclick="() => SetStatusFilter(SessionStatusFilter.All)">
                All <span class="filter-count">@sessions.Count</span>
            </button>
            @if (processingCount > 0)
            {
                <button class="filter-chip filter-chip-processing @(_statusFilter == SessionStatusFilter.Processing ? "active" : "")"
                        @onclick="() => SetStatusFilter(SessionStatusFilter.Processing)">
                    ⚙ Working <span class="filter-count">@processingCount</span>
                </button>
            }
            @if (attentionCount > 0)
            {
                <button class="filter-chip filter-chip-attention @(_statusFilter == SessionStatusFilter.NeedsAttention ? "active" : "")"
                        @onclick="() => SetStatusFilter(SessionStatusFilter.NeedsAttention)">
                    ● Attention <span class="filter-count">@attentionCount</span>
                </button>
            }
            @if (stuckCount > 0)
            {
                <button class="filter-chip filter-chip-stuck @(_statusFilter == SessionStatusFilter.Stuck ? "active" : "")"
                        @onclick="() => SetStatusFilter(SessionStatusFilter.Stuck)">
                    ⚠ Stuck <span class="filter-count">@stuckCount</span>
                </button>
            }
            <button class="filter-chip filter-chip-idle @(_statusFilter == SessionStatusFilter.Idle ? "active" : "")"
                    @onclick="() => SetStatusFilter(SessionStatusFilter.Idle)">
                Idle <span class="filter-count">@CountByStatus(SessionStatusFilter.Idle)</span>
            </button>
        </div>
    };

    private GroupRenderModel BuildGroupRenderModel(
        SessionGroup group,
        List<AgentSessionInfo> all,
        IReadOnlyDictionary<string, SessionMeta> metas)
    {
        if (all.Count == 0)
            return new GroupRenderModel(group, all, all, [], false, 0);

        var pinned = new List<AgentSessionInfo>(all.Count);
        var unpinned = new List<AgentSessionInfo>(all.Count);

        foreach (var session in all)
        {
            if (metas.TryGetValue(session.Name, out var meta) && meta.IsPinned)
                pinned.Add(session);
            else
                unpinned.Add(session);
        }

        var showUnpinnedToggle = pinned.Count > 0 && unpinned.Count > 0;
        return new GroupRenderModel(
            group,
            all,
            showUnpinnedToggle ? pinned : all,
            showUnpinnedToggle && !group.UnpinnedCollapsed ? unpinned : [],
            showUnpinnedToggle,
            unpinned.Count);
    }

