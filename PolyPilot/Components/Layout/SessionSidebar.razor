@using PolyPilot.Services
@using PolyPilot.Models
@inject CopilotService CopilotService
@inject RepoManager RepoManager
@inject EfficiencyAnalysisService EfficiencyAnalysis
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

@if (IsMobileTopBar)
{
    <div class="mobile-bar">
        @if (CopilotService.IsInitialized)
        {
            <button class="hamburger-btn" @onclick="ToggleFlyout">
                ☰
            </button>
        }
        <span class="mobile-title"><img src="PolyPilot_text.png" height="20" style="vertical-align:middle" /></span>
        <div class="mobile-tabs">
            <a href="/" class="mobile-tab @(currentPage == "/" || currentPage == "/dashboard" ? "active" : "")" @onclick='() => { CopilotService.SaveUiState("/"); currentPage = "/"; }' title="Dashboard"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg></a>
            <a href="/settings" class="mobile-tab @(currentPage == "/settings" ? "active" : "")" @onclick='() => { CopilotService.SaveUiState("/settings"); currentPage = "/settings"; }' title="Settings"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></a>
        </div>
    </div>
}
else if (IsFlyoutPanel)
{
    <div class="sidebar-content flyout-content mobile-flyout-sidebar">
        <div class="sidebar-header desktop-shell flyout-shell">
            <div class="sidebar-header-row">
                <a href="/" class="header-logo-link header-brand @(currentPage == "/" || currentPage == "/dashboard" ? "active" : "")"
                   title="Dashboard"
                   @onclick="FlyoutDashboardClicked"
                   @onclick:preventDefault="true">
                    <span class="header-brand-mark">
                        <img src="PolyPilot_logo.png" class="header-brand-logo" alt="PolyPilot" />
                    </span>
                    <span class="header-brand-copy">
                        <span class="header-brand-name">PolyPilot</span>
                        <span class="status-pill @(CopilotService.IsInitialized ? "connected" : "disconnected")" title="Connection status">
                            <span class="status-pill-dot"></span>
                            @(CopilotService.IsInitialized ? CopilotService.CurrentMode : "Disconnected")
                        </span>
                    </span>
                </a>
                <div class="header-actions flyout-header-actions">
                    <a href="/settings"
                       class="header-icon-btn @(currentPage == "/settings" ? "active" : "")"
                       title="Settings"
                       @onclick="FlyoutSettingsClicked"
                       @onclick:preventDefault="true">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="3"/>
                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                        </svg>
                    </a>
                    <button class="header-icon-btn flyout-close-icon" title="Close sidebar" @onclick="ToggleFlyout">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div class="new-session-wrapper sidebar-compose-panel flyout-compose-panel" style="position:relative">
            @RenderCompactCreateToolbar
        </div>

        <div class="sidebar-divider"></div>
        <div class="sidebar-organize-shell flyout-organize-shell" style="position:relative">
            @RenderFilterBar
        </div>
        @RenderSessionList
    </div>
}
else
{
    <div class="sidebar-content desktop-sidebar @(IsDesktopRailMode ? "desktop-rail-mode" : "desktop-expanded-mode") @(IsSupportPanelOpen ? "support-open" : "") @(openMenuSession != null || openGroupMenuId != null ? "has-open-menu" : "")">
        <div class="sidebar-header desktop-shell">
            <div class="sidebar-header-row">
                <a href="/" class="header-logo-link header-brand @(currentPage == "/" || currentPage == "/dashboard" ? "active" : "")"
                   title="Dashboard"
                   @onclick="DashboardClicked"
                   @onclick:preventDefault="true">
                    <span class="header-brand-mark">
                        <img src="PolyPilot_logo.png" class="header-brand-logo" alt="PolyPilot" />
                    </span>
                    <span class="header-brand-copy">
                        <span class="header-brand-name">PolyPilot</span>
                        <span class="status-pill @(CopilotService.IsInitialized ? "connected" : "disconnected")" title="Connection status">
                            <span class="status-pill-dot"></span>
                            @(CopilotService.IsInitialized ? CopilotService.CurrentMode : "Disconnected")
                        </span>
                    </span>
                </a>
                <div class="header-actions">
                    <a href="/settings" class="header-icon-btn @(currentPage == "/settings" ? "active" : "")" title="Settings" @onclick='() => { CopilotService.SaveUiState("/settings"); currentPage = "/settings"; }'><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></a>
                    <div class="header-overflow">
                        <button class="header-icon-btn header-overflow-trigger"
                                type="button"
                                aria-haspopup="true">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="5" cy="12" r="1.5"></circle>
                                <circle cx="12" cy="12" r="1.5"></circle>
                                <circle cx="19" cy="12" r="1.5"></circle>
                            </svg>
                        </button>
                        <div class="header-overflow-panel">
                            <div class="header-overflow-menu">
                                <a href="/tutorial"
                                   class="header-overflow-action @(currentPage == "/tutorial" ? "active" : "")"
                                   title="Tutorial"
                                   @onclick='() => { CopilotService.SaveUiState("/tutorial"); currentPage = "/tutorial"; }'>
                                    <span class="header-overflow-action-icon" aria-hidden="true">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                    </span>
                                    <span class="header-overflow-action-copy">
                                        <span class="header-overflow-action-title">Tutorial</span>
                                        <span class="header-overflow-action-subtitle">Tips, walkthroughs, and onboarding</span>
                                    </span>
                                </a>
                                <a href="/scheduled-tasks"
                                   class="header-overflow-action @(currentPage == "/scheduled-tasks" ? "active" : "")"
                                   title="Scheduled Tasks"
                                   @onclick='() => { CopilotService.SaveUiState("/scheduled-tasks"); currentPage = "/scheduled-tasks"; }'>
                                    <span class="header-overflow-action-icon" aria-hidden="true">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    </span>
                                    <span class="header-overflow-action-copy">
                                        <span class="header-overflow-action-title">Scheduled Tasks</span>
                                        <span class="header-overflow-action-subtitle">Run recurring prompts on a schedule</span>
                                    </span>
                                </a>
                                <button class="header-overflow-action"
                                        type="button"
                                        title="Statistics"
                                        @onclick="ToggleStatisticsPopup">
                                    <span class="header-overflow-action-icon" aria-hidden="true">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                                    </span>
                                    <span class="header-overflow-action-copy">
                                        <span class="header-overflow-action-title">Statistics</span>
                                        <span class="header-overflow-action-subtitle">Open usage and session stats</span>
                                    </span>
                                </button>
                            </div>
                            <div class="header-overflow-divider"></div>
                            <div class="header-overflow-section">
                                <div class="header-overflow-section-title">Connection & shortcuts</div>
                                <div class="info-row"><span class="info-label">Mode</span><span class="info-value">@CopilotService.CurrentMode</span></div>
                                <div class="info-row"><span class="info-label">Status</span><span class="info-value">@(CopilotService.IsInitialized ? "Connected" : "Disconnected")</span></div>
                                <div class="info-row"><span class="info-label">Build</span><span class="info-value" title="@BuildInfo.BuildTimestamp">@BuildInfo.ShortBuildId</span></div>
                                @if (PlatformHelper.IsDesktop)
                                {
                                    <div class="info-divider"></div>
                                    <div class="info-row"><span class="info-label">⌘,</span><span class="info-value">Settings</span></div>
                                    <div class="info-row"><span class="info-label">⌘1-9</span><span class="info-value">Switch session</span></div>
                                    <div class="info-row"><span class="info-label">⌘E</span><span class="info-value">Expand/collapse</span></div>
                                    <div class="info-row"><span class="info-label">Esc</span><span class="info-value">Collapse to grid</span></div>
                                    <div class="info-row"><span class="info-label">Tab</span><span class="info-value">Next session</span></div>
                                    <div class="info-row"><span class="info-label">⌘+/−/0</span><span class="info-value">Font size</span></div>
                                    <div class="info-row"><span class="info-label">Ctrl+C</span><span class="info-value">Interrupt</span></div>
                                    <div class="info-row"><span class="info-label">↑/↓</span><span class="info-value">History</span></div>
                                }
                            </div>
                        </div>
                    </div>
                    <button class="header-icon-btn rail-toggle-btn"
                            title="@(IsDesktopRailMode ? "Expand sidebar" : "Collapse to rail")"
                            @onclick="ToggleDesktopRailMode">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="16" rx="2" />
                            <line x1="9" y1="4" x2="9" y2="20" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div class="new-session-wrapper sidebar-compose-panel">
            @if (UseDesktopCreateRail)
            {
                @RenderCompactCreateToolbar
            }
            else
            {
                <CreateSessionForm @ref="createSessionFormRef" @bind-SessionName="newSessionName"
                                   @bind-SelectedModel="selectedModel"
                                   AvailableModels="availableModels.ToList()"
                                   CompactMode="IsDesktopRailMode"
                                   IsCreating="isCreating"
                                   CreateError="@createError"
                                   OnCreate="HandleCreateSession"
                                   OnRequestExpandSidebar="ExpandSidebarFromRail"
                                   OnBrowseDirectory="OpenDirectoryPicker" />
            }
        </div>

        @if (!IsDesktopRailMode)
        {
            <div class="sidebar-divider"></div>
            <div class="sidebar-organize-shell @(UseDesktopCreateRail ? "sidebar-organize-shell-compact" : "")">
                @if (!UseDesktopCreateRail)
                {
                    @RenderSortToolbar
                }
                @RenderFilterBar
            </div>
        }
        @RenderSessionList

        <div class="sidebar-footer sidebar-support-fab @(IsSupportPanelOpen ? "open" : "")">
            <button class="support-row @(IsSupportPanelOpen ? "expanded" : "")"
                    @onclick="ToggleSupportPanel"
                    title="Report issues or launch a fix session">
                <span class="support-row-icon" aria-hidden="true"></span>
                <span class="support-row-copy">
                    <span class="support-row-title">Support</span>
                </span>
                <span class="support-row-chevron @(IsSupportPanelOpen ? "expanded" : "collapsed")" aria-hidden="true"></span>
            </button>
            @if (IsSupportPanelOpen)
            {
                <div class="support-panel">
                    <div class="support-panel-tabs">
                        <button class="support-tab @(showBugReport ? "active" : "")"
                                @onclick="() => SwitchSupportPanel(true)"
                                title="Report a bug">
                            Report bug
                        </button>
                        <button class="support-tab @(showFixIt ? "active" : "")"
                                @onclick="() => SwitchSupportPanel(false)"
                                title="Fix a bug or add a feature">
                            Fix / Feature
                        </button>
                        <button class="support-close-btn" @onclick="CloseFooterPanel" aria-label="Close panel" title="Close support panel">✕</button>
                    </div>
                    @if (showBugReport)
                    {
                        <div class="bug-report-inline">
                            <select class="bug-report-select" @bind="selectedBugSession" aria-label="Select session to report">
                                <option value="">No specific session</option>
                                @foreach (var s in CopilotService.GetAllSessions())
                                {
                                    <option value="@s.Name">@s.Name@(s.IsProcessing ? " (Thinking)" : "")</option>
                                }
                            </select>
                            <textarea class="bug-report-textarea" @bind="bugDescription" placeholder="Describe the issue you're seeing…" aria-label="Bug description"></textarea>
                            <details class="bug-report-details">
                                <summary>Debug info included</summary>
                                <pre class="bug-report-debug">@GetBugReportDebugInfo()</pre>
                            </details>
                            <div class="bug-report-actions">
                                @if (!string.IsNullOrEmpty(footerStatus))
                                {
                                    <span class="bug-report-status @(footerStatus.StartsWith("✓") ? "success" : "error")">@footerStatus</span>
                                }
                                <button class="bug-report-submit" @onclick="SubmitBugReport" disabled="@footerSubmitting" title="Submit bug report as a GitHub issue">
                                    @(footerSubmitting ? "Submitting…" : "Submit Issue")
                                </button>
                            </div>
                        </div>
                    }
                    else if (showFixIt)
                    {
                        <div class="bug-report-inline">
                            <select class="bug-report-select" @bind="selectedBugSession" aria-label="Select session">
                                <option value="">No specific session</option>
                                @foreach (var s in CopilotService.GetAllSessions())
                                {
                                    <option value="@s.Name">@s.Name@(s.IsProcessing ? " (Thinking)" : "")</option>
                                }
                            </select>
                            <textarea class="bug-report-textarea" @bind="bugDescription" placeholder="Describe what to fix or build…" aria-label="Description"></textarea>
                            <details class="bug-report-details">
                                <summary>Debug info included</summary>
                                <pre class="bug-report-debug">@GetBugReportDebugInfo()</pre>
                            </details>
                            <div class="bug-report-actions">
                                @if (!string.IsNullOrEmpty(footerStatus))
                                {
                                    <span class="bug-report-status @(footerStatus.StartsWith("✓") ? "success" : footerStatus.StartsWith("⏳") ? "" : "error")">@footerStatus</span>
                                }
                                <button class="bug-report-submit" @onclick="LaunchFixIt" disabled="@footerSubmitting" title="Launch a Copilot session to fix the bug or build the feature">
                                    @(footerSubmitting ? "Launching…" : "Launch Copilot")
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@if (showDirectoryPicker)
{
    <RemoteDirectoryPicker OnSelected="OnDirectorySelected" OnCancelled="OnDirectoryPickerCancelled" />
}

@code {
    [Parameter] public bool IsMobileTopBar { get; set; }
    [Parameter] public bool IsFlyoutPanel { get; set; }
    [Parameter] public EventCallback OnToggleFlyout { get; set; }
    [Parameter] public EventCallback OnSessionSelected { get; set; }
    [Parameter] public int FontSize { get; set; } = 20;
    [Parameter] public EventCallback<int> OnFontSizeChange { get; set; }
    [Parameter] public EventCallback OnToggleStatistics { get; set; }
    [Parameter] public bool IsDesktopRailMode { get; set; }
    [Parameter] public EventCallback<bool> OnDesktopRailModeChanged { get; set; }

    private Dictionary<string, (OrchestratorPhase Phase, string? Detail)> _groupPhases = new();
    private HashSet<string> _groupSettingsExpanded = new();
    private Timer? _diskSizeTimer;
    private DotNetObjectReference<SessionSidebar>? _sidebarRef;

    private static string PhaseLabel(OrchestratorPhase phase, string? detail) => phase switch
    {
        OrchestratorPhase.Planning => "Planning..." + (detail != null ? $" ({detail})" : ""),
        OrchestratorPhase.Dispatching => "Dispatching..." + (detail != null ? $" {detail}" : ""),
        OrchestratorPhase.WaitingForWorkers => "Waiting for workers...",
        OrchestratorPhase.Synthesizing => detail != null ? detail : "Synthesizing...",
        _ => ""
    };

    private bool IsSupportPanelOpen => showBugReport || showFixIt;
    private bool showCreateSessionPopover;
    private bool showCreateSessionForm;
    private bool UseDesktopCreateRail => !IsMobileTopBar && !IsDesktopRailMode;
    private bool IsDesktopCreatePopoverOpen =>
        UseDesktopCreateRail &&
        (showCreateSessionPopover || showCreateSessionForm || isAddingGroup || isAddingMultiAgentGroup || pendingMultiAgentRepo != null || showAddRepo);

    private string DesktopCreatePopoverTitle => showCreateSessionPopover
        ? "Create"
        : showCreateSessionForm
            ? "Start a focused session"
        : isAddingGroup
            ? "Create a session group"
            : (isAddingMultiAgentGroup || pendingMultiAgentRepo != null)
                ? "Create a multi-agent team"
                : showAddRepo
                    ? "Add a repository"
                    : "Create";

    private string DesktopCreatePopoverSubtitle => showCreateSessionPopover
        ? "Choose what kind of workspace you want to create."
        : showCreateSessionForm
            ? "Repo, folder, empty chat, or codespace."
        : isAddingGroup
            ? "Create a named container for related sessions."
            : isAddingMultiAgentGroup
                ? "Choose the repository this team should work in."
                : pendingMultiAgentRepo != null
                    ? "Name the team and choose the preset you want to launch."
                : showAddRepo
                    ? "Connect a repo URL or register an existing local clone."
                    : "Choose what kind of workspace you want to create.";

    private async Task ToggleDesktopRailMode()
    {
        if (!OnDesktopRailModeChanged.HasDelegate)
            return;

        if (!IsDesktopRailMode)
        {
            CloseFooterPanel();
            CloseCreatePopover();
        }

        await OnDesktopRailModeChanged.InvokeAsync(!IsDesktopRailMode);
    }

    private async Task ExpandSidebarFromRail()
    {
        if (IsDesktopRailMode && OnDesktopRailModeChanged.HasDelegate)
            await OnDesktopRailModeChanged.InvokeAsync(false);
    }

    private string? _pendingCreateSessionRepoId;

    private void OpenCreateSessionPopoverForRepo(string repoId)
    {
        if (UseDesktopCreateRail)
        {
            CloseFooterPanel();
            ResetDesktopCreateFlows();
            showCreateSessionForm = true;
            _pendingCreateSessionRepoId = repoId;
            StateHasChanged();
        }
        else
        {
            createSessionFormRef?.ExpandForRepo(repoId);
        }
    }

    private void ToggleCreateSessionPopover()
    {
        if (showCreateSessionPopover || showCreateSessionForm)
        {
            CloseCreatePopover();
            return;
        }

        CloseFooterPanel();
        ResetDesktopCreateFlows();
        showCreateSessionPopover = true;
    }

    private void StartAddSessionFromFloatingMenu()
    {
        PrepareDesktopCreateFlow();
        showCreateSessionPopover = false;
        showCreateSessionForm = true;
    }

    private void PrepareDesktopCreateFlow()
    {
        if (!UseDesktopCreateRail)
            return;

        CloseFooterPanel();
        showCreateSessionPopover = false;
        ResetDesktopCreateFlows();
    }

    private void CloseCreatePopover()
    {
        showCreateSessionPopover = false;
        showCreateSessionForm = false;
        ResetDesktopCreateFlows();
    }

    private void ResetDesktopCreateFlows()
    {
        isAddingGroup = false;
        isAddingMultiAgentGroup = false;
        pendingMultiAgentRepo = null;
        selectedStrategy = null;
        showCreateSessionForm = false;
        showAddRepo = false;
        addRepoError = null;
        addRepoFolderMode = false;
        addRepoFolderPath = "";
        addFolderMergedIntoGroupName = null;
        confirmRepoReplace = false;
        confirmRepoName = null;
        newRepoUrl = "";
    }

    private async Task ToggleSupportPanel()
    {
        if (IsDesktopRailMode)
        {
            await ExpandSidebarFromRail();
            OpenBugReport();
            return;
        }

        if (IsSupportPanelOpen)
            CloseFooterPanel();
        else
            OpenBugReport();
    }

    private void SwitchSupportPanel(bool showReportBug)
    {
        if (showReportBug)
            OpenBugReport();
        else
            OpenFixIt();
    }

    private async Task IncreaseFontSize()
    {
        if (FontSize < 24)
            await OnFontSizeChange.InvokeAsync(2);
    }

    private async Task DecreaseFontSize()
    {
        if (FontSize > 12)
            await OnFontSizeChange.InvokeAsync(-2);
    }

