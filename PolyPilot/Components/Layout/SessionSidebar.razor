        {
            var analysisName = await EfficiencyAnalysis.AnalyzeSessionAsync(sessionName);
            CopilotService.SwitchSession(analysisName);
            CopilotService.SaveUiState(currentPage);
            await OnSessionSelected.InvokeAsync();
        }
        catch (Exception ex)
        {
            footerStatus = $"✗ Efficiency analysis failed: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task ContinueInNewSession(string sessionName)
    {
