    private void RefreshFromPreset(string groupId)
    {
        var group = CopilotService.Organization.Groups.FirstOrDefault(g => g.Id == groupId);
        if (group == null) return;

        var worktreeRoot = string.IsNullOrEmpty(group.WorktreeId) ? null
            : RepoManager.Worktrees.FirstOrDefault(w => w.Id == group.WorktreeId)?.Path;

        var success = CopilotService.RefreshGroupFromPreset(groupId, worktreeRoot);
        if (success)
        {
            var orchestratorName = CopilotService.GetOrchestratorSession(groupId);
            if (orchestratorName != null)
            {
                var session = CopilotService.GetSession(orchestratorName);
                if (session != null)
                    session.History.Add(ChatMessage.SystemMessage($"🔄 Group settings refreshed from preset \"{group.SourcePresetName}\"."));
            }
        }
        StateHasChanged();
    }

