    private void LinkFiestaWorker()
    {
        fiestaLinkError = null;
        try
        {
            if (string.IsNullOrWhiteSpace(fiestaLinkUrl) || string.IsNullOrWhiteSpace(fiestaLinkToken))
            {
                fiestaLinkError = "Worker URL and token are required.";
                return;
