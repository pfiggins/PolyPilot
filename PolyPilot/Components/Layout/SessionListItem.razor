@using PolyPilot.Services
@using PolyPilot.Models
@using System.Diagnostics
@inject CopilotService CopilotService
@inject RepoManager RepoManager
@inject IJSRuntime JS

@{
    var isPinned = Meta?.IsPinned ?? false;
    var sessionDir = GetSessionDirectory();
    var cssClass = IsActive ? "active" : 
                   IsCompleted ? "completed" :
                   Session.IsProcessing ? "busy" : "";
    // Prefer SDK-reported context window; fall back to accumulated totals
    var hasContextWindow = Session.ContextCurrentTokens > 0 && Session.ContextTokenLimit > 0;
    var totalTokens = Session.TotalInputTokens + Session.TotalOutputTokens;
    var hasTokens = hasContextWindow || totalTokens > 0;
    var contextPct = hasContextWindow 
        ? Math.Min(100.0, (double)Session.ContextCurrentTokens!.Value / Session.ContextTokenLimit!.Value * 100) 
        : 0;
    var contextColor = contextPct > 85 ? "var(--accent-primary)" : contextPct > 60 ? "#fbbf24" : "var(--accent-success)";
}
<div class="session-item @cssClass @(isPinned ? "pinned" : "")"
     data-session-name="@Session.Name"
     @onclick="() => OnSelect.InvokeAsync()"
     @oncontextmenu="OpenContextMenu"
     @oncontextmenu:preventDefault="true">
    <div class="session-info">
        <span class="session-name">
            @if (ShortcutIndex is > 0 and <= 9)
            {
                <span class="shortcut-badge" title="⌘@ShortcutIndex">@ShortcutIndex</span>
            }
            @if (isPinned)
            {
                <span class="pin-badge" title="Pinned" @onclick="() => OnPin.InvokeAsync(false)" @onclick:stopPropagation="true">📌</span>
            }
            @if (IsCompleted)
            {
                <span class="done-badge">✅</span>
            }
            @if (IsRenaming)
            {
                <input type="text" class="rename-input" id="renameInput"
                       value="@Session.Name"
                       @onclick:stopPropagation="true"
                       @oncontextmenu:stopPropagation="true"
                       @onblur="() => OnCommitRename.InvokeAsync()"
                       @onkeyup="HandleRenameKeyUp" />
            }
            else
            {
                <span class="session-name-text" @ondblclick="() => OnStartRename.InvokeAsync()" @ondblclick:stopPropagation="true">@Session.Name</span>
                @if (Meta?.Role == MultiAgentRole.Orchestrator)
                {
                    <span class="role-badge orchestrator" title="Orchestrator">🎯</span>
                }
                @if (Session.UnreadCount > 0)
                {
                    <span class="unread-badge">@Session.UnreadCount</span>
                }
            }
        </span>
        <div class="session-meta-row">
            <span class="session-meta">
                @Session.MessageCount msgs@(Session.Model != "resumed" ? $" • {CopilotService.GetEffectiveModel(Session.Name)}" : "")
                @if (Meta?.PreferredModel != null && Meta.PreferredModel != Session.Model)
                {
                    <span class="model-override" title="Model override: @Meta.PreferredModel">⚡</span>
                }
                @if (Session.IsProcessing)
                {
                    <span class="processing"> • @GetShortProcessingStatus()</span>
                }
                @if (!string.IsNullOrEmpty(Session.WorkingDirectory))
                {
                    <text> • @GetShortPath(Session.WorkingDirectory)</text>
                }
            </span>
        </div>
        @if (hasContextWindow)
        {
            <div class="context-bar-row">
                <div class="context-bar-track">
                    <div class="context-bar-fill" style="width: @($"{contextPct:F0}")%; background: @contextColor;"></div>
                </div>
                <span class="context-bar-label">@FormatTokenCount(Session.ContextCurrentTokens!.Value)/@FormatTokenCount(Session.ContextTokenLimit!.Value)</span>
            </div>
        }
        else if (hasTokens)
        {
            <div class="context-bar-row">
                <span class="context-bar-label">↑@FormatTokenCount(Session.TotalInputTokens) ↓@FormatTokenCount(Session.TotalOutputTokens)</span>
            </div>
        }
    </div>
    <div class="session-actions">
        <button class="more-btn" @onclick:stopPropagation="true"
                @onclick="() => OnToggleMenu.InvokeAsync()" title="More actions">⋯</button>
        @if (IsMenuOpen)
        {
            <div class="menu-overlay" @onclick="() => OnCloseMenu.InvokeAsync()" @onclick:stopPropagation="true"></div>
            <div class="session-menu" @onclick:stopPropagation="true">
                <button class="menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); OnStartRename.InvokeAsync(); }">
                    ✏️ Rename
                </button>
                @if (isPinned)
                {
                    <button class="menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); OnPin.InvokeAsync(false); }">
                        📌 Unpin
                    </button>
                }
                else
                {
                    <button class="menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); OnPin.InvokeAsync(true); }">
                        📌 Pin
                    </button>
                }
                @if (Groups != null && Groups.Count > 1)
                {
                    <div class="menu-separator"></div>
                    <div class="menu-submenu">
                        <span class="menu-item submenu-label">📁 Move to…</span>
                        @foreach (var g in Groups)
                        {
                            if (g.Id == Meta?.GroupId) continue;
                            var targetId = g.Id;
                            <button class="menu-item submenu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); OnMove.InvokeAsync(targetId); }">
                                @g.Name
                            </button>
                        }
                    </div>
                }
                @{
                    var currentGroup = Groups?.FirstOrDefault(g => g.Id == Meta?.GroupId);
                }
                @if (currentGroup is { IsMultiAgent: true })
                {
                    <div class="menu-separator"></div>
                    @if (Meta?.Role == MultiAgentRole.Orchestrator)
                    {
                        <button class="menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); CopilotService.SetSessionRole(Session.Name, MultiAgentRole.Worker); }">
                            👷 Set as Worker
                        </button>
                    }
                    else
                    {
                        <button class="menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); CopilotService.SetSessionRole(Session.Name, MultiAgentRole.Orchestrator); }">
                            🎯 Set as Orchestrator
                        </button>
                    }
                    <div class="menu-separator"></div>
                    <span class="menu-item submenu-label">🧠 Model</span>
                    <div class="model-picker-inline" @onclick:stopPropagation="true">
                        <select value="@(Meta?.PreferredModel ?? "")" @onchange="OnPreferredModelChanged">
                            <option value="">Default (@Session.Model)</option>
                            @foreach (var model in CopilotService.AvailableModels)
                            {
                                var strengths = ModelCapabilities.GetStrengths(model);
                                <option value="@model" title="@strengths">@model</option>
                            }
                        </select>
                        @{
                            var effectiveModel = CopilotService.GetEffectiveModel(Session.Name);
                            var warnings = ModelCapabilities.GetRoleWarnings(effectiveModel, Meta?.Role ?? MultiAgentRole.Worker);
                        }
                        @if (warnings.Count > 0)
                        {
                            @foreach (var w in warnings)
                            {
                                <div class="model-warning">@w</div>
                            }
                        }
                        else
                        {
                            <div class="model-strengths">@ModelCapabilities.GetStrengths(effectiveModel)</div>
                        }
                    </div>
                }
                <div class="menu-separator"></div>
                <button class="menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); OnReportBug.InvokeAsync(); }">
                    🐛 Report Bug
                </button>
                @if (PlatformHelper.IsDesktop)
                {
                    <button class="menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); OnFixWithCopilot.InvokeAsync(); }">
                        🔧 Fix with Copilot
                    </button>
                }
                <div class="menu-separator"></div>
                @if (PlatformHelper.IsDesktop && !string.IsNullOrEmpty(Session.SessionId))
                {
                    <button class="menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); OpenInCopilotConsole(); }">
                        >_ Copilot Console
                    </button>
                }
                @if (PlatformHelper.IsDesktop && !string.IsNullOrEmpty(sessionDir))
                {
                    <button class="menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); OpenInVSCode(); }">
                        ⌨ VS Code
                    </button>
                    <div class="menu-separator"></div>
                }
                <button class="menu-item destructive" @onclick="ShowCloseConfirm">
                    🗑 Close Session…
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public AgentSessionInfo Session { get; set; } = null!;
    [Parameter] public SessionMeta? Meta { get; set; }
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public bool IsCompleted { get; set; }
    [Parameter] public bool IsRenaming { get; set; }
    [Parameter] public bool IsMenuOpen { get; set; }
    [Parameter] public int ShortcutIndex { get; set; }
    [Parameter] public List<SessionGroup>? Groups { get; set; }
    [Parameter] public SessionUsageInfo? UsageInfo { get; set; }

    [Parameter] public EventCallback OnSelect { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<(bool DeleteWorktree, bool DeleteBranch)> OnCloseWithOptions { get; set; }
    [Parameter] public EventCallback<bool> OnPin { get; set; }
    [Parameter] public EventCallback<string> OnMove { get; set; }
    [Parameter] public EventCallback OnStartRename { get; set; }
    [Parameter] public EventCallback OnCommitRename { get; set; }
    [Parameter] public EventCallback OnToggleMenu { get; set; }
    [Parameter] public EventCallback OnCloseMenu { get; set; }
    [Parameter] public EventCallback OnReportBug { get; set; }
    [Parameter] public EventCallback OnFixWithCopilot { get; set; }

    /// <summary>
    /// Show close confirmation via a JS-created dialog (outside Blazor's DOM tree).
    /// This avoids render batch corruption — portaling Blazor-managed elements to
    /// document.body breaks Blazor's DOM index tracking on component removal.
    /// </summary>
    private async Task ShowCloseConfirm()
    {
        await OnCloseMenu.InvokeAsync();
        try
        {
            bool hasWorktree = !string.IsNullOrEmpty(Meta?.WorktreeId);
            string branchName = "";
            if (hasWorktree)
            {
                var wt = RepoManager.Worktrees.FirstOrDefault(w => w.Id == Meta!.WorktreeId);
                branchName = wt?.Branch ?? "";
            }

            var result = await JS.InvokeAsync<CloseDialogResult>(
                "showCloseSessionDialog", Session.Name, hasWorktree, branchName);

            if (!result.Confirmed) return;

            if (hasWorktree && (result.DeleteWorktree || result.DeleteBranch))
                await OnCloseWithOptions.InvokeAsync((result.DeleteWorktree, result.DeleteBranch));
            else
                await OnClose.InvokeAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SessionListItem] ShowCloseConfirm error: {ex.Message}");
        }
    }

    private record CloseDialogResult(bool Confirmed, bool DeleteWorktree, bool DeleteBranch);

    private async Task OpenContextMenu(MouseEventArgs e)
    {
        if (!IsMenuOpen)
            await OnToggleMenu.InvokeAsync();
    }

    private async Task HandleRenameKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await OnCommitRename.InvokeAsync();
        else if (e.Key == "Escape") await OnCloseMenu.InvokeAsync();
    }

    private void OnPreferredModelChanged(ChangeEventArgs e)
    {
        var slug = e.Value?.ToString();
        CopilotService.SetSessionPreferredModel(Session.Name, string.IsNullOrEmpty(slug) ? null : slug);
    }

    private static string GetShortPath(string path)
    {
        var parts = path.Split(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
        if (parts.Length <= 2) return path;
        return "…/" + parts[^1];
    }

    private string GetShortProcessingStatus()
    {
        if (Session.ProcessingPhase == 0) return "Sending…";
        if (Session.ProcessingPhase == 1) return "Connected…";
        if (Session.ProcessingPhase == 2 && Session.ToolCallCount == 0) return "Thinking…";
        var parts = new List<string>();
        if (Session.ProcessingStartedAt.HasValue)
        {
            var elapsed = DateTime.UtcNow - Session.ProcessingStartedAt.Value;
            if (elapsed.TotalMinutes >= 1)
                parts.Add($"{(int)elapsed.TotalMinutes}m");
            else if (elapsed.TotalSeconds >= 5)
                parts.Add($"{(int)elapsed.TotalSeconds}s");
        }
        if (Session.ToolCallCount > 0)
            parts.Add($"{Session.ToolCallCount} tools");
        return parts.Count > 0 ? string.Join(" · ", parts) : "Working";
    }

    private string? GetSessionDirectory()
    {
        if (!string.IsNullOrEmpty(Session.WorkingDirectory))
            return Session.WorkingDirectory;
        // Fallback: resolve from worktree metadata
        if (Meta?.WorktreeId != null)
        {
            var wt = RepoManager.Worktrees.FirstOrDefault(w => w.Id == Meta.WorktreeId);
            if (wt != null) return wt.Path;
        }
        return null;
    }

    private void OpenInCopilotConsole()
    {
        var sessionId = Session.SessionId;
        if (string.IsNullOrEmpty(sessionId)) return;
        var dir = GetSessionDirectory() ?? Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        try
        {
            if (OperatingSystem.IsWindows())
            {
                // Use single quotes in PS script to prevent subexpression parsing of GUIDs/parens
                var psDir = dir.Replace("'", "''");
                var psName = Session.Name.Replace("'", "''");
                var psId = sessionId.Replace("'", "''");
                var psScript = Path.Combine(Path.GetTempPath(), $"polypilot-copilot-{Guid.NewGuid():N}.ps1");
                File.WriteAllText(psScript,
                    $"Set-Location '{psDir}'\n" +
                    $"Write-Host '🔗 Resuming session: {psName} ({psId})'\n" +
                    "Write-Host '─────────────────────────────────────────'\n" +
                    "Write-Host ''\n" +
                    $"copilot --resume '{psId}' --yolo\n");
                Process.Start(new ProcessStartInfo("powershell.exe",
                    $"-ExecutionPolicy Bypass -NoExit -File \"{psScript}\"")
                {
                    UseShellExecute = true,
                    WorkingDirectory = dir
                });
            }
            else
            {
                var safeDir = PlatformHelper.ShellEscape(dir);
                var safeName = PlatformHelper.ShellEscape(Session.Name);
                var safeId = PlatformHelper.ShellEscape(sessionId);

                var shellScript = Path.Combine(Path.GetTempPath(), $"polypilot-copilot-{Guid.NewGuid():N}.sh");
                File.WriteAllText(shellScript,
                    "#!/bin/bash\n" +
                    $"cd {safeDir}\n" +
                    $"echo '🔗 Resuming session:' {safeName} '('{safeId}')'\n" +
                    "echo '─────────────────────────────────────────'\n" +
                    "echo ''\n" +
                    $"copilot --resume {safeId} --yolo\n");
                Process.Start("chmod", $"+x \"{shellScript}\"")?.WaitForExit();
                Process.Start(new ProcessStartInfo("open", $"-a Terminal \"{shellScript}\"")
                {
                    UseShellExecute = false,
                    CreateNoWindow = true
                });
            }
        }
        catch { }
    }

    private void OpenInVSCode()
    {
        var dir = GetSessionDirectory();
        if (string.IsNullOrEmpty(dir)) return;
        try
        {
            // In remote mode, use --folder-uri with vscode-remote:// to open via Remote - Tunnels
            var remoteFolderUri = PlatformHelper.BuildVSCodeRemoteFolderUri(
                CopilotService.IsRemoteMode, CopilotService.ServerMachineName, dir);

            if (OperatingSystem.IsWindows())
            {
                var psi = new ProcessStartInfo
                {
                    FileName = "cmd.exe",
                    UseShellExecute = false,
                    CreateNoWindow = true
                };
                psi.ArgumentList.Add("/c");
                psi.ArgumentList.Add("code");
                if (remoteFolderUri != null)
                {
                    psi.ArgumentList.Add("--folder-uri");
                    psi.ArgumentList.Add(remoteFolderUri);
                }
                else
                {
                    psi.ArgumentList.Add(dir);
                }
                Process.Start(psi);
            }
            else
            {
                var psi = new ProcessStartInfo
                {
                    FileName = "code",
                    UseShellExecute = false
                };
                if (remoteFolderUri != null)
                {
                    psi.ArgumentList.Add("--folder-uri");
                    psi.ArgumentList.Add(remoteFolderUri);
                }
                else
                {
                    psi.ArgumentList.Add(dir);
                }
                Process.Start(psi);
            }
        }
        catch { }
    }

    private static string FormatTokenCount(int count) =>
        count >= 1000 ? $"{count / 1000}k" : count.ToString();
}
