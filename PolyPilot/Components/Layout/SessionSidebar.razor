            else
            {
                <div class="sidebar-create-section">
                    <span class="sidebar-create-section-label">Repository URL</span>
                    <input type="text" @bind="newRepoUrl" placeholder="owner/repo or full URL" class="repo-url-input sidebar-create-input" />
                </div>
                @if (confirmRepoReplace)
                {
                    <div class="repo-confirm">
                        <span>@confirmRepoName already exists. Re-fetch?</span>
                        <div class="repo-confirm-actions sidebar-create-actions">
                            <button class="btn-repo-cancel sidebar-create-button sidebar-create-button-secondary" @onclick="() => { confirmRepoReplace = false; confirmRepoName = null; }">Cancel</button>
                            <button class="btn-repo-add sidebar-create-button sidebar-create-button-primary" @onclick="ConfirmAddRepository">Re-fetch</button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="add-repo-actions sidebar-create-actions">
                        <button class="btn-repo-cancel sidebar-create-button sidebar-create-button-secondary" @onclick="CloseAddRepoForm">Cancel</button>
                        <button class="btn-repo-add sidebar-create-button sidebar-create-button-primary" @onclick="AddRepository" disabled="@(isAddingRepo || string.IsNullOrWhiteSpace(newRepoUrl))">
                            @(isAddingRepo ? "Cloning..." : "Add")
                        </button>
                    </div>
                }
            }
            @if (isAddingRepo && !string.IsNullOrEmpty(addRepoProgress))
            {
                <div class="repo-progress">@addRepoProgress</div>
            }
            @if (!string.IsNullOrEmpty(addRepoError))
            {
                <div class="repo-error">⚠ @addRepoError</div>
            }
        </div>
    };

    private RenderFragment RenderSessionList => __builder =>
    {
        @if (showAddRepo && !UseDesktopCreateRail)
        {
            @RenderAddRepoForm
        }

        <div class="session-list">
            @{
                var showGroupHeaders = _showGroupHeaders;
                var sessionIndex = 0;
                var regularGroups = _regularGroupModels;
                var codespaceGroups = _codespaceGroups;
            }

            @if (!sessions.Any() && !CopilotService.HasMultipleGroups)
            {
                <div class="section-header"><span class="section-header-label">Active Sessions</span></div>
                <p class="no-sessions">No active sessions.<br/>Create one above or resume below.</p>
            }

                @if (sessions.Any() && _statusFilter != SessionStatusFilter.All && !regularGroups.Any(g => g.AllSessions.Any()))
            {
                <p class="no-sessions" style="padding:1rem 0.5rem;font-style:italic;color:var(--text-dim)">No @(_statusFilter.ToString().ToLowerInvariant()) sessions</p>
            }

            @if (sessions.Any() || CopilotService.HasMultipleGroups)
            {
                @if (!showGroupHeaders)
                {
                    <div class="section-header"><span class="section-header-label">Active Sessions</span></div>
                }

                    @foreach (var groupModel in regularGroups)
                    {
                        var group = groupModel.Group;
                        var groupSessions = groupModel.AllSessions;
                        var groupProvider = CopilotService.GetProviderForGroup(group.Id);
                    @if (showGroupHeaders)
                    {
                        var isRepoGroup = !string.IsNullOrEmpty(group.RepoId);
                        var isLocalFolderGroup = group.IsLocalFolder;
                        var repoForGroup = isRepoGroup ? RepoManager.Repositories.FirstOrDefault(r => r.Id == group.RepoId) : null;
                        var groupTitle = repoForGroup != null ? $"{repoForGroup.Url}\n{repoForGroup.BareClonePath}" : "";
                        if (isLocalFolderGroup) groupTitle = group.LocalPath!;
                        var repoDiskSize = repoForGroup != null ? RepoManager.GetRepoDiskSize(repoForGroup.Id) : null;
                        var groupWt = !string.IsNullOrEmpty(group.WorktreeId)
                            ? RepoManager.Worktrees.FirstOrDefault(w => w.Id == group.WorktreeId)
                            : null;
                        var hasWorktree = groupWt != null;
                        var groupIconStateClass = group.IsCollapsed ? "is-collapsed" : "is-expanded";
                        var groupIconClass = groupProvider != null
                            ? null
                            : isLocalFolderGroup
                                ? (hasWorktree ? "folder-worktree" : "folder")
                                : isRepoGroup
                                    ? (hasWorktree ? "repo-worktree" : "repo")
                                    : group.IsMultiAgent
                                        ? "team"
                                        : null;
                        var groupIconTitle = groupProvider != null
                            ? groupProvider.DisplayName
                            : isLocalFolderGroup
                                ? (hasWorktree ? "Local folder worktree" : "Local folder")
                                : isRepoGroup
                                    ? (hasWorktree ? "Repository worktree" : "Repository")
                                    : group.IsMultiAgent
                                        ? "Multi-agent group"
                                        : "Group";
                        if (repoDiskSize.HasValue)
                            groupTitle += $"\nDisk: {RepoManager.FormatSize(repoDiskSize.Value)}";
                        if (hasWorktree)
                            groupTitle += $"\nWorktree: {groupWt!.Branch}\n{groupWt.Path}";
                        if (groupProvider != null)
                            groupTitle = groupProvider.GroupDescription;
                        <div class="group-header @(group.IsCollapsed ? "collapsed" : "") @(isRepoGroup || isLocalFolderGroup ? "repo-group" : "") @(groupProvider != null ? "provider-group" : "")"
                             title="@groupTitle"
                             style="@(groupProvider != null ? $"border-left-color: {groupProvider.AccentColor};" : "")"
                             @onclick="() => ToggleGroupCollapsedLocal(group.Id)">
                            <span class="group-chevron @(group.IsCollapsed ? "collapsed" : "expanded")" aria-hidden="true"></span>
                            @if (groupProvider != null)
                            {
                                <span class="group-repo-icon provider-icon" title="@groupProvider.DisplayName">@groupProvider.Icon</span>
                            }
                            else if (!string.IsNullOrEmpty(groupIconClass))
                            {
                                <span class="group-repo-icon @groupIconClass @groupIconStateClass" title="@groupIconTitle" aria-hidden="true"></span>
                            }
                            @if (renamingGroupId == group.Id)
                            {
                                var rgId = group.Id;
                                <input type="text" class="group-rename-input" id="groupRenameInput"
                                       value="@group.Name"
                                       @onclick:stopPropagation="true"
                                       @onblur="() => CommitGroupRename(rgId)"
                                       @onkeyup="(e) => HandleGroupRenameKeyUp(e, rgId)" />
                            }
                            else
                            {
                                <span class="group-name">@group.Name</span>
                            }
                            @if (group.IsMultiAgent || hasWorktree)
                            {
                                <span class="group-inline-badges">
                                    @if (group.IsMultiAgent)
                                    {
                                        <span class="group-mode-badge" title="Multi-agent team" aria-hidden="true"></span>
                                    }
                                    @if (hasWorktree)
                                    {
                                        <span class="group-worktree-badge"
                                              title="@($"Worktree branch: {groupWt!.Branch}\n{groupWt.Path}")"
                                              aria-hidden="true"></span>
                                    }
                                </span>
                            }
                            <div class="group-meta-strip">
                                <span class="group-count">@groupSessions.Count</span>
                                @if (group.IsCollapsed && groupSessions.Any(s => s.IsProcessing))
                                {
                                    <span class="group-busy-dot"></span>
                                }
                                @if (group.Id != SessionGroup.DefaultId)
                                {
                                    @if (isRepoGroup && confirmRemoveRepoId == group.RepoId)
                                    {
                                        var rId = group.RepoId!;
                                        var gId = group.Id;
                                        <span class="repo-remove-confirm" @onclick:stopPropagation="true">
                                            <span class="repo-remove-label">Delete folder?</span>
                                            <button class="btn-repo-rm" @onclick="() => RemoveRepo(rId, gId, true)">Yes</button>
                                            <button class="btn-repo-rm" @onclick="() => RemoveRepo(rId, gId, false)">No</button>
                                            <button class="btn-repo-rm cancel" @onclick="() => { confirmRemoveRepoId = null; }">Cancel</button>
                                        </span>
                                    }
                                    else
                                    {
                                        var gId = group.Id;
                                        <div class="group-menu-wrapper">
                                            <button class="group-more-btn" title="More actions"
                                                    @onclick="() => { openGroupMenuId = openGroupMenuId == gId ? null : gId; }"
                                                    @onclick:stopPropagation="true">…</button>
                                            @if (openGroupMenuId == group.Id)
                                            {
                                                <div class="group-menu-overlay" @onclick="() => { openGroupMenuId = null; }" @onclick:stopPropagation="true"></div>
                                                <div class="group-menu" @onclick:stopPropagation="true">
                                                    @if (isLocalFolderGroup)
                                                    {
                                                        var localFolderPath = group.LocalPath!;
                                                        <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; QuickCreateSessionForFolder(gId, localFolderPath); }">
                                                            ➕ New Session Here
                                                        </button>
                                                        @if (!string.IsNullOrEmpty(group.RepoId))
                                                        {
                                                            @* 📁 group backed by a bare clone — offer full branch/worktree features *@
                                                            var lfRepoId = group.RepoId!;
                                                            var lfLocalPath = group.LocalPath!;
                                                            <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; QuickCreateSessionForRepo(lfRepoId, gId, lfLocalPath); }">
                                                                ⚡ Quick Branch + Session
                                                            </button>
                                                            <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; StartQuickBranch(lfRepoId, gId, lfLocalPath); }">
                                                                ⑂ Named Branch + Session
                                                            </button>
                                                        }
                                                         <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; StartGroupRename(gId); }">
                                                             ✏️ Rename
                                                         </button>
                                                         @if (group.IsMultiAgent)
                                                         {
                                                             <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; PromptSaveAsPreset(gId); }">
                                                                 Save as Preset
                                                             </button>
                                                         }
                                                         <div class="group-menu-separator"></div>
                                                         <button class="group-menu-item destructive" @onclick="() => { openGroupMenuId = null; CopilotService.DeleteGroup(gId); }">
                                                             🗑 Remove Folder
                                                         </button>
                                                    }
                                                    else @if (isRepoGroup)
                                                    {
                                                        var rId = group.RepoId!;
                                                        <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; OpenCreateSessionPopoverForRepo(rId); }">
                                                            ➕ New Session
                                                        </button>
                                                        <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; QuickCreateSessionForRepo(rId); }">
                                                            ⚡ Quick Branch + Session
                                                        </button>
                                                        <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; StartQuickBranch(rId); }">
                                                            ⑂ Named Branch + Session
                                                        </button>
                                                         <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; StartGroupRename(gId); }">
                                                             ✏️ Rename
                                                         </button>
                                                         @if (group.IsMultiAgent)
                                                         {
                                                             <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; PromptSaveAsPreset(gId); }">
                                                                 Save as Preset
                                                             </button>
                                                         }
                                                         <div class="group-menu-separator"></div>
                                                         @if (group.IsMultiAgent)
                                                         {
                                                             <button class="group-menu-item destructive" @onclick="async () => { openGroupMenuId = null; await ShowDeleteGroupConfirm(gId, group.Name ?? gId); }">
                                                                 🗑 Delete Team…
                                                            </button>
                                                        }
                                                        @if (!group.IsMultiAgent)
                                                        {
                                                            <button class="group-menu-item destructive" @onclick="() => { openGroupMenuId = null; confirmRemoveRepoId = rId; }">
                                                                🗑 Remove Repo
                                                            </button>
                                                        }
                                                    }
                                                    else
                                                     {
                                                         <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; StartGroupRename(gId); }">
                                                             ✏️ Rename
                                                         </button>
                                                         @if (group.IsMultiAgent)
                                                         {
                                                             <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; PromptSaveAsPreset(gId); }">
                                                                 Save as Preset
                                                             </button>
                                                         }
                                                         @if (!group.IsMultiAgent)
                                                         {
                                                             <button class="group-menu-item" @onclick="() => { openGroupMenuId = null; CopilotService.ConvertToMultiAgent(gId); }">
                                                                 🤖 Convert to Multi-Agent
                                                             </button>
                                                            <div class="group-menu-separator"></div>
                                                        }
                                                        <button class="group-menu-item destructive" @onclick="async () => { openGroupMenuId = null; await ShowDeleteGroupConfirm(gId, group.Name ?? gId); }">
                                                            🗑 @(group.IsMultiAgent ? "Delete Team…" : "Delete Group…")
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        @if (quickBranchRepoId == group.RepoId && (isRepoGroup || isLocalFolderGroup))
                        {
                            var qbRepoId = group.RepoId!;
                            <div class="quick-branch-input-bar" @onclick:stopPropagation="true">
                                <span class="quick-branch-icon">⑂</span>
                                <input type="text" class="quick-branch-input" placeholder="branch name or #PR"
                                       @bind="quickBranchInput" @bind:event="oninput"
                                       @onkeyup="(e) => HandleQuickBranchKeyDown(e, qbRepoId)"
                                       disabled="@quickBranchIsCreating" />
                                @if (quickBranchIsCreating)
                                {
                                    <span class="quick-branch-spinner">⏳</span>
                                }
                                else
                                {
                                    <button class="quick-branch-go-btn" @onclick="() => CommitQuickBranch(qbRepoId)"
                                            disabled="@string.IsNullOrWhiteSpace(quickBranchInput)">→</button>
                                    <button class="quick-branch-cancel-btn" @onclick="() => { quickBranchRepoId = null; }">✕</button>
                                }
                                @if (!string.IsNullOrEmpty(quickBranchError))
                                {
                                    <div class="quick-branch-error">⚠ @quickBranchError</div>
                                }
                            </div>
                        }
                        @if (quickCreateErrorRepoId == group.RepoId && !string.IsNullOrEmpty(quickCreateError))
                        {
                            <div class="quick-branch-error" @onclick:stopPropagation="true">
                                ⚠ @quickCreateError
                                <button class="quick-branch-cancel-btn" @onclick="() => { quickCreateError = null; quickCreateErrorRepoId = null; }">✕</button>
                            </div>
                        }

                        @if (group.IsMultiAgent && !group.IsCollapsed && groupProvider == null)
                        {
                            var maGroupId = group.Id;
                            var maGroupDiagnostics = CopilotService.GetGroupDiagnostics(maGroupId)
                                .Where(d => !d.Message.Contains("uses premium model", StringComparison.OrdinalIgnoreCase))
                                .ToList();
                            var showInlineOrchestratorModeControl = false;
                            if (group.OrchestratorMode is MultiAgentMode.Orchestrator or MultiAgentMode.OrchestratorReflect)
                            {
                                var inlineOrchName = CopilotService.GetOrchestratorSession(group.Id);
                                showInlineOrchestratorModeControl = inlineOrchName != null && groupSessions.Any(s => s.Name == inlineOrchName);
                            }
                            var hasSidebarPhase = _groupPhases.TryGetValue(maGroupId, out var sidebarPhase);
                            var showTopModeRow = !showInlineOrchestratorModeControl;
                            var showTopControls = showTopModeRow
                                || group.OrchestratorMode == MultiAgentMode.OrchestratorReflect
                                || group.OrchestratorMode != MultiAgentMode.Orchestrator && group.OrchestratorMode != MultiAgentMode.OrchestratorReflect
                                || hasSidebarPhase
                                || maGroupDiagnostics.Count > 0;
                            @if (showTopControls)
                            {
                            <div class="sidebar-ma-controls" @onclick:stopPropagation="true">
                                @if (showTopModeRow)
                                {
                                    <div class="sidebar-ma-mode-row">
                                        <span class="sidebar-ma-mode-icon @GetSidebarMultiAgentModeIconClass(group.OrchestratorMode)" aria-hidden="true"></span>
                                        <select class="sidebar-ma-mode-select" aria-label="Orchestration mode" @onchange="(e) => OnSidebarMultiAgentModeChanged(maGroupId, e)">
                                            <option value="Broadcast" selected="@(group.OrchestratorMode == MultiAgentMode.Broadcast)">Broadcast</option>
                                            <option value="Sequential" selected="@(group.OrchestratorMode == MultiAgentMode.Sequential)">Sequential</option>
                                            <option value="Orchestrator" selected="@(group.OrchestratorMode == MultiAgentMode.Orchestrator)">Orchestrate</option>
                                            <option value="OrchestratorReflect" selected="@(group.OrchestratorMode == MultiAgentMode.OrchestratorReflect)">Reflect</option>
                                        </select>
                                    </div>
                                }
                                @if (group.OrchestratorMode == MultiAgentMode.OrchestratorReflect)
                                {
                                    <div class="reflect-iterations-bar">
                                        <label class="reflect-iter-label">Max iterations:</label>
                                        <input type="number" min="1" max="100" value="@GetGroupMaxIterations(maGroupId)"
                                               class="reflect-iter-input"
                                               @onchange="(e) => SetGroupMaxIterations(maGroupId, e)"
                                               @onclick:stopPropagation="true" />
                                    </div>
                                }
                                @if (group.OrchestratorMode != MultiAgentMode.Orchestrator && group.OrchestratorMode != MultiAgentMode.OrchestratorReflect)
                                {
                                <div class="sidebar-ma-input-bar">
                                    <textarea id="sidebar-ma-input-@maGroupId" class="sidebar-ma-input" placeholder="@GetInputPlaceholder(group.OrchestratorMode)" autocorrect="off" rows="1" @onclick:stopPropagation="true"></textarea>
                                    <button class="sidebar-ma-send-btn" @onclick="() => SendToSidebarMultiAgentGroup(maGroupId)" @onclick:stopPropagation="true" aria-label="Send to multi-agent group" title="Send to multi-agent group">
                                        <span class="sidebar-ma-send-icon" aria-hidden="true"></span>
                                    </button>
                                </div>
                                }
                                @if (hasSidebarPhase)
                                {
                                    <span class="phase-indicator">@PhaseLabel(sidebarPhase.Phase, sidebarPhase.Detail)</span>
                                }
                                @if (group.ReflectionState is { IsActive: true } rs)
                                {
                                    <div class="group-reflect-status">
                                        <span class="reflect-iter">
                                            <span class="sidebar-ma-inline-icon reflect-icon-cycle" aria-hidden="true"></span>
                                            @rs.CurrentIteration/@rs.MaxIterations
                                        </span>
                                        @if (rs.EvaluationHistory.Count > 0)
                                        {
                                            var lastEval = rs.EvaluationHistory.Last();
                                            <span class="reflect-score" title="@lastEval.Rationale">
                                                <span class="sidebar-ma-inline-icon reflect-icon-score" aria-hidden="true"></span>
                                                @lastEval.Score.ToString("F1") (@lastEval.EvaluatorModel)
                                            </span>
                                        }
                                        <span class="reflect-goal" title="@rs.Goal">@(rs.Goal.Length > 40 ? rs.Goal[..40] + "…" : rs.Goal)</span>
                                        <button class="reflect-stop-btn" @onclick="() => CopilotService.StopGroupReflection(maGroupId)" @onclick:stopPropagation="true" aria-label="Stop reflection cycle" title="Stop reflection cycle">
                                            <span class="sidebar-ma-inline-icon reflect-icon-stop" aria-hidden="true"></span>
                                        </button>
                                        <button class="reflect-pause-btn" @onclick="() => CopilotService.PauseGroupReflection(maGroupId, !rs.IsPaused)" @onclick:stopPropagation="true" aria-label="@(rs.IsPaused ? "Resume reflection cycle" : "Pause reflection cycle")" title="@(rs.IsPaused ? "Resume reflection cycle" : "Pause reflection cycle")">
                                            <span class="sidebar-ma-inline-icon @(rs.IsPaused ? "reflect-icon-play" : "reflect-icon-pause")" aria-hidden="true"></span>
                                        </button>
                                    </div>
                                    @if (rs.PendingAdjustments.Count > 0)
                                    {
                                        <div class="adjust-banner">
                                            @foreach (var adj in rs.PendingAdjustments)
                                            {
                                                <span>@adj</span>
                                            }
                                        </div>
                                    }
                                }
                                @if (maGroupDiagnostics.Count > 0)
                                {
                                    <div class="group-diagnostics">
                                        @foreach (var d in maGroupDiagnostics)
                                        {
                                            <span class="diag-@d.Level">@d.Message</span>
                                        }
                                    </div>
                                }
                                @{
                                    var settingsExpanded = _groupSettingsExpanded.Contains(maGroupId);
                                }
                                <div class="group-settings-toggle" @onclick="() => ToggleGroupSettings(maGroupId)" @onclick:stopPropagation="true">
                                    <span class="unpinned-chevron">@(settingsExpanded ? "▼" : "▶")</span>
                                    <span class="unpinned-label">⚙ Settings</span>
                                </div>
                                @if (settingsExpanded)
                                {
                                    <div class="group-settings-panel">
                                        <button class="save-preset-btn" @onclick="() => PromptSaveAsPreset(maGroupId)" @onclick:stopPropagation="true" title="Save this group as a reusable preset">💾 Save as Preset</button>
                                        <button class="save-preset-btn" @onclick="() => ExportGroupToSquadFolder(maGroupId)" @onclick:stopPropagation="true" title="Export this group to a .squad folder">📤 Export .squad</button>
                                        @if (!string.IsNullOrEmpty(group.SourcePresetName))
                                        {
                                            <button class="save-preset-btn" @onclick="() => RefreshFromPreset(maGroupId)" @onclick:stopPropagation="true" title="Refresh settings from preset '@group.SourcePresetName'">🔄 Refresh from Preset</button>
                                        }
                                    </div>
                                }
                            </div>
                            }
                        }
                    }

                    @if (!group.IsCollapsed || !showGroupHeaders)
                    {
                        <div class="group-session-tree @(showGroupHeaders ? "" : "ungrouped-tree") @(group.IsMultiAgent ? "multi-agent-tree" : "")">
                        @if (groupProvider != null)
                        {
                            var providerActions = groupProvider.GetActions();
                            @if (providerActions.Count > 0)
                            {
                                <div class="provider-actions-bar" style="padding: 4px 8px;">
                                    @foreach (var action in providerActions)
                                    {
                                        var actionProvider = groupProvider;
                                        var actionId = action.Id;
                                        <button class="provider-action-btn"
                                                title="@action.Tooltip"
                                                @onclick="() => ExecuteProviderAction(actionProvider, actionId)"
                                                @onclick:stopPropagation="true">
                                            @action.Label
                                        </button>
                                    }
                                </div>
                            }
                        }
                        @if (group.IsMultiAgent)
                        {
                            @* Multi-agent: orchestrator first, then workers as children.
                               GetFilteredSessions (pin-based splitting) is intentionally skipped here —
                               workers are presented as a collapsible unit under the orchestrator rather than
                               individually pin-filtered. The UnpinnedCollapsed flag drives the worker toggle. *@
                            var orchName = CopilotService.GetOrchestratorSession(group.Id);
                            var workerSessions = groupSessions.Where(s => s.Name != orchName).ToList();
                            var workerCount = workerSessions.Count;
                            var wToggleGroupId = group.Id;
                            var orchSession = orchName != null ? groupSessions.FirstOrDefault(s => s.Name == orchName) : null;
                            if (orchSession != null)
                            {
                                sessionIndex++;
                                var orchIdx = sessionIndex;
                                var orchMeta = CopilotService.GetSessionMeta(orchSession.Name);
                                var orchSName = orchSession.Name;
                                <SessionListItem Session="orchSession"
                                                 Meta="orchMeta"
                                                 CompactMode="IsDesktopRailMode"
                                                 IsActive="@(orchSession.Name == CopilotService.ActiveSessionName)"
                                                 IsCompleted="@completedSessions.Contains(orchSession.Name)"
                                                 IsDisabled="@(group.IsCodespace && group.ConnectionState != CodespaceConnectionState.Connected)"
                                                 IsRenaming="@(renamingSession == orchSession.Name)"
                                                 IsMenuOpen="@(openMenuSession == orchSession.Name)"
                                                 IsMultiAgentMember="true"
                                                 GroupName="@group.Name"
                                                 ShortcutIndex="orchIdx"
                                                 Groups="CopilotService.Organization.Groups"
                                                 UsageInfo="@(usageBySession.TryGetValue(orchSession.Name, out var orchUsg) ? orchUsg : null)"
                                                 OnSelect="() => SelectSession(orchSName)"
                                                 OnClose="() => CloseSession(orchSName)"
                                                 OnCloseWithOptions="(opts) => CloseSessionWithOptions(orchSName, opts.DeleteWorktree, opts.DeleteBranch)"
                                                 OnPin="(pinned) => { CopilotService.PinSession(orchSName, pinned); }"
                                                 OnMove="(groupId) => CopilotService.MoveSession(orchSName, groupId)"
                                                 OnStartRename="() => StartRename(orchSName)"
                                                 OnCommitRename="CommitRename"
                                                 OnToggleMenu="() => ToggleSessionMenu(orchSName)"
                                                 OnCloseMenu="() => { openMenuSession = null; }"
                                                 OnReportBug="() => OpenBugReportForSession(orchSName)"
                                                 OnFixWithCopilot="() => OpenFixItForSession(orchSName)"
                                                 OnAnalyze="() => AnalyzeSessionEfficiency(orchSName)"
                                                 OnContinueInNewSession="() => ContinueInNewSession(orchSName)"
                                                 ShowChildrenToggle="@(workerCount > 0)"
                                                 AreChildrenCollapsed="group.UnpinnedCollapsed"
                                                 ChildCount="@workerCount"
                                                 OnToggleChildren="() => ToggleUnpinnedCollapsedLocal(wToggleGroupId)"
                                                 ShowInlineModeControl="@(group.OrchestratorMode is MultiAgentMode.Orchestrator or MultiAgentMode.OrchestratorReflect)"
                                                 HideRoleBadge="@(group.OrchestratorMode is MultiAgentMode.Orchestrator or MultiAgentMode.OrchestratorReflect)"
                                                 InlineMode="group.OrchestratorMode"
                                                 OnInlineModeChanged="(mode) => OnSidebarMultiAgentModeChanged(group.Id, mode)" />
                            }
                            if (workerCount > 0)
                            {
                                var activeWorkerCount = workerSessions.Count(s => s.IsProcessing);
                                @if (orchSession == null)
                                {
                                    <div class="unpinned-toggle worker-toggle" @onclick="() => ToggleUnpinnedCollapsedLocal(wToggleGroupId)" @onclick:stopPropagation="true">
                                        <span class="unpinned-chevron @(group.UnpinnedCollapsed ? "collapsed" : "expanded")" aria-hidden="true"></span>
                                        <span class="unpinned-label">@workerCount @(workerCount != 1 ? "workers" : "worker")</span>
                                        @if (activeWorkerCount > 0)
                                        {
                                            <span class="worker-active-badge" title="@activeWorkerCount @(activeWorkerCount != 1 ? "workers" : "worker") currently processing">⚡ @activeWorkerCount active</span>
                                        }
                                    </div>
                                }
                                @if (!group.UnpinnedCollapsed)
                                {
                                    <div class="group-session-tree worker-session-tree">
                                        @foreach (var session in workerSessions)
                                        {
                                            sessionIndex++;
                                            var wIdx = sessionIndex;
                                            var wMeta = CopilotService.GetSessionMeta(session.Name);
                                            var wSName = session.Name;
                                            <SessionListItem Session="session"
                                                             Meta="wMeta"
                                                             CompactMode="IsDesktopRailMode"
                                                             IsActive="@(session.Name == CopilotService.ActiveSessionName)"
                                                             IsCompleted="@completedSessions.Contains(session.Name)"
                                                             IsDisabled="@(group.IsCodespace && group.ConnectionState != CodespaceConnectionState.Connected)"
                                                             IsWorkerChild="true"
                                                             IsMultiAgentMember="true"
                                                             GroupName="@group.Name"
                                                             IsRenaming="@(renamingSession == session.Name)"
                                                             IsMenuOpen="@(openMenuSession == session.Name)"
                                                             ShortcutIndex="wIdx"
                                                             Groups="CopilotService.Organization.Groups"
                                                             UsageInfo="@(usageBySession.TryGetValue(session.Name, out var wUsg) ? wUsg : null)"
                                                             OnSelect="() => SelectSession(wSName)"
                                                             OnClose="() => CloseSession(wSName)"
                                                             OnCloseWithOptions="(opts) => CloseSessionWithOptions(wSName, opts.DeleteWorktree, opts.DeleteBranch)"
                                                             OnPin="(pinned) => { CopilotService.PinSession(wSName, pinned); }"
                                                             OnMove="(groupId) => CopilotService.MoveSession(wSName, groupId)"
                                                             OnStartRename="() => StartRename(wSName)"
                                                             OnCommitRename="CommitRename"
                                                             OnToggleMenu="() => ToggleSessionMenu(wSName)"
                                                             OnCloseMenu="() => { openMenuSession = null; }"
                                                             OnReportBug="() => OpenBugReportForSession(wSName)"
                                                             OnFixWithCopilot="() => OpenFixItForSession(wSName)"
                                                             OnAnalyze="() => AnalyzeSessionEfficiency(wSName)"
                                                             OnContinueInNewSession="() => ContinueInNewSession(wSName)" />
                                        }
                                    </div>
                                }
                            }
                        }
                        else
                        {
                        @foreach (var session in groupModel.PinnedSessions)
                        {
                            sessionIndex++;
                            var idx = sessionIndex;
                            var meta = CopilotService.GetSessionMeta(session.Name);
                            var sName = session.Name;
                            <SessionListItem Session="session"
                                             Meta="meta"
                                             CompactMode="IsDesktopRailMode"
                                             IsActive="@(session.Name == CopilotService.ActiveSessionName)"
                                             IsCompleted="@completedSessions.Contains(session.Name)"
                                             IsDisabled="@(group.IsCodespace && group.ConnectionState != CodespaceConnectionState.Connected)"
                                             IsRenaming="@(renamingSession == session.Name)"
                                             IsMenuOpen="@(openMenuSession == session.Name)"
                                             ShortcutIndex="idx"
                                             Groups="CopilotService.Organization.Groups"
                                             UsageInfo="@(usageBySession.TryGetValue(session.Name, out var usg) ? usg : null)"
                                             OnSelect="() => SelectSession(sName)"
                                             OnClose="() => CloseSession(sName)"
                                             OnCloseWithOptions="(opts) => CloseSessionWithOptions(sName, opts.DeleteWorktree, opts.DeleteBranch)"
                                             OnPin="(pinned) => { CopilotService.PinSession(sName, pinned); }"
                                             OnMove="(groupId) => CopilotService.MoveSession(sName, groupId)"
                                             OnStartRename="() => StartRename(sName)"
                                             OnCommitRename="CommitRename"
                                             OnToggleMenu="() => ToggleSessionMenu(sName)"
                                             OnCloseMenu="() => { openMenuSession = null; }"
                                             OnReportBug="() => OpenBugReportForSession(sName)"
                                             OnFixWithCopilot="() => OpenFixItForSession(sName)"
                                             OnAnalyze="() => AnalyzeSessionEfficiency(sName)"
                                             OnContinueInNewSession="() => ContinueInNewSession(sName)" />
                        }
                        @if (groupModel.ShowUnpinnedToggle)
                        {
                            var toggleGroupId = group.Id;
                            var unpinnedCount = groupModel.UnpinnedCount;
                            <div class="unpinned-toggle" @onclick="() => ToggleUnpinnedCollapsedLocal(toggleGroupId)" @onclick:stopPropagation="true">
                                <span class="unpinned-chevron @(group.UnpinnedCollapsed ? "collapsed" : "expanded")" aria-hidden="true"></span>
                                <span class="unpinned-label">@(unpinnedCount) @(group.UnpinnedCollapsed ? "more" : "") @(unpinnedCount != 1 ? "sessions" : "session")</span>
                            </div>
                        }
                        @foreach (var session in groupModel.UnpinnedSessions)
                        {
                            sessionIndex++;
                            var idx = sessionIndex;
                            var meta = CopilotService.GetSessionMeta(session.Name);
                            var sName = session.Name;
                            <SessionListItem Session="session"
                                             Meta="meta"
                                             CompactMode="IsDesktopRailMode"
                                             IsActive="@(session.Name == CopilotService.ActiveSessionName)"
                                             IsCompleted="@completedSessions.Contains(session.Name)"
                                             IsRenaming="@(renamingSession == session.Name)"
                                             IsMenuOpen="@(openMenuSession == session.Name)"
                                             ShortcutIndex="idx"
                                             Groups="CopilotService.Organization.Groups"
                                             UsageInfo="@(usageBySession.TryGetValue(session.Name, out var usg2) ? usg2 : null)"
                                             OnSelect="() => SelectSession(sName)"
                                             OnClose="() => CloseSession(sName)"
                                             OnCloseWithOptions="(opts) => CloseSessionWithOptions(sName, opts.DeleteWorktree, opts.DeleteBranch)"
                                             OnPin="(pinned) => { CopilotService.PinSession(sName, pinned); }"
                                             OnMove="(groupId) => CopilotService.MoveSession(sName, groupId)"
                                             OnStartRename="() => StartRename(sName)"
                                             OnCommitRename="CommitRename"
                                             OnToggleMenu="() => ToggleSessionMenu(sName)"
                                             OnCloseMenu="() => { openMenuSession = null; }"
                                             OnReportBug="() => OpenBugReportForSession(sName)"
                                             OnFixWithCopilot="() => OpenFixItForSession(sName)"
                                             OnAnalyze="() => AnalyzeSessionEfficiency(sName)"
                                             OnContinueInNewSession="() => ContinueInNewSession(sName)" />
                        }
                        }
                        </div>
                    }
                }

                @if (CopilotService.CodespacesEnabled && codespaceGroups.Any())
                {
                    <div class="sidebar-divider"></div>
                    <div class="section-header"><span class="section-header-label" title="Alpha feature — may have rough edges">☁️ Codespaces <span style="font-size:var(--type-caption1);opacity:0.6">α</span></span></div>
                    @foreach (var (group, groupSessions) in codespaceGroups)
                    {
                        var csDisconnected = group.ConnectionState != CodespaceConnectionState.Connected;
                        var csState = group.ConnectionState;
                        var gId = group.Id;
                        @if (showGroupHeaders)
                        {
                        <div class="group-header codespace-group @(group.IsCollapsed ? "collapsed" : "") @(csDisconnected ? "cs-group-disabled" : "")"
                             title="GitHub Codespace: @group.CodespaceName"
                             @onclick="() => ToggleGroupCollapsedLocal(group.Id)">
                            <span class="group-chevron @(group.IsCollapsed ? "collapsed" : "expanded")" aria-hidden="true"></span>
                            <span class="group-repo-icon" title="GitHub Codespace">🖥️</span>
                            @if (csState == CodespaceConnectionState.Connected)
                            {
                                <span class="codespace-state-dot connected" title="Connected">●</span>
                            }
                            else if (csState == CodespaceConnectionState.Reconnecting)
                            {
                                var attempts = group.ReconnectAttempts;
                                <span class="codespace-state-dot reconnecting" title="Reconnecting... (attempt @attempts)">●</span>
                            }
                            else if (csState == CodespaceConnectionState.CodespaceStopped)
                            {
                                <span class="codespace-state-dot stopped" title="Codespace stopped">●</span>
