@using PolyPilot.Services
@using PolyPilot.Models
@inject IJSRuntime JS
@inject RepoManager RepoManager
@inject CopilotService CopilotService
@inject CodespaceService CodespaceService
@implements IDisposable

@if (!EmbeddedMode && (CompactMode || !isExpanded))
{
    <button class="new-session-btn @(CompactMode ? "compact" : "")" @onclick="HandleExpandClick" title="Create a new session">
        <span class="new-session-btn-icon">+</span>
        <span class="new-session-btn-copy">
            <span class="new-session-btn-title">New session</span>
            @if (!CompactMode)
            {
                <span class="new-session-btn-subtitle">Repo, folder, empty chat, or codespace</span>
            }
        </span>
    </button>
}
else
{
    <div class="new-session-form @(EmbeddedMode ? "new-session-form-embedded" : "")">
        @if (!EmbeddedMode)
        {
            <div class="new-session-form-header">
                <div class="new-session-form-copy">
                    <span class="new-session-form-eyebrow">Compose</span>
                    <span class="new-session-form-title">Start a focused session</span>
                    <span class="new-session-form-subtitle">@GetFormSubtitle()</span>
                </div>
                <button class="new-session-form-close" @onclick="Collapse" title="Collapse new session form">✕</button>
            </div>
        }

        @* Mode chips — shown only when repos exist *@
        @if (RepoManager.Repositories.Count > 0 || PlatformHelper.IsDesktop)
        {
            <div class="ns-mode-chips">
                @if (RepoManager.Repositories.Count > 0)
                {
                    <button class="ns-chip @(mode == FormMode.Repo ? "active" : "")" @onclick="() => SetMode(FormMode.Repo)">📦 Repo</button>
                }
                <button class="ns-chip @(mode == FormMode.Directory ? "active" : "")" @onclick="() => SetMode(FormMode.Directory)">📁 Directory</button>
                <button class="ns-chip @(mode == FormMode.Empty ? "active" : "")" @onclick="() => SetMode(FormMode.Empty)">💬 Empty</button>
                @if (PlatformHelper.IsDesktop && CopilotService.CodespacesEnabled)
                {
                    <button class="ns-chip @(mode == FormMode.Codespace ? "active" : "")" @onclick="() => SetMode(FormMode.Codespace)" title="Alpha feature">☁️ Codespace</button>
                }
            </div>
        }

        @* Repo mode: repo selector + worktree strategy *@
        @if (mode == FormMode.Repo)
        {
            @if (RepoManager.Repositories.Count > 1)
            {
                <select class="ns-repo-select" value="@selectedRepoId" @onchange="OnRepoChanged">
                    @foreach (var repo in RepoManager.Repositories)
                    {
                        <option value="@repo.Id">@repo.Name</option>
                    }
                </select>
            }
            else
            {
                <div class="ns-repo-label">📦 @RepoManager.Repositories[0].Name</div>
            }

            <div class="ns-wt-segment">
                <button class="ns-seg @(wtMode == WtMode.Auto ? "active" : "")" @onclick="() => SetWtMode(WtMode.Auto)">⚡ Auto</button>
                <button class="ns-seg @(wtMode == WtMode.Branch ? "active" : "")" @onclick="() => SetWtMode(WtMode.Branch)">⑂ Branch</button>
                <button class="ns-seg @(wtMode == WtMode.PR ? "active" : "")" @onclick="() => SetWtMode(WtMode.PR)"># PR</button>
                <button class="ns-seg @(wtMode == WtMode.Existing ? "active" : "")" @onclick="() => SetWtMode(WtMode.Existing)">📂 Existing</button>
            </div>

            @if (wtMode == WtMode.Branch)
            {
                <input type="text" @bind="branchInput" @bind:event="oninput" @onkeyup="HandleInputKeyUp"
                       placeholder="branch-name" class="ns-input" />
            }
            else if (wtMode == WtMode.PR)
            {
                <input type="text" @bind="prInput" @bind:event="oninput" @onkeyup="HandleInputKeyUp"
                       placeholder="PR # (e.g. 123)" class="ns-input" />
            }
            else if (wtMode == WtMode.Existing)
            {
                var repoWts = RepoManager.Worktrees.Where(w => w.RepoId == selectedRepoId).ToList();
                @if (repoWts.Count > 0)
                {
                    <select class="ns-repo-select" value="@selectedWorktreeId" @onchange="OnExistingWtChanged">
                        @foreach (var wt in repoWts)
                        {
                            <option value="@wt.Id">⑂ @wt.Branch @(wt.PrNumber.HasValue ? $"(#{wt.PrNumber})" : "")</option>
                        }
                    </select>
                }
                else
                {
                    <div class="ns-hint">No existing worktrees — try ⚡ Auto or ⑂ Branch</div>
                }
            }

            @if (!string.IsNullOrEmpty(worktreeError))
            {
                <div class="ns-error">⚠ @worktreeError</div>
            }
        }
        else if (mode == FormMode.Directory)
        {
            <div class="ns-dir-row">
                <input type="text" @bind="sessionDirectory" placeholder="Working directory..."
                       class="ns-input" style="flex:1" />
                <button class="ns-dir-browse" @onclick="BrowseDirectory">…</button>
            </div>
        }
        else if (mode == FormMode.Codespace)
        {
            @if (isLoadingCodespaces)
            {
                <div class="ns-hint">⏳ Discovering codespaces...</div>
            }
            else if (codespaces.Count == 0)
            {
                <div class="ns-hint">No codespaces found.</div>
                <button class="ns-cs-action" @onclick="LoadCodespacesAsync">🔄 Retry</button>
            }
            else
            {
                <div class="ns-codespace-list">
                    @foreach (var cs in codespaces)
                    {
                        var csName = cs.Name;
                        var alreadyAdded = CopilotService.Organization.Groups.Any(g => g.CodespaceName == csName);
                        var isConnecting = connectingCodespace == csName;
                        var isStopped = cs.State != "Available";
                        <div class="ns-codespace-row @(isStopped ? "ns-codespace-row-stopped" : "")">
                            <div class="ns-codespace-info">
                                <span class="ns-codespace-repo">@cs.Repository</span>
                                <span class="ns-codespace-name">@cs.Name</span>
                                @{
                                    var existingGroup = CopilotService.Organization.Groups.FirstOrDefault(g => g.CodespaceName == csName);
                                    var sshKnown = existingGroup?.SshAvailable;
                                }
                                <span class="ns-codespace-state @(cs.State == "Available" ? "state-available" : "")">● @cs.State@(sshKnown == false ? " · No SSH" : "")</span>
                            </div>
                            @if (alreadyAdded)
                            {
                                <span class="ns-codespace-added">✓ Added</span>
                            }
                            else if (cs.State == "Available")
                            {
                                <button class="ns-cs-action" @onclick="() => AddCodespaceAsync(csName)" disabled="@(connectingCodespace != null)">
                                    @if (isConnecting) { <text>⏳</text> } else { <text>+ Add</text> }
                                </button>
                            }
                            else
                            {
                                <button class="ns-cs-play" @onclick="() => StartAndAddCodespaceAsync(csName)" disabled="@(connectingCodespace != null)">▶ Start &amp; Add</button>
                            }
                        </div>
                        @if (isConnecting && !string.IsNullOrEmpty(connectingStatus))
                        {
                            <div class="ns-hint">@connectingStatus</div>
                        }
                    }
                </div>
                <button class="ns-cs-action" @onclick="LoadCodespacesAsync" style="margin-top:0.5rem">🔄 Refresh</button>
            }
            @if (!string.IsNullOrEmpty(codespaceError))
            {
                <div class="ns-error">
                    <span>⚠ @codespaceError</span>
                    <button class="ns-error-dismiss" @onclick="() => { codespaceError = null; StateHasChanged(); }">✕</button>
                </div>
            }
        }

        @if (mode != FormMode.Codespace)
        {
        <input type="text" value="@SessionName" @oninput="OnNameInput" @onkeyup="HandleKeyUp"
               placeholder="Session name..." class="ns-name" />
        <textarea @bind="initialPrompt" placeholder="What should this session do? (optional)"
                  class="ns-prompt" rows="2"></textarea>

        <div class="ns-footer">
            <ModelSelector Value="@SelectedModel" ValueChanged="OnModelSelected" Models="AvailableModels" CssClass="ns-model" />
            <div class="ns-footer-actions">
                <button class="ns-cancel" @onclick="Collapse">@(EmbeddedMode ? "Close" : "Cancel")</button>
                <button class="ns-create" @onclick="TriggerCreate"
                        disabled="@(IsCreating || isCreatingWorktree || string.IsNullOrWhiteSpace(SessionName))">
                    @if (IsCreating || isCreatingWorktree) { <span>…</span> } else { <span>Create</span> }
                </button>
            </div>
        </div>
        }
        else
        {
        <div class="ns-footer">
            <div></div>
            <div class="ns-footer-actions">
                <button class="ns-cancel" @onclick="Collapse">Close</button>
            </div>
        </div>
        }

        @if (!string.IsNullOrEmpty(CreateError))
        {
            <div class="ns-error">⚠ @CreateError</div>
        }
    </div>
}

@code {
    [Parameter] public bool IsCreating { get; set; }
    [Parameter] public string? CreateError { get; set; }
    [Parameter] public List<string> AvailableModels { get; set; } = new();
    [Parameter] public string SelectedModel { get; set; } = "claude-opus-4.6";
    [Parameter] public EventCallback<string> SelectedModelChanged { get; set; }
    [Parameter] public bool CompactMode { get; set; }
    [Parameter] public bool EmbeddedMode { get; set; }
    [Parameter] public EventCallback OnRequestExpandSidebar { get; set; }
    [Parameter] public EventCallback OnCloseRequested { get; set; }

    [Parameter] public EventCallback<(string Name, string Model, string? Directory, string? WorktreeId, string? InitialPrompt, string? RepoId, string? BranchName, int? PrNumber)> OnCreate { get; set; }
    [Parameter] public EventCallback OnBrowseDirectory { get; set; }
    [Parameter] public string SessionName { get; set; } = "";
    [Parameter] public EventCallback<string> SessionNameChanged { get; set; }

    private enum FormMode { Repo, Directory, Empty, Codespace }
    private enum WtMode { Auto, Branch, PR, Existing }

    private bool isExpanded;
    private FormMode mode;
    private WtMode wtMode = WtMode.Auto;
    private string? selectedRepoId;
    private string? selectedWorktreeId;
    private string branchInput = "";
    private string prInput = "";
    private string initialPrompt = "";
    private string sessionDirectory = "";
    private string? worktreeError;
    private bool isCreatingWorktree;
    private bool nameManuallyEdited;
    private bool _embeddedModeActive;

    private async Task HandleExpandClick()
    {
        if (CompactMode && OnRequestExpandSidebar.HasDelegate)
            await OnRequestExpandSidebar.InvokeAsync();

        Expand();
    }

    protected override void OnParametersSet()
    {
        if (EmbeddedMode)
        {
            if (!_embeddedModeActive)
            {
                Expand();
                _embeddedModeActive = true;
            }

            return;
        }

        _embeddedModeActive = false;

        if (CompactMode)
            isExpanded = false;
    }

    protected override void OnInitialized()
    {
        RepoManager.OnStateChanged += OnRepoStateChanged;
    }

    private void OnRepoStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        RepoManager.OnStateChanged -= OnRepoStateChanged;
    }

    private void Expand()
    {
        isExpanded = true;
        nameManuallyEdited = false;
        mode = RepoManager.Repositories.Count > 0 ? FormMode.Repo : FormMode.Empty;
        if (RepoManager.Repositories.Count > 0)
            selectedRepoId = RepoManager.Repositories[0].Id;
        AutoSelectFirstWorktree();
    }

    public void ExpandForRepo(string repoId)
    {
        isExpanded = true;
        nameManuallyEdited = false;
        mode = FormMode.Repo;
        selectedRepoId = repoId;
        wtMode = WtMode.Auto;
        AutoSelectFirstWorktree();
        StateHasChanged();
    }

    private void ResetFormFields()
    {
        isExpanded = false;
        worktreeError = null;
        branchInput = "";
        prInput = "";
        sessionDirectory = "";
        initialPrompt = "";
        selectedWorktreeId = null;
        nameManuallyEdited = false;
    }

    private async Task Collapse()
    {
        ResetFormFields();

        if (EmbeddedMode && OnCloseRequested.HasDelegate)
            await OnCloseRequested.InvokeAsync();
    }

    /// <summary>Called by the parent on successful session creation to close the form.</summary>
    public async Task CollapseOnSuccess()
    {
        ResetFormFields();

        if (EmbeddedMode && OnCloseRequested.HasDelegate)
            await OnCloseRequested.InvokeAsync();

        StateHasChanged();
    }

    private string GetFormSubtitle() => mode switch
    {
        FormMode.Repo => "Branch from a repo, attach to an existing worktree, or pick a PR.",
        FormMode.Directory => "Open a session inside any local working directory.",
        FormMode.Empty => "Start a blank chat when you just need a quick thought partner.",
        FormMode.Codespace => "Connect to a cloud workspace and drop straight into the task.",
        _ => "Choose the right workspace and model for the next task."
    };

    private void SetMode(FormMode newMode)
    {
        mode = newMode;
        worktreeError = null;
        if (!nameManuallyEdited) { SessionName = ""; _ = SessionNameChanged.InvokeAsync(""); }
        if (newMode == FormMode.Codespace && codespaces.Count == 0 && !isLoadingCodespaces)
            _ = LoadCodespacesAsync();
    }

    private void SetWtMode(WtMode newWtMode)
    {
        wtMode = newWtMode;
        worktreeError = null;
        branchInput = "";
        prInput = "";
        if (newWtMode == WtMode.Existing)
            AutoSelectFirstWorktree();
        if (!nameManuallyEdited) UpdateAutoName();
    }

    private void OnRepoChanged(ChangeEventArgs e)
    {
        selectedRepoId = e.Value?.ToString();
        if (wtMode == WtMode.Existing) AutoSelectFirstWorktree();
        if (!nameManuallyEdited) UpdateAutoName();
    }

    private void OnExistingWtChanged(ChangeEventArgs e)
    {
        selectedWorktreeId = e.Value?.ToString();
        if (!nameManuallyEdited) UpdateAutoName();
    }

    private void AutoSelectFirstWorktree()
    {
        if (selectedRepoId == null) return;
        var first = RepoManager.Worktrees.FirstOrDefault(w => w.RepoId == selectedRepoId);
        selectedWorktreeId = first?.Id;
    }

    private void UpdateAutoName()
    {
        if (nameManuallyEdited) return;
        string? auto = null;
        if (mode == FormMode.Repo)
        {
            if (wtMode == WtMode.Branch && !string.IsNullOrWhiteSpace(branchInput))
                auto = branchInput.Trim();
            else if (wtMode == WtMode.PR && !string.IsNullOrWhiteSpace(prInput))
                auto = $"PR #{prInput.Trim().TrimStart('#')}";
            else if (wtMode == WtMode.Existing && selectedWorktreeId != null)
            {
                var wt = RepoManager.Worktrees.FirstOrDefault(w => w.Id == selectedWorktreeId);
                if (wt != null) auto = wt.Branch;
            }
        }
        if (auto != null)
        {
            SessionName = auto;
            _ = SessionNameChanged.InvokeAsync(auto);
        }
    }

    private async Task OnNameInput(ChangeEventArgs e)
    {
        SessionName = e.Value?.ToString() ?? "";
        nameManuallyEdited = !string.IsNullOrWhiteSpace(SessionName);
        await SessionNameChanged.InvokeAsync(SessionName);
    }

    private async Task OnModelSelected(string model)
    {
        SelectedModel = model;
        await SelectedModelChanged.InvokeAsync(model);
    }

    private async Task HandleInputKeyUp(KeyboardEventArgs e)
    {
        if (!nameManuallyEdited) UpdateAutoName();
        if (e.Key == "Enter") await TriggerCreate();
        else if (e.Key == "Escape") await Collapse();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await Collapse();
        else if (e.Key == "Enter") await TriggerCreate();
    }

    private async Task TriggerCreate()
    {
        if (string.IsNullOrWhiteSpace(SessionName) || IsCreating || isCreatingWorktree) return;

        var prompt = string.IsNullOrWhiteSpace(initialPrompt) ? null : initialPrompt.Trim();
        string? repoId = null;
        string? branchName = null;
        int? prNumber = null;
        string? wtId = null;
        string? dir = mode == FormMode.Empty ? null : "";

        if (mode == FormMode.Repo && selectedRepoId != null)
        {
            repoId = selectedRepoId;
            if (wtMode == WtMode.Auto)
            {
                // Auto-generate branch name from session name
                var sanitized = System.Text.RegularExpressions.Regex.Replace(SessionName.Trim(), @"[^a-zA-Z0-9_-]", "-").Trim('-');
                if (string.IsNullOrEmpty(sanitized)) sanitized = "session";
                branchName = $"{sanitized}-{Guid.NewGuid().ToString()[..4]}";
            }
            else if (wtMode == WtMode.Branch)
            {
                if (string.IsNullOrWhiteSpace(branchInput)) { worktreeError = "Enter a branch name"; return; }
                branchName = branchInput.Trim();
            }
            else if (wtMode == WtMode.PR)
            {
                if (!int.TryParse(prInput.Trim().TrimStart('#'), out var pr) || pr <= 0)
                { worktreeError = "Enter a valid PR number"; return; }
                prNumber = pr;
            }
            else if (wtMode == WtMode.Existing)
            {
                if (string.IsNullOrEmpty(selectedWorktreeId)) { worktreeError = "Select a worktree"; return; }
                wtId = selectedWorktreeId;
            }
        }
        else if (mode == FormMode.Directory)
        {
            dir = sessionDirectory;
        }

        worktreeError = null;
        await OnCreate.InvokeAsync((SessionName, SelectedModel, dir, wtId, prompt, repoId, branchName, prNumber));
        // Note: form collapse is handled by the parent calling CollapseOnSuccess() on success.
        // On error, the parent sets CreateError which is displayed in this form — we intentionally
        // stay open so the user can see the error without needing to click "New Session" again.
    }

    private async Task BrowseDirectory()
    {
#if MACCATALYST || WINDOWS
        try
        {
            var dir = await FolderPickerService.PickFolderAsync();
            if (!string.IsNullOrEmpty(dir))
            { sessionDirectory = dir; StateHasChanged(); }
        }
        catch (Exception ex) { Console.WriteLine($"Folder picker error: {ex.Message}"); }
#else
        await OnBrowseDirectory.InvokeAsync();
#endif
    }

    public void SetDirectory(string path)
    {
        sessionDirectory = path;
        StateHasChanged();
    }

    // ── Codespace mode ──
    private List<CodespaceService.CodespaceInfo> codespaces = new();
    private bool isLoadingCodespaces;
    private string? connectingCodespace;
    private string connectingStatus = "";
    private string? codespaceError;
    private CancellationTokenSource? _errorDismissCts;

    private void SetCodespaceError(string message)
    {
        codespaceError = message;
        _errorDismissCts?.Cancel();
        _errorDismissCts = new CancellationTokenSource();
        var ct = _errorDismissCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(10_000, ct);
                await InvokeAsync(() => { codespaceError = null; StateHasChanged(); });
            }
            catch (OperationCanceledException) { }
        });
    }

    private async Task LoadCodespacesAsync()
    {
        isLoadingCodespaces = true;
        codespaceError = null;
        StateHasChanged();
        try
        {
            codespaces = await CodespaceService.ListCodespacesAsync();
        }
        catch (Exception ex)
        {
            SetCodespaceError(ex.Message);
        }
        finally
        {
            isLoadingCodespaces = false;
            StateHasChanged();
        }
    }

    private async Task AddCodespaceAsync(string codespaceName)
    {
        var cs = codespaces.FirstOrDefault(c => c.Name == codespaceName);
        if (cs == null || cs.State != "Available") return;

        connectingCodespace = codespaceName;
        connectingStatus = "Starting...";
        codespaceError = null;
        StateHasChanged();
        try
        {
            var group = await CopilotService.CreateCodespaceGroupAsync(
                codespaceName,
                cs.Repository ?? "",
                onProgress: msg => { connectingStatus = msg; InvokeAsync(StateHasChanged); });

            if (group.ConnectionState == CodespaceConnectionState.SetupRequired)
                connectingStatus = "Setup required — opened in browser. Install SSHD and start copilot.";
            else if (group.ConnectionState == CodespaceConnectionState.WaitingForCopilot)
                connectingStatus = $"Copilot not running — run: copilot --headless --port {group.CodespacePort}";
            Collapse();
        }
        catch (Exception ex)
        {
            SetCodespaceError(ex.Message);
        }
        finally
        {
            connectingCodespace = null;
            connectingStatus = "";
            StateHasChanged();
        }
    }

    private async Task StartAndAddCodespaceAsync(string codespaceName)
    {
        var cs = codespaces.FirstOrDefault(c => c.Name == codespaceName);
        if (cs == null) return;

        codespaceError = null;
        connectingCodespace = codespaceName;
        connectingStatus = "Starting codespace...";
        StateHasChanged();
        try
        {
            CopilotService.AddStoppedCodespaceGroup(codespaceName, cs.Repository ?? "");
            connectingStatus = "Codespace starting — check sidebar for status";
            StateHasChanged();
            // Brief delay so user sees the status before collapse
            await Task.Delay(1500);
            Collapse();
        }
        catch (Exception ex)
        {
            SetCodespaceError(ex.Message);
        }
        finally
        {
            connectingCodespace = null;
            connectingStatus = "";
            StateHasChanged();
        }
    }
}
