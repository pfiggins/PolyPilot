@using PolyPilot.Models
@using PolyPilot.Services
@using PolyPilot.Components
@using Microsoft.JSInterop

@switch (Message.MessageType)
{
    case ChatMessageType.User:
        var _primaryUserCopyText = ChatCopyPayloads.GetPrimaryCopyText(Message);
        var _fullPromptCopyText = ChatCopyPayloads.GetOrchestrationPromptCopyText(Message);
        <div class="chat-msg user">
            @if (!Compact)
            {
                <div class="chat-msg-avatar">
                    @if (!string.IsNullOrEmpty(UserAvatarUrl))
                    {
                        <img src="@UserAvatarUrl" width="36" height="36" alt="You" class="user-avatar-img" />
                    }
                    else
                    {
                        <text>👤</text>
                    }
                </div>
            }
            <div class="chat-msg-content copyable-bubble">
                @if (!Compact && !string.IsNullOrEmpty(_primaryUserCopyText))
                {
                    <CopyToClipboardButton Text="@_primaryUserCopyText"
                                           Title="Copy message"
                                           CopiedTitle="Copied message"
                                           CssClass="message-copy-btn bubble-copy-btn" />
                }
                @if (Compact)
                {
                    <span class="chat-msg-role">You</span>
                }
                @if (!string.IsNullOrEmpty(Message.OriginalContent) && ChatMessageList.IsWorkerPrompt(Message.Content))
                {
                    @((MarkupString)ChatMessageList.RenderWorkerPromptSections(Message.Content, Message.OriginalContent, CollapseOriginalContent))
                }
                else if (ChatMessageList.IsWorkerPrompt(Message.Content))
                {
                    @((MarkupString)ChatMessageList.RenderWorkerPromptSections(Message.Content))
                }
                else if (!string.IsNullOrEmpty(Message.OriginalContent))
                {
                    @((MarkupString)ChatMessageList.RenderOrchestratorPromptSections(Message.Content, Message.OriginalContent, CollapseOriginalContent))
                }
                else if (ChatMessageList.IsOrchestratorPrompt(Message.Content))
                {
                    @((MarkupString)ChatMessageList.RenderOrchestratorPromptSections(Message.Content))
                }
                else
                {
                    <div class="chat-msg-text">@((MarkupString)ChatMessageList.FormatUserMessage(Message.Content))</div>
                }
                @if (!Compact)
                {
                    <div class="chat-msg-time">@Message.Timestamp.ToShortTimeString()</div>
                }
            </div>
        </div>
        break;

    case ChatMessageType.Assistant:
        var _assistantCopyText = ChatCopyPayloads.GetPrimaryCopyText(Message);
        <div class="chat-msg assistant @(IsStreaming ? "streaming" : "")">
            @if (!Compact)
            {
                <div class="chat-msg-avatar"><img src="PolyPilot_logo.png" width="36" height="36" alt="PolyPilot" /></div>
            }
            <div class="chat-msg-content copyable-bubble">
                @if (!Compact && !string.IsNullOrEmpty(_assistantCopyText))
                {
                    <CopyToClipboardButton Text="@_assistantCopyText"
                                           Title="Copy message"
                                           CopiedTitle="Copied message"
                                           CssClass="message-copy-btn bubble-copy-btn" />
                }
                @if (Compact)
                {
                    <span class="chat-msg-role">AI</span>
                }
                <div class="chat-msg-text markdown-body">@((MarkupString)ChatMessageList.RenderMarkdown(Message.Content, RepoUrl))</div>
                @if (!Compact && !IsStreaming)
                {
                    <div class="chat-msg-time">@Message.Timestamp.ToShortTimeString()@(!string.IsNullOrEmpty(Message.Model) ? $" · {Message.Model}" : "")</div>
                }
            </div>
        </div>
        break;

    case ChatMessageType.Reasoning:
        @if (Compact)
        {
            <div class="chat-msg reasoning">
                <span class="chat-msg-role reasoning-role-icon" aria-hidden="true"></span>
                <span class="chat-msg-text">@(Message.IsComplete ? "Thought" : "Thinking...")</span>
            </div>
        }
        else
        {
            var _reasoningCopyText = ChatCopyPayloads.GetPrimaryCopyText(Message);
            <div class="reasoning-block @(Message.IsCollapsed && ChatMessageList.LineCount(Message.Content) > 5 ? "collapsed" : "")">
                <div class="reasoning-header">
                    <button type="button" class="reasoning-toggle" @onclick="() => Message.IsCollapsed = !Message.IsCollapsed">
                        <span class="reasoning-title">
                            <span class="reasoning-icon" aria-hidden="true"></span>
                            <span>@(Message.IsComplete ? "Thought" : "Thinking...")</span>
                        </span>
                        @if (ChatMessageList.LineCount(Message.Content) > 5)
                        {
                            <span class="collapse-icon">@(Message.IsCollapsed ? "▶" : "▼")</span>
                        }
                    </button>
                    @if (!string.IsNullOrEmpty(_reasoningCopyText))
                    {
                        <CopyToClipboardButton Text="@_reasoningCopyText"
                                               Title="Copy reasoning"
                                               CopiedTitle="Copied reasoning"
                                               CssClass="message-copy-btn inline-copy-btn" />
                    }
                </div>
                @if (!Message.IsCollapsed || ChatMessageList.LineCount(Message.Content) <= 5)
                {
                    <div class="reasoning-content">@Message.Content</div>
                }
                else
                {
                    <div class="reasoning-content preview">@ChatMessageList.FirstLines(Message.Content, 3)</div>
                }
            </div>
        }
        break;

    case ChatMessageType.ToolCall:
        @if (Compact)
        {
            <div class="chat-msg tool">
                <span class="chat-msg-role">🔧</span>
                <span class="chat-msg-text">@ChatMessageList.FormatToolName(Message.ToolName ?? "tool") @(Message.IsComplete ? (Message.IsSuccess ? "✓" : "✗") : "…")</span>
            </div>
        }
        else if (Message.ToolName == "task_complete")
        {
            var _taskCompleteCopyText = ChatCopyPayloads.GetPrimaryCopyText(Message);
            <div class="task-complete-card copyable-status-card">
                @if (!string.IsNullOrEmpty(_taskCompleteCopyText))
                {
                    <CopyToClipboardButton Text="@_taskCompleteCopyText"
                                           Title="Copy completion message"
                                           CopiedTitle="Copied completion message"
                                           CssClass="message-copy-btn status-copy-btn" />
                }
                ✅
                <span class="task-complete-text">@(string.IsNullOrEmpty(Message.Content) || ChatMessageList.IsUnusableResult(Message.Content) ? "Task complete" : Message.Content)</span>
            </div>
        }
        else
        {
            var _hasOutput = Message.IsComplete && !string.IsNullOrEmpty(Message.Content) && !ChatMessageList.IsUnusableResult(Message.Content);
            var _hasInputDetails = !string.IsNullOrEmpty(Message.ToolInput);
            var _hasImageOutput = !string.IsNullOrEmpty(Message.ImageDataUri) || ChatMessageList.GetImagePath(Message.Content) is string _;
            var _hasDiffOutput = _hasOutput && !_hasImageOutput && DiffParser.ShouldRenderDiffView(Message.Content, Message.ToolName);
            var _outputLineCount = _hasOutput && !_hasImageOutput ? ChatMessageList.LineCount(Message.Content) : 0;
            var _canExpand = _hasOutput || _hasInputDetails;
            var _inputCopyText = ChatCopyPayloads.GetToolInputCopyText(Message);
            var _outputCopyText = ChatCopyPayloads.GetToolOutputCopyText(Message);
            @* Unified compact command box: one summary row, details only when expanded *@
            <div class="action-box @(ChatMessageList.GetActionLabel(Message.ToolName ?? "").CssClass) @(Message.IsComplete ? (Message.IsSuccess ? "done" : "failed") : "running") @(Message.IsCollapsed ? "collapsed" : "expanded")">
                <div class="action-header @(_canExpand ? "expandable" : "")"
                     @onclick="() => { if (_canExpand) Message.IsCollapsed = !Message.IsCollapsed; }"
                     @onclick:stopPropagation="true">
                    <span class="action-dot"></span>
                    <span class="action-label">@(ChatMessageList.GetActionLabel(Message.ToolName ?? "").Label)</span>
                    <span class="action-desc @(ChatMessageList.IsPathTool(Message.ToolName ?? "") ? "truncate-head" : "")">@ChatMessageList.FormatActionDescriptionCompact(Message.ToolName ?? "", Message.ToolInput, Message.Content, Message.IsComplete)</span>
                    <span class="action-controls">
                    @if (_hasOutput && _hasImageOutput)
                    {
                        <span class="action-meta-hint">image</span>
                    }
                    @if (_canExpand)
                    {
                        <span class="action-chevron @(Message.IsCollapsed ? "collapsed" : "expanded")" aria-hidden="true"></span>
                    }
                    </span>
                </div>
                @if (!Message.IsCollapsed)
                {
                    @if (_hasInputDetails)
                    {
                        <div class="action-full-input">
                            <div class="action-detail-meta">
                                <span>Input</span>
                                @if (!string.IsNullOrEmpty(_inputCopyText))
                                {
                                    <CopyToClipboardButton Text="@_inputCopyText"
                                                           Title="Copy tool input"
                                                           CopiedTitle="Copied tool input"
                                                           CssClass="message-copy-btn action-copy-btn" />
                                }
                            </div>
                            <pre>@ChatMessageList.FormatToolInputExpanded(Message.ToolName ?? "", Message.ToolInput ?? "")</pre>
                        </div>
                    }
                    @if (_hasOutput)
                    {
                        <div class="action-output">
                            <div class="action-detail-meta">
                                <span>Output</span>
                                <span class="action-detail-hint">
                                    @if (_hasImageOutput)
                                    {
                                        <span>image</span>
                                    }
                                    else if (_outputLineCount > 0)
                                    {
                                        <span>@_outputLineCount line@(_outputLineCount != 1 ? "s" : "")</span>
                                    }
                                    @if (!string.IsNullOrEmpty(_outputCopyText))
                                    {
                                        <CopyToClipboardButton Text="@_outputCopyText"
                                                               Title="Copy tool output"
                                                               CopiedTitle="Copied tool output"
                                                               CssClass="message-copy-btn action-copy-btn" />
                                    }
                                </span>
                            </div>
                            @if (GetToolOutputImage(Message) is string toolImgUri)
                            {
                                <img src="@toolImgUri" alt="image" />
                            }
                            else if (_hasDiffOutput)
                            {
                                var _parsedDiff = DiffParser.Parse(Message.Content);
                                if (_parsedDiff.Count > 0)
                                {
                                    <div class="action-output-diff">
                                        <DiffView RawDiff="@Message.Content" />
                                    </div>
                                }
                                else
                                {
                                    <pre>@ChatMessageList.TruncateResult(Message.Content)</pre>
                                }
                            }
                            else if (DiffParser.TryExtractNumberedViewOutput(Message.Content, out var _plainViewOutput))
                            {
                                <pre>@ChatMessageList.TruncateResult(_plainViewOutput)</pre>
                            }
                            else
                            {
                                <pre>@ChatMessageList.TruncateResult(Message.Content)</pre>
                            }
                        </div>
                    }
                    else if (Message.ToolName == "bash" && !string.IsNullOrEmpty(Message.ToolInput))
                    {
                        <div class="action-output action-output-empty">
                            <div class="action-detail-meta">
                                <span>Awaiting output</span>
                            </div>
                        </div>
                    }
                    else if (!Message.IsComplete)
                    {
                        <div class="action-output action-output-empty">
                            <div class="action-detail-meta">
                                <span>Awaiting result</span>
                            </div>
                        </div>
                    }
                    else if (Message.IsComplete && !_hasOutput && Message.ToolName != "bash")
                    {
                        <div class="action-output action-output-empty">
                            <div class="action-detail-meta">
                                <span>No output</span>
                            </div>
                        </div>
                    }

                }
            </div>
        }
        break;
 
    case ChatMessageType.Error:
        var _errorCopyText = ChatCopyPayloads.GetPrimaryCopyText(Message);
        <div class="@(Compact ? "chat-msg error" : "error-card copyable-status-card")">
            @if (Compact)
            {
                <span class="chat-msg-role">⚠️</span>
                <span class="chat-msg-text">@Message.Content</span>
            }
            else
            {
                @if (!string.IsNullOrEmpty(_errorCopyText))
                {
                    <CopyToClipboardButton Text="@_errorCopyText"
                                           Title="Copy error"
                                           CopiedTitle="Copied error"
                                           CssClass="message-copy-btn status-copy-btn" />
                }
                <span class="error-icon">⚠️</span>
                <span class="error-text">@Message.Content</span>
            }
        </div>
        break;

    case ChatMessageType.System:
        var _systemCopyText = ChatCopyPayloads.GetPrimaryCopyText(Message);
        <div class="chat-msg system @(Message.Content.Contains("\n-") ? "system-multiline" : "")">
            <div class="system-copy-panel">
                @if (!Compact && !string.IsNullOrEmpty(_systemCopyText))
                {
                    <CopyToClipboardButton Text="@_systemCopyText"
                                           Title="Copy system message"
                                           CopiedTitle="Copied system message"
                                           CssClass="message-copy-btn panel-copy-btn" />
                }
                <div class="system-text markdown-body">@((MarkupString)ChatMessageList.RenderMarkdown(Message.Content, RepoUrl))</div>
            </div>
        </div>
        break;

    case ChatMessageType.ShellOutput:
        var _shellCopyText = ChatCopyPayloads.GetPrimaryCopyText(Message);
        <div class="chat-msg shell-output">
            <div class="shell-output-panel">
                @if (!Compact && !string.IsNullOrEmpty(_shellCopyText))
                {
                    <CopyToClipboardButton Text="@_shellCopyText"
                                           Title="Copy shell output"
                                           CopiedTitle="Copied shell output"
                                           CssClass="message-copy-btn panel-copy-btn" />
                }
                <pre class="shell-output-text copyable-shell-output">@Message.Content</pre>
            </div>
        </div>
        break;

    case ChatMessageType.Diff:
        <div class="chat-msg diff-msg">
            <DiffView RawDiff="@Message.Content" />
        </div>
        break;

    case ChatMessageType.Reflection:
        @if (TryGetReflectionData(Message.Content, out var rData))
        {
            <div class="chat-msg reflection-card">
                <div class="reflection-header">
                    <span class="reflection-pill-small">Reflection Cycle</span>
                    <span>Iteration @rData.Iteration / @rData.Max</span>
                    @{var _reflectionCardCopyText = ChatCopyPayloads.GetPrimaryCopyText(Message);}
                    @if (!Compact && !string.IsNullOrEmpty(_reflectionCardCopyText))
                    {
                        <CopyToClipboardButton Text="@_reflectionCardCopyText"
                                               Title="Copy reflection"
                                               CopiedTitle="Copied reflection"
                                               CssClass="message-copy-btn inline-copy-btn" />
                    }
                </div>
                <div class="reflection-body">
                    <div class="reflection-goal">Target: @rData.Goal</div>
                    <div class="reflection-status">
                        <span>@rData.Status</span>
                    </div>
                    <div class="reflection-progress-track">
                        <div class="reflection-progress-bar" style="width: @(rData.Max > 0 ? Math.Min(100, (double)rData.Iteration / rData.Max * 100) : 0)%"></div>
                    </div>
                </div>
            </div>
        }
        else
        {
            var _reflectionTextCopyText = ChatCopyPayloads.GetPrimaryCopyText(Message);
            <div class="chat-msg reflection">
                <div class="reflection-text-panel">
                    @if (!Compact && !string.IsNullOrEmpty(_reflectionTextCopyText))
                    {
                        <CopyToClipboardButton Text="@_reflectionTextCopyText"
                                               Title="Copy reflection"
                                               CopiedTitle="Copied reflection"
                                               CssClass="message-copy-btn panel-copy-btn" />
                    }
                    <div class="reflection-text">@Message.Content</div>
                </div>
            </div>
        }
        break;

    case ChatMessageType.Image:
        @if (GetImageSource(Message) is string _imgSrc)
        {
            <div class="chat-msg assistant image-bubble">
                <div class="image-bubble-content">
                    <img src="@_imgSrc" alt="@(Message.Caption ?? "Image")" class="image-bubble-img" />
                    @if (!string.IsNullOrEmpty(Message.Caption))
                    {
                        <div class="image-bubble-caption">@Message.Caption</div>
                    }
                </div>
            </div>
        }
        else if (!Message.IsComplete)
        {
            <div class="chat-msg assistant image-bubble">
                <div class="image-bubble-content loading">
                    <span>📷 Preparing image…</span>
                </div>
            </div>
        }
        break;
}

@code {
    [Parameter] public ChatMessage Message { get; set; } = default!;
    [Parameter] public bool Compact { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public bool CollapseOriginalContent { get; set; }
    [Parameter] public string? UserAvatarUrl { get; set; }
    [Parameter] public string? RepoUrl { get; set; }

    private static string? GetImageSource(ChatMessage msg) =>
        msg.ImageDataUri ?? (!string.IsNullOrEmpty(msg.ImagePath) ? ChatMessageList.FileToDataUri(msg.ImagePath) : null);

    /// <summary>Lazy image loading for tool output — persists + caches on first expand.</summary>
    private static string? GetToolOutputImage(ChatMessage msg)
    {
        // Already loaded (cached from previous expand or bridge)
        if (!string.IsNullOrEmpty(msg.ImageDataUri)) return msg.ImageDataUri;

        var path = ChatMessageList.GetImagePath(msg.Content);
        if (string.IsNullOrEmpty(path)) return null;

        return ChatMessageList.PersistAndLoadImage(path, msg);
    }

    private bool TryGetReflectionData(string content, out ReflectionData data)
    {
        data = default;
        if (string.IsNullOrWhiteSpace(content) || !content.TrimStart().StartsWith("{")) return false;
        try
        {
            var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            data = System.Text.Json.JsonSerializer.Deserialize<ReflectionData>(content, options);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private struct ReflectionData
    {
        public int Iteration { get; set; }
        public int Max { get; set; }
        public string Goal { get; set; }
        public string Status { get; set; }
    }
}
