    private async Task DoAddRepository()
    {
        isAddingRepo = true;
        addRepoProgress = null;
        try
        {
            await CopilotService.AddRepoRemoteAsync(newRepoUrl.Trim(), progress =>
            {
                addRepoProgress = progress;
                InvokeAsync(StateHasChanged);
            });
            showAddRepo = false;
            newRepoUrl = "";
        }
        catch (Exception ex)
        {
            addRepoError = ex.Message;
        }
        finally
        {
            isAddingRepo = false;
            addRepoProgress = null;
        }
    }

