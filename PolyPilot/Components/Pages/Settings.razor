@page "/settings"
@using PolyPilot.Services
@using PolyPilot.Models
@inject CopilotService CopilotService
@inject ServerManager ServerManager
@inject DevTunnelService DevTunnelService
@inject WsBridgeServer WsBridgeServer
@inject TailscaleService TailscaleService
@inject QrScannerService QrScanner
@inject GitAutoUpdateService GitAutoUpdate
@inject FiestaService FiestaService
@inject RepoManager RepoManager
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IServiceProvider ServiceProvider
@implements IDisposable

<div class="settings-page">
    <div class="settings-header">
        <div class="header-row">
            <h2>Settings</h2>
            <div class="header-right">
                <div class="settings-search">
                    <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" class="search-input" id="settings-search" placeholder="Search..." />
                    @if (!string.IsNullOrEmpty(searchQuery))
                    {
                        <button class="search-clear" @onclick="ClearSearch">×</button>
                    }
                </div>

            </div>
        </div>
    </div>

    <div class="settings-body">
        @if (string.IsNullOrWhiteSpace(searchQuery))
        {
        <nav class="settings-nav">
            @if (!PlatformHelper.IsMobile || CopilotService.IsInitialized || PlatformHelper.AvailableModes.Length > 1)
            {
                <button class="settings-nav-item @(activeCategory == "connection" ? "active" : "")" @onclick='() => ScrollToCategory("connection")'>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>
                    Connection
                </button>
            }


            <button class="settings-nav-item @(activeCategory == "ui" ? "active" : "")" @onclick='() => ScrollToCategory("ui")'>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                UI
            </button>
            @if (GitAutoUpdate.IsAvailable || PlatformHelper.IsDesktop)
            {
                <button class="settings-nav-item @(activeCategory == "developer" ? "active" : "")" @onclick='() => ScrollToCategory("developer")'>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                    Developer
                </button>
            }
            @if (PlatformHelper.IsDesktop)
            {
                <button class="settings-nav-item @(activeCategory == "plugins" ? "active" : "")" @onclick='() => ScrollToCategory("plugins")'>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6l3-3"/><path d="M12 2v6l-3-3"/><rect x="3" y="14" width="18" height="8" rx="2"/><circle cx="8" cy="18" r="1"/><circle cx="16" cy="18" r="1"/></svg>
                    Plugins
                </button>
                <button class="settings-nav-item @(activeCategory == "diagnostics" ? "active" : "")" @onclick='() => ScrollToCategory("diagnostics")'>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    Diagnostics
                </button>
            }
        </nav>
        }

        <div class="settings-content" id="settings-scroll-container">

    @if (!PlatformHelper.IsMobile || CopilotService.IsInitialized || PlatformHelper.AvailableModes.Length > 1)
    {
    <div id="settings-connection" class="settings-group @(GroupVisible("connection") ? "" : "search-hidden")">
        <h2 class="group-title">Connection</h2>

    @if (PlatformHelper.AvailableModes.Length > 1)
    {
        <div class="settings-section @(SectionVisible("transport mode embedded persistent remote") ? "" : "search-hidden") @((settings.Mode == ConnectionMode.Remote || (PlatformHelper.IsDesktop && (settings.Mode == ConnectionMode.Embedded || settings.Mode == ConnectionMode.Persistent))) ? "mode-linked-root" : "")">
            <h3>Transport Mode</h3>
            <div class="mode-cards">
                @foreach (var mode in PlatformHelper.AvailableModes)
                {
                    <div class="mode-card @(settings.Mode == mode ? "selected" : "")"
                         @onclick="() => SetMode(mode)">
                        <div class="mode-icon">@GetModeIcon(mode)</div>
                        <div class="mode-title">@mode</div>
                        <div class="mode-desc">@GetModeDescription(mode)</div>
                    </div>
                }
            </div>
            @if (settings.Mode != _initialMode)
            {
                <div class="mode-changed-hint">
                    <span>⚡ Mode changed to <strong>@settings.Mode</strong> — reconnect to apply.</span>
                    <button class="reconnect-inline-btn" @onclick="SaveAndApply">Reconnect Now</button>
                </div>
            }
        </div>
    }

    @if (settings.Mode == ConnectionMode.Persistent)
    {
        <div class="mode-linked-panel @(SectionVisible("persistent server port start stop pid") ? "" : "search-hidden")">
            <h3>Persistent Server</h3>
            <div class="server-controls">
                <div class="server-status">
                    <span class="status-dot @(serverAlive ? "alive" : "dead")"></span>
                    <span>@(serverAlive ? $"Running on port {settings.Port}" : "Not running")</span>
                    @if (ServerManager.ServerPid != null && serverAlive)
                    {
                        <span class="pid-label">PID @ServerManager.ServerPid</span>
                    }
                </div>
                <div class="port-input">
                    <label>Port:</label>
                    <input type="number" @bind="settings.Port" min="1024" max="65535" />
                </div>
                <div class="server-buttons">
                    @if (!serverAlive)
                    {
                        <button class="start-btn" @onclick="StartServer" disabled="@starting">
                            @if (starting) {<svg class="icon spin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg><text> Starting...</text>}
                            else {<svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg><text> Start Server</text>}
                        </button>
                    }
                    else
                    {
                        <button class="stop-btn" @onclick="StopServer"><svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="1"/></svg> Stop Server</button>
                    }
                </div>
            </div>
        </div>
    }

    @if (PlatformHelper.IsDesktop && (settings.Mode == ConnectionMode.Embedded || settings.Mode == ConnectionMode.Persistent))
    {
        <div class="mode-linked-panel @(SectionVisible("devtunnel share tunnel remote mobile qr") ? "" : "search-hidden")">
            <h3>Share via DevTunnel</h3>
                @if (devTunnelAvailable == null)
                {
                    <div class="tunnel-checking">
                        <svg class="icon spin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
                        <span>Checking for devtunnel CLI…</span>
                    </div>
                }
                else if (devTunnelAvailable == false)
                {
                    <div class="tunnel-warning">
                        <p><svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> <code>devtunnel</code> CLI not found. Install it to share your server remotely.</p>
                        <p class="hint">Run: <code>winget install Microsoft.devtunnel</code> (Windows) or <code>brew install --cask devtunnel</code> (macOS)</p>
                    </div>
                }
                else
                {
                    <div class="tunnel-controls">
                        <div class="server-status">
                            <span class="status-dot @(DevTunnelService.State == TunnelState.Running ? "alive" : DevTunnelService.State == TunnelState.Error ? "error" : "dead")"></span>
                            <span>@GetTunnelStatusText()</span>
                        </div>

                        @if (DevTunnelService.State == TunnelState.NotStarted || DevTunnelService.State == TunnelState.Error)
                        {
                            @if (!tunnelLoggedIn)
                            {
                                <button class="start-btn" @onclick="TunnelLogin" disabled="@tunnelBusy">
                                    @if (tunnelBusy) {<svg class="icon spin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg><text> Authenticating...</text>}
                                    else {<svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg><text> Login with GitHub</text>}
                                </button>
                            }
                            else
                            {
                                <button class="start-btn" @onclick="StartTunnel" disabled="@tunnelBusy">
                                    @if (tunnelBusy) {<svg class="icon spin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg><text> Starting tunnel...</text>}
                                    else {<svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2 15 22 11 13 2 9z"/></svg><text> Start Tunnel</text>}
                                </button>
                            }

                            @if (DevTunnelService.State == TunnelState.Error)
                            {
                                <p class="tunnel-error">@DevTunnelService.ErrorMessage</p>
                            }
                        }
                        else if (DevTunnelService.State == TunnelState.Running)
                        {
                            <div class="tunnel-url-section">
                                <div class="tunnel-url">
                                    <code>@DevTunnelService.TunnelUrl</code>
                                    <button class="copy-btn" @onclick="CopyTunnelUrl" title="Copy URL"><svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
                                </div>

                                @if (!string.IsNullOrEmpty(DevTunnelService.AccessToken))
                                {
                                    <div class="tunnel-token">
                                        <label>Token:</label>
                                        <code class="token-value @(showToken ? "" : "blurred")">@DevTunnelService.AccessToken</code>
                                        <button class="copy-btn" @onclick="() => showToken = !showToken" title="@(showToken ? "Hide" : "Reveal")">@if (showToken) {<svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>} else {<svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>}</button>
                                        <button class="copy-btn" @onclick="CopyTunnelToken" title="Copy Token"><svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(qrCodeDataUri))
                                {
                                    <div class="qr-code">
                                        <img src="@qrCodeDataUri" alt="QR Code" class="@(showQrCode ? "" : "blurred")" />
                                        <button class="qr-reveal-btn" @onclick="() => showQrCode = !showQrCode" title="@(showQrCode ? "Hide QR" : "Reveal QR")">@if (showQrCode) {<svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>} else {<svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>}</button>
                                        <p class="qr-hint">Scan with PolyPilot on iOS/Android to connect</p>
                                    </div>
                                }
                            </div>

                            <button class="stop-btn" @onclick="StopTunnel"><svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="1"/></svg> Stop Tunnel</button>
                        }
                        else
                        {
                            <p class="tunnel-status-text">@GetTunnelStatusText()</p>
                        }
                    </div>
                }
            </div>
        }

    @if (PlatformHelper.IsDesktop && (settings.Mode == ConnectionMode.Embedded || settings.Mode == ConnectionMode.Persistent))
    {
        <div class="mode-linked-panel mode-linked-last @(SectionVisible("direct connection sharing tailscale lan password qr") ? "" : "search-hidden")">
            <h3>Direct Connection</h3>
            <div class="tunnel-controls">
                <p class="mode-hint">Share your server directly over LAN, Tailscale, or VPN — no DevTunnel needed.</p>
                <div class="onboarding-steps">
                    <p class="onboarding-heading"><strong>🖥️ Setting up this machine as a Fiesta worker?</strong></p>
                    <ol class="onboarding-list">
                        <li>Set a password below and click <strong>Enable Direct Sharing</strong>.</li>
                        <li>Copy the <strong>pairing string</strong> (<code>pp+…</code>) that appears.</li>
                        <li>On the <strong>host machine</strong>, go to Settings → Fiesta Workers → paste the string → click <strong>Link</strong>.</li>
                        <li>The host can then dispatch tasks to this machine using <code>@@worker-name</code> mentions in chat.</li>
                    </ol>
                </div>

                <div class="url-input">
                    <label>Password:</label>
                    <input type="password" @bind="settings.ServerPassword" placeholder="Set a password for remote access" class="form-input wide" />
                </div>

                @if (!WsBridgeServer.IsRunning)
                {
                    <button class="start-btn" @onclick="StartDirectSharing" disabled="@(string.IsNullOrWhiteSpace(settings.ServerPassword))">
                        <svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2 15 22 11 13 2 9z"/></svg> Enable Direct Sharing
                    </button>
                    @if (string.IsNullOrWhiteSpace(settings.ServerPassword))
                    {
                        <p class="hint">Set a password above to enable direct sharing.</p>
                    }
                }
                else
                {
                    <div class="server-status">
                        <span class="status-dot alive"></span>
                        <span>@(WsBridgeServer.SupportsRemoteConnections
                            ? $"Listening on port {DevTunnelService.BridgePort}"
                            : "Listening on localhost only")</span>
                    </div>

                    <div class="tunnel-url-section">
                        @if (!WsBridgeServer.SupportsRemoteConnections)
                        {
                            <p class="tunnel-error">Direct sharing could only bind to localhost, so phones and other PCs cannot connect directly. Use Tunnel instead.</p>
                        }
                        else if (TailscaleService.IsRunning)
                        {
                            <div class="tunnel-url">
                                <label>✅ Tailscale:</label>
                                <code>http://@(TailscaleService.MagicDnsName ?? TailscaleService.TailscaleIp):@DevTunnelService.BridgePort</code>
                                <button class="copy-btn" @onclick="CopyDirectUrl" title="Copy URL"><svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
                            </div>
                        }
                        else
                        {
                            <div class="onboarding-steps">
                                <p class="onboarding-heading"><strong>🌐 Want to use Fiesta across different networks?</strong></p>
                                <p>Install <a href="https://tailscale.com/download" target="_blank">Tailscale</a> (free) to connect machines that aren't on the same LAN.</p>
                                <ol class="onboarding-list">
                                    <li>Download from <a href="https://tailscale.com/download" target="_blank">tailscale.com/download</a></li>
                                    <li>Install and sign in on both machines (same account)</li>
                                    <li>Restart PolyPilot — it auto-detects Tailscale</li>
                                </ol>
                                <p class="hint">Tailscale creates a secure private network between your devices, so Fiesta pairing strings work across the internet.</p>
                            </div>
                        }
                        @if (WsBridgeServer.SupportsRemoteConnections)
                        {
                            @foreach (var ip in localIps)
                            {
                                <div class="tunnel-url">
                                    <label>LAN:</label>
                                    <code>http://@ip:@DevTunnelService.BridgePort</code>
                                </div>
                            }
                        }

                        @if (WsBridgeServer.SupportsRemoteConnections && fiestaPairingString != null)
                        {
                            <div class="tunnel-url">
                                <label>Pairing string:</label>
                                <code class="token-value @(showFiestaPairingString ? "" : "blurred")">@fiestaPairingString</code>
                                <button class="copy-btn" @onclick="() => showFiestaPairingString = !showFiestaPairingString"
                                        title="@(showFiestaPairingString ? "Hide" : "Reveal")">
                                    @if (showFiestaPairingString)
                                    {
                                        <svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                    }
                                    else
                                    {
                                        <svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    }
                                </button>
                                <button class="copy-btn" @onclick="CopyFiestaPairingString" title="Copy to clipboard">
                                    <svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                </button>
                            </div>
                            <p class="hint">Paste this string into the hub machine's Settings → Fiesta Workers → "Paste pairing string" field.</p>
                        }

                        @if (!string.IsNullOrEmpty(directQrCodeDataUri))
                        {
                            <div class="qr-code">
                                <img src="@directQrCodeDataUri" alt="QR Code" class="@(showDirectQrCode ? "" : "blurred")" />
                                <button class="qr-reveal-btn" @onclick="() => showDirectQrCode = !showDirectQrCode" title="@(showDirectQrCode ? "Hide QR" : "Reveal QR")">@if (showDirectQrCode) {<svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>} else {<svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>}</button>
                                <p class="qr-hint">Scan with PolyPilot on iOS/Android to connect</p>
                            </div>
                        }
                    </div>

                    <button class="stop-btn" @onclick="StopDirectSharing"><svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="1"/></svg> Stop Direct Sharing</button>
                }
            </div>
        </div>
    }

    @if (PlatformHelper.IsDesktop && (settings.Mode == ConnectionMode.Embedded || settings.Mode == ConnectionMode.Persistent))
    {
        <div class="mode-linked-panel @(SectionVisible("fiesta workers discovery link remove hostname pair pairing") ? "" : "search-hidden")">
            <h3>Fiesta Workers</h3>
            <div class="tunnel-controls">
                <div class="onboarding-steps">
                    <p class="onboarding-heading">
                        <strong class="onboarding-heading-inline">
                            <span class="onboarding-heading-icon" aria-hidden="true">
                                <svg viewBox="0 0 20 20">
                                    <path d="M5.2 13.6 11.5 7.3"></path>
                                    <path d="m10.7 6.6 2.7-1.1 1.1 2.7-2.7 1.1z"></path>
                                    <path d="M4.6 14.2 3.7 17l2.8-.9 5.4-5.4-1.9-1.9z"></path>
                                    <path d="M12.8 4.4V2.8"></path>
                                    <path d="M15.6 5.5 17 4.7"></path>
                                    <path d="m15 8.4 1.5.5"></path>
                                    <path d="M7.7 4.9 9 6.2"></path>
                                </svg>
                            </span>
                            <span>How Fiesta works</span>
                        </strong>
                    </p>
                    <p class="mode-hint">Fiesta lets this machine act as a <strong>hub</strong> that dispatches work to linked worker machines on your LAN.</p>
                    <ol class="onboarding-list">
                        <li><strong>On each worker machine:</strong> open Settings → Direct Connection → set a password → click <strong>Enable Direct Sharing</strong> → copy the <code>pp+…</code> pairing string.</li>
                        <li><strong>Here (hub):</strong> paste that string into the field below and click <strong>Link</strong>. The worker appears in "Linked workers".</li>
                        <li><strong>In any chat:</strong> use <code>@@worker-name</code> to send a task to that machine. It runs autonomously and returns results.</li>
                    </ol>
                </div>
                <p class="mode-hint">Discovered workers require manual linking before they can be used in Fiesta mode.</p>

                @* Incoming pair requests (worker side) *@
                @foreach (var req in FiestaService.PendingPairRequests)
                {
                    var secondsLeft = Math.Max(0, (int)(req.ExpiresAt - DateTime.UtcNow).TotalSeconds);
                    <div class="pair-request-banner">
                        <p><strong>@req.HostName</strong> (<code>@req.RemoteIp</code>) wants to pair with this machine. <span class="pair-expiry">Expires in @secondsLeft s</span></p>
                        <div class="pair-request-actions">
                            <button class="start-btn" @onclick="() => ApproveFiestaPairRequest(req.RequestId)">Allow</button>
                            <button class="stop-btn" @onclick="() => DenyFiestaPairRequest(req.RequestId)">Deny</button>
                        </div>
                    </div>
                }

                @* Worker side — show pairing string when bridge is running *@
                @if (WsBridgeServer.IsRunning && WsBridgeServer.SupportsRemoteConnections && fiestaPairingString != null)
                {
                    <div class="tunnel-url-section">
                        <label>Your pairing string:</label>
                        <p class="mode-hint">Copy this on the worker machine and paste it on the hub to link instantly. Works via RDP clipboard, SSH, or any text channel.</p>
                        <div class="tunnel-url">
                            <code class="token-value @(showFiestaPairingString ? "" : "blurred")">@fiestaPairingString</code>
                            <button class="copy-btn" @onclick="() => showFiestaPairingString = !showFiestaPairingString"
                                    title="@(showFiestaPairingString ? "Hide" : "Reveal")">
                                @if (showFiestaPairingString)
                                {
                                    <svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                }
                                else
                                {
                                    <svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                }
                            </button>
                            <button class="copy-btn" @onclick="CopyFiestaPairingString" title="Copy to clipboard">
                                <svg class="icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                            </button>
                        </div>
                    </div>
                }

                @* Discovered LAN workers with Request Pair button *@
                @if (FiestaService.DiscoveredWorkers.Any())
                {
                    <div class="tunnel-url-section">
                        <label>Discovered on LAN:</label>
                        @foreach (var worker in FiestaService.DiscoveredWorkers.OrderByDescending(w => w.LastSeenAt))
                        {
                            <div class="tunnel-url">
                                <code>@worker.Hostname — @worker.BridgeUrl</code>
                                @if (pendingOutgoingPairs.ContainsKey(worker.InstanceId))
                                {
                                    <span class="hint">Waiting for approval…</span>
                                }
                                else
                                {
                                    <button class="start-btn" @onclick="() => RequestPairFromWorker(worker)" title="Send pairing request — worker must approve">Request Pair</button>
                                    <button class="copy-btn" @onclick="() => UseDiscoveredWorker(worker)" title="Fill form manually">Use</button>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="hint">No workers discovered yet. Enable Direct Sharing on worker machines first.</p>
                }

                @* Paste pairing string (hub side) *@
                <div class="url-input">
                    <label>Paste pairing string:</label>
                    <div class="tunnel-url">
                        <input type="text" @bind="fiestaPasteString" placeholder="pp+..." class="form-input wide" />
                        <button class="start-btn" @onclick="ImportFiestaPairingString"
                                disabled="@(!fiestaPasteString.StartsWith("pp+", StringComparison.Ordinal))">Link</button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(fiestaPasteError))
                {
                    <p class="tunnel-error">@fiestaPasteError</p>
                }

                @* Manual form *@
                <div class="url-input">
                    <label>Worker Name:</label>
                    <input type="text" @bind="fiestaLinkName" placeholder="e.g. mac-mini" class="form-input wide" />
                </div>
                <div class="url-input">
                    <label>Worker URL:</label>
                    <input type="text" @bind="fiestaLinkUrl" placeholder="http://192.168.1.20:4322" class="form-input wide" />
                </div>
                <div class="url-input">
                    <label>Worker Token:</label>
                    <input type="password" @bind="fiestaLinkToken" placeholder="Worker server password/token" class="form-input wide" />
                </div>
                <button class="start-btn" @onclick="LinkFiestaWorker"
                        disabled="@(string.IsNullOrWhiteSpace(fiestaLinkUrl) || string.IsNullOrWhiteSpace(fiestaLinkToken))">
                    Link Worker
                </button>

                @if (!string.IsNullOrEmpty(fiestaLinkError))
                {
                    <p class="tunnel-error">@fiestaLinkError</p>
                }

                @if (FiestaService.LinkedWorkers.Any())
                {
                    <div class="tunnel-url-section">
                        <label>Linked workers:</label>
                        @foreach (var worker in FiestaService.LinkedWorkers.OrderBy(w => w.Name))
                        {
                            <div class="tunnel-url">
                                <code>@worker.Name (@worker.Hostname) — @worker.BridgeUrl @(worker.IsOnline ? "🟢" : "⚪")</code>
                                <button class="stop-btn" @onclick="() => RemoveFiestaWorker(worker.Id)">Remove</button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }


    @if (settings.Mode == ConnectionMode.Remote)
    {
        <div class="mode-linked-panel mode-linked-last @(SectionVisible("remote server url token connect") ? "" : "search-hidden")">
            <h3>Remote Server</h3>
            <div class="remote-controls">
                <p class="mode-hint">Connect to a Copilot server running on another machine (via DevTunnel URL).</p>

                @if (PlatformHelper.IsMobile)
