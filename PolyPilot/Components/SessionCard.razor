@using PolyPilot.Services
@using PolyPilot.Models
@inject CopilotService CopilotService
@inject IJSRuntime JS
@inject PrLinkService PrLinkService

@{
    var providerDisplayName = CopilotService.GetProviderSessionDisplayName(Session.Name);
    var displayName = providerDisplayName ?? Session.Name;
    var hasQueuedMessages = Session.MessageQueue.Any();
    var showStuckFlag = Session.ConsecutiveStuckCount >= 1 && !Session.IsProcessing;
    var activeReflectionCycle = Session.ReflectionCycle is { IsActive: true, IsPaused: false } activeRc ? activeRc : null;
    var pausedReflectionCycle = Session.ReflectionCycle is { IsPaused: true } pausedRc ? pausedRc : null;
    var showCardFlags =
        Session.NeedsAttention ||
        ActiveWorkerCount > 0 ||
        hasQueuedMessages ||
        !string.IsNullOrEmpty(Intent) ||
        activeReflectionCycle != null ||
        pausedReflectionCycle != null ||
        showStuckFlag;
}

<div class="session-card @(Session.IsProcessing ? "processing" : IsCompleted ? "completed" : Session.NeedsAttention ? "needs-attention" : "idle") @(Meta?.IsPinned == true ? "pinned" : "") @(IsInFocusStrip ? "in-focus-strip" : "")" data-session="@Session.Name" style="@(MinHeight > 0 ? $"min-height:{MinHeight}px" : "")">
    <div class="card-header">
        <div class="card-header-main" @onclick="GoToSession" style="cursor:pointer">
            <div class="card-title-row">
                @if (Meta?.IsPinned == true)
                {
                    <span class="card-pin-indicator" aria-hidden="true"></span>
                }
                <span class="card-status-dot @(Session.IsProcessing ? "processing" : IsCompleted ? "completed" : Session.NeedsAttention ? "needs-attention" : "idle")"></span>
                @if (IsRenaming)
                {
                    <input type="text" class="card-rename-input" id="cardRenameInput"
                           value="@Session.Name"
                           @onclick:stopPropagation="true"
                           @onblur="CommitRename"
                           @onkeyup="HandleRenameKeyUp" />
                }
                else
                {
                    <h3>@displayName</h3>
                    @if (Session.UnreadCount > 0)
                    {
                        <span class="unread-badge">@Session.UnreadCount</span>
                    }
                    @if (_prUrl != null && PlatformHelper.IsDesktop)
                    {
                        <button class="pr-badge" title="@_prUrl">@_prLabel</button>
                    }
                }
            </div>
        </div>
        <div class="card-actions-bar">
            <div class="card-more-wrapper">
                <button class="card-more-btn card-action-segment" @onclick="ToggleMenu" @onclick:stopPropagation="true" title="More actions">⋯</button>
                @if (IsMenuOpen)
                {
                    <div class="menu-overlay" @onclick="() => OnCloseMenu.InvokeAsync()" @onclick:stopPropagation="true"></div>
                    <div class="card-menu" @onclick:stopPropagation="true">
                    <button class="card-menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); OnStartRename.InvokeAsync(); }">
                        ✏️ Rename
                    </button>
                    @if (Meta?.IsPinned == true)
                    {
                        <button class="card-menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); CopilotService.PinSession(Session.Name, false); }">
                            📌 Unpin
                        </button>
                    }
                    else
                    {
                        <button class="card-menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); CopilotService.PinSession(Session.Name, true); }">
                            📌 Pin
                        </button>
                    }
                    <div class="card-menu-separator"></div>
                    @if (IsInFocusStrip)
                    {
                        <button class="card-menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); CopilotService.RemoveFromFocus(Session.Name); }">
                            🎯 Remove from Focus
                        </button>
                    }
                    else
                    {
                        <button class="card-menu-item" @onclick="() => { OnCloseMenu.InvokeAsync(); CopilotService.AddToFocus(Session.Name); }">
                            🎯 Add to Focus
                        </button>
                    }
                    <div class="card-menu-separator"></div>
                    <button class="card-menu-item destructive" @onclick="async () => { await OnCloseMenu.InvokeAsync(); _ = CopilotService.CloseSessionAsync(Session.Name); }">
                        ✕ Close Session
                    </button>
                </div>
                }
            </div>
            @if (Session.IsProcessing)
            {
                <button class="card-stop card-action-segment" @onclick="() => CopilotService.AbortSessionAsync(Session.Name)" title="Stop">■</button>
            }
            @if (IsInFocusStrip)
            {
                <button class="card-focus-up card-action-segment" @onclick="() => OnPromote.InvokeAsync()" title="Move up in Focus">⬆</button>
                <button class="card-focus-down card-action-segment" @onclick="() => OnDemote.InvokeAsync()" title="Move down in Focus">⬇</button>
                <button class="card-focus-remove card-action-segment" @onclick="() => OnRemoveFromFocus.InvokeAsync()" title="Remove from Focus">✕</button>
            }
            <button class="card-expand card-action-segment" @onclick="ExpandSession" title="Expand">⤢</button>
        </div>
        @if (!string.IsNullOrEmpty(Session.WorkingDirectory) || !string.IsNullOrEmpty(Session.GitBranch))
        {
            <div class="card-context" @onclick="GoToSession" style="cursor:pointer">
                @if (!string.IsNullOrEmpty(Session.WorkingDirectory))
                {
                    <span class="card-meta-chip card-dir" title="@Session.WorkingDirectory">@ShortenPath(Session.WorkingDirectory)</span>
                }
                @if (!string.IsNullOrEmpty(Session.GitBranch))
                {
                    <span class="card-meta-chip card-branch-sub">@Session.GitBranch</span>
                }
            </div>
        }
    </div>
    @if (showCardFlags)
    {
        <div class="card-flags">
            @if (Session.NeedsAttention)
            {
                <span class="card-flag attention">Awaiting response</span>
            }
            @if (ActiveWorkerCount > 0)
            {
                <span class="card-flag workers">@ActiveWorkerCount worker@(ActiveWorkerCount != 1 ? "s" : "") active</span>
            }
            @if (hasQueuedMessages)
            {
                <span class="card-flag queue">
                    Queued @Session.MessageQueue.Count
                    <button class="card-flag-action" @onclick="ClearQueue">Clear</button>
                </span>
            }
            @if (!string.IsNullOrEmpty(Intent))
            {
                <span class="card-flag intent">@Intent</span>
            }
            @if (activeReflectionCycle != null)
            {
                var progress = activeReflectionCycle.MaxIterations > 0 ? (double)activeReflectionCycle.CurrentIteration / activeReflectionCycle.MaxIterations * 100 : 0;
                var truncGoal = activeReflectionCycle.Goal.Length > 30 ? activeReflectionCycle.Goal[..27] + "…" : activeReflectionCycle.Goal;
                <div class="card-reflection-pill">
                    <span class="card-reflection-progress" style="width: @progress.ToString("F0")%"></span>
                    <span class="card-reflection-label">Loop</span>
                    <span class="card-reflection-text">@activeReflectionCycle.CurrentIteration/@activeReflectionCycle.MaxIterations · @truncGoal</span>
                    <button class="card-reflection-stop" @onclick="() => CopilotService.StopReflectionCycle(Session.Name)" @onclick:stopPropagation="true" title="Stop reflection cycle">■</button>
                </div>
            }
            @if (pausedReflectionCycle != null)
            {
                var truncGoal = pausedReflectionCycle.Goal.Length > 30 ? pausedReflectionCycle.Goal[..27] + "…" : pausedReflectionCycle.Goal;
                <div class="card-reflection-pill paused">
                    <span class="card-reflection-label">Paused</span>
                    <span class="card-reflection-text">@pausedReflectionCycle.CurrentIteration/@pausedReflectionCycle.MaxIterations · @truncGoal</span>
                </div>
            }
            @if (showStuckFlag)
            {
                <span class="card-flag stuck">Stuck · @Session.ConsecutiveStuckCount failures</span>
            }
        </div>
    }

    <div class="card-messages">
        @{
            var cardMsgs = GetCardMessages(Session.Name, Session.History);
            var hasMoreCard = Session.MessageCount > cardMsgs.Count;
        }
        @if (hasMoreCard)
        {
            <button class="load-more-btn" @onclick="LoadMoreMessages">▲ Load earlier messages (@(Session.MessageCount - cardMsgs.Count) more)</button>
        }
        <ChatMessageList Messages="cardMsgs"
                         StreamingContent="@StreamingContent"
                         CurrentToolName="@CurrentToolName"
                         ToolActivities="@ToolActivities"
                         ActivityText="@ActivityText"
                         IsProcessing="Session.IsProcessing"
                         IsRemoteStreaming="IsRemoteStreaming"
                         ProcessingStartedAt="Session.ProcessingStartedAt"
                         ToolCallCount="Session.ToolCallCount"
                         ProcessingPhase="Session.ProcessingPhase"
                         LastActivityAt="Session.LastUpdatedAt"
                         Compact="true"
                         UserAvatarUrl="@UserAvatarUrl"
                         Layout="@Layout"
                         Style="@Style"
                         RepoUrl="@RepoUrl" />
        @if (!Session.IsProcessing && string.IsNullOrEmpty(Intent) && cardMsgs.Count == 0 && !string.IsNullOrEmpty(Session.LastUserPrompt))
        {
            <div class="card-last-prompt" title="Last prompt sent to this session">Last prompt · @(Session.LastUserPrompt.Length > 80 ? Session.LastUserPrompt[..77] + "…" : Session.LastUserPrompt)</div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="card-error">
            <span>⚠️ @Error</span>
            <button @onclick="DismissError">✕</button>
        </div>
    }

    @if (PendingImages.Any())
    {
        <div class="attachment-strip">
            @for (var cpi = 0; cpi < PendingImages.Count; cpi++)
            {
                var cpidx = cpi;
                var cpimg = PendingImages[cpi];
                <div class="attachment-thumb">
                    <img src="@cpimg.DataUri" alt="@cpimg.FileName" />
                    <button class="attachment-remove" @onclick="() => OnRemovePendingImage.InvokeAsync(cpidx)" title="Remove">×</button>
                    <span class="attachment-name">@TruncateFileName(cpimg.FileName, 15)</span>
                </div>
            }
        </div>
    }

    <div class="card-input">
        <input type="text" id="input-@Session.Name.Replace(" ", "-")"
               autocomplete="off"
               placeholder="@(Session.IsProcessing ? "Queue a message…" : $"Send to {displayName}...")"
               @onkeyup="HandleInputKeyUp" />
        @if (Session.IsProcessing)
        {
            <button class="card-stop-btn" @onclick="() => CopilotService.AbortSessionAsync(Session.Name)" title="Stop">■</button>
        }
        <button class="send-btn" @onclick="SendInput">➤</button>
    </div>
</div>

@code {
    [Parameter] public AgentSessionInfo Session { get; set; } = default!;
    [Parameter] public SessionMeta? Meta { get; set; }
    [Parameter] public bool IsCompleted { get; set; }
    [Parameter] public string StreamingContent { get; set; } = "";
    [Parameter] public bool IsRemoteStreaming { get; set; }
    [Parameter] public string ActivityText { get; set; } = "";
    [Parameter] public string CurrentToolName { get; set; } = "";
    [Parameter] public List<ToolActivity> ToolActivities { get; set; } = new();
    [Parameter] public string Intent { get; set; } = "";
    [Parameter] public string? Error { get; set; }
    [Parameter] public List<PendingImage> PendingImages { get; set; } = new();
    [Parameter] public string? UserAvatarUrl { get; set; }
    [Parameter] public string? RepoUrl { get; set; }
    [Parameter] public ChatLayout Layout { get; set; } = ChatLayout.Default;
    [Parameter] public ChatStyle Style { get; set; } = ChatStyle.Normal;
    
    // State controlled by parent or callbacks
    [Parameter] public bool IsRenaming { get; set; }
    [Parameter] public bool IsMenuOpen { get; set; }
    [Parameter] public int MessageCount { get; set; } = 5; // Default for card view

    [Parameter] public EventCallback OnExpand { get; set; }
    [Parameter] public EventCallback OnGoTo { get; set; }
    [Parameter] public EventCallback OnToggleMenu { get; set; }
    [Parameter] public EventCallback OnCloseMenu { get; set; }
    [Parameter] public EventCallback OnStartRename { get; set; }
    [Parameter] public EventCallback<string> OnCommitRename { get; set; } // new name
    [Parameter] public EventCallback OnLoadMore { get; set; }
    [Parameter] public EventCallback OnDismissError { get; set; }
    [Parameter] public EventCallback OnClearQueue { get; set; }
    [Parameter] public EventCallback<int> OnRemovePendingImage { get; set; }
    [Parameter] public EventCallback<string> OnSend { get; set; } // message text
    /// <summary>When in Focus strip, removes this session from Focus.</summary>
    [Parameter] public EventCallback OnRemoveFromFocus { get; set; }
    /// <summary>Moves session up one position in Focus order.</summary>
    [Parameter] public EventCallback OnPromote { get; set; }
    /// <summary>Moves session down one position in Focus order.</summary>
    [Parameter] public EventCallback OnDemote { get; set; }
    /// <summary>Kept for backward compatibility.</summary>
    [Parameter] public EventCallback OnHandledInFocus { get; set; }
    /// <summary>Kept for backward compatibility — use OnRemoveFromFocus instead.</summary>
    [Parameter] public EventCallback OnDismissFromFocus { get; set; }
    /// <summary>When true, the card is rendered in the Focus strip (slightly more messages, distinct styling).</summary>
    [Parameter] public bool IsInFocusStrip { get; set; }
    [Parameter] public int ActiveWorkerCount { get; set; } = 0;
    /// <summary>Minimum height in px for the card. 0 = use CSS default.</summary>
    [Parameter] public int MinHeight { get; set; } = 0;
    private async Task HandleRenameKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
             // We need to read the value via JS because input value binding might not be updated on Enter if using @onkeydown
             // But let's assume standard binding or JS interop
             // For simplicity, I'll rely on onblur or just call commit. 
             // Actually, parent implementation used onblur="CommitCardRename".
             // We can use JS to get value or bind a local var. 
             // Let's use JS to get value to be safe as done in Dashboard? 
             // Dashboard uses @onblur="CommitCardRename".
             await CommitRename();
        }
        else if (e.Key == "Escape")
        {
            await OnCloseMenu.InvokeAsync(); // Close rename (reuse close menu/cancel rename logic?)
            // Actually, cancel rename isn't exposed. Just commit or blur.
        }
    }

    private async Task CommitRename()
    {
        var val = await JS.InvokeAsync<string>("getElementValue", "cardRenameInput");
        if (!string.IsNullOrWhiteSpace(val))
        {
            await OnCommitRename.InvokeAsync(val);
        }
    }

    private async Task HandleInputKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendInput();
        }
    }

    private async Task SendInput()
    {
        var id = $"input-{Session.Name.Replace(" ", "-")}";
        var text = await JS.InvokeAsync<string>("getElementValue", id);
        if (!string.IsNullOrWhiteSpace(text))
        {
            await JS.InvokeVoidAsync("clearElementValue", id);
            await OnSend.InvokeAsync(text);
        }
    }

    private void GoToSession() => OnGoTo.InvokeAsync();
    private void ToggleMenu() => OnToggleMenu.InvokeAsync();
    private void ExpandSession() => OnExpand.InvokeAsync();
    private void LoadMoreMessages() => OnLoadMore.InvokeAsync();
    private void DismissError() => OnDismissError.InvokeAsync();
    private void ClearQueue() => OnClearQueue.InvokeAsync();

    private List<ChatMessage> GetCardMessages(string sessionName, List<ChatMessage> history)
    {
        ChatMessage[] snapshot;
        lock (Session.HistoryLock) { snapshot = history.ToArray(); }
        if (snapshot.Length <= MessageCount) return snapshot.ToList();
        return snapshot.Skip(snapshot.Length - MessageCount).ToList();
    }

    private string ShortenPath(string path)
    {
        if (string.IsNullOrEmpty(path)) return "";
        var parts = path.Split(System.IO.Path.DirectorySeparatorChar, System.IO.Path.AltDirectorySeparatorChar);
        return parts.Length > 2 ? ".../" + parts[^1] : path;
    }
    
    private string TruncateFileName(string name, int len)
    {
        if (name.Length <= len) return name;
        return name.Substring(0, len - 3) + "...";
    }

    private string? _prUrl;
    private string _prLabel = "PR";
    private string? _lastPrCheckedDir;

    protected override void OnParametersSet()
    {
        if (PlatformHelper.IsDesktop)
        {
            var dir = Session.WorkingDirectory;
            if (!string.IsNullOrEmpty(dir) && dir != _lastPrCheckedDir)
            {
                _lastPrCheckedDir = dir;
                _ = FetchPrUrlAsync(dir);
            }
        }
    }

    private async Task FetchPrUrlAsync(string dir)
    {
        _prUrl = await PrLinkService.GetPrUrlForDirectoryAsync(dir);
        if (_prUrl != null)
        {
            var lastSlash = _prUrl.LastIndexOf('/');
            if (lastSlash >= 0 && lastSlash < _prUrl.Length - 1)
                _prLabel = "#" + _prUrl[(lastSlash + 1)..];
        }
        try { await InvokeAsync(StateHasChanged); } catch (ObjectDisposedException) { }
    }
}
