    private async Task CloseSessionWithOptions(string name, bool deleteWorktree, bool deleteBranch)
    {
        try
        {
            var meta = CopilotService.GetSessionMeta(name);
            var worktreeId = meta?.WorktreeId;

            await CopilotService.CloseSessionAsync(name);

            if (!string.IsNullOrEmpty(worktreeId))
            {
                if (deleteWorktree && !IsWorktreeInUse(worktreeId, excludeSession: name))
                {
                    await DeleteWorktreeAsync(worktreeId, deleteBranch);
                }
                else if (deleteBranch && !deleteWorktree)
                {
                    // UI prevents this state (checkbox disabled), but guard just in case.
                    // Can't delete a branch that's checked out in a kept worktree — skip.
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SessionSidebar] CloseSessionWithOptions error for '{name}': {ex.Message}");
        }
    }

    private async Task DeleteGroupAndWorktrees(string groupId, HashSet<string> worktreeIds, bool deleteBranch = true)
    {
        // Collect session names being deleted so we can exclude them from the guard
        var deletedSessions = CopilotService.Organization.Sessions
            .Where(m => m.GroupId == groupId)
            .Select(m => m.SessionName)
            .ToHashSet();
        CopilotService.DeleteGroup(groupId);
        // Delete each worktree if no remaining sessions or groups still reference it
        foreach (var wtId in worktreeIds)
        {
            if (!IsWorktreeInUse(wtId, excludeSessions: deletedSessions))
            {
                await DeleteWorktreeAsync(wtId, deleteBranch);
            }
        }
    }

    /// <summary>Collect all worktree IDs associated with a group (group-level + session-level + CreatedWorktreeIds).</summary>
    private HashSet<string> CollectGroupWorktreeIds(string groupId)
    {
        var ids = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var group = CopilotService.Organization.Groups.FirstOrDefault(g => g.Id == groupId);
        if (group != null)
        {
            if (!string.IsNullOrEmpty(group.WorktreeId))
                ids.Add(group.WorktreeId);
            foreach (var id in group.CreatedWorktreeIds)
                if (!string.IsNullOrEmpty(id)) ids.Add(id);
        }
        // Also check session-level worktree assignments
        foreach (var session in CopilotService.Organization.Sessions.Where(s => s.GroupId == groupId))
        {
            if (!string.IsNullOrEmpty(session.WorktreeId))
                ids.Add(session.WorktreeId);
        }
        return ids;
    }

    private record DeleteGroupDialogResult(bool Confirmed, bool DeleteWorktree, bool DeleteBranch);

    private async Task ShowDeleteGroupConfirm(string groupId, string groupName)
    {
        try
        {
            // Gather all worktree IDs from group + sessions + CreatedWorktreeIds
            var allWorktreeIds = CollectGroupWorktreeIds(groupId);
            bool hasWorktree = allWorktreeIds.Count > 0;
            string branchName = "";
            if (hasWorktree)
            {
                // Show branch name from the first worktree found
                var firstWtId = allWorktreeIds.First();
                var wt = RepoManager.Worktrees.FirstOrDefault(w => w.Id == firstWtId);
                branchName = wt?.Branch ?? "";
            }

            var result = await JS.InvokeAsync<DeleteGroupDialogResult>(
                "showDeleteGroupDialog", groupName, hasWorktree, branchName);

            if (!result.Confirmed) return;

            if (hasWorktree && (result.DeleteWorktree || result.DeleteBranch))
                await DeleteGroupAndWorktrees(groupId, allWorktreeIds, result.DeleteBranch);
            else
                CopilotService.DeleteGroup(groupId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SessionSidebar] ShowDeleteGroupConfirm error: {ex.Message}");
        }
    }

    private async Task DeleteWorktreeAsync(string worktreeId, bool deleteBranch = true)
    {
        try
        {
            if (CopilotService.IsRemoteMode)
                await CopilotService.RemoveWorktreeViaBridgeAsync(worktreeId, deleteBranch);
            else
                await RepoManager.RemoveWorktreeAsync(worktreeId, deleteBranch: deleteBranch);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SessionSidebar] Failed to delete worktree {worktreeId}: {ex.Message}");
        }
    }

    /// <summary>Check if any remaining sessions or groups reference the worktree.</summary>
    private bool IsWorktreeInUse(string worktreeId, string? excludeSession = null, HashSet<string>? excludeSessions = null)
    {
        var org = CopilotService.Organization;
        // Check organization metadata — exclude sessions we just closed
        if (org.Sessions.Any(s => s.WorktreeId == worktreeId
            && s.SessionName != excludeSession
            && (excludeSessions == null || !excludeSessions.Contains(s.SessionName))))
            return true;
        if (org.Groups.Any(g => g.WorktreeId == worktreeId))
            return true;
        // Also check live non-hidden sessions whose working directory matches the worktree path
        var wt = RepoManager.Worktrees.FirstOrDefault(w => w.Id == worktreeId);
        if (wt != null)
        {
            foreach (var session in CopilotService.GetAllSessions())
            {
                if (session.Name == excludeSession) continue;
                if (excludeSessions != null && excludeSessions.Contains(session.Name)) continue;
                if (!string.IsNullOrEmpty(session.WorkingDirectory)
                    && session.WorkingDirectory.StartsWith(wt.Path, StringComparison.OrdinalIgnoreCase))
                    return true;
            }
        }
        return false;
    }

