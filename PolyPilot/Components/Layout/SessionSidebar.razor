                            }
                            else if (csState == CodespaceConnectionState.StartingCodespace)
                            {
                                <span class="codespace-state-dot starting" title="Starting codespace...">⏳</span>
                            }
                            else if (csState == CodespaceConnectionState.WaitingForCopilot)
                            {
                                <span class="codespace-state-dot waiting" title="Copilot not running — click ⋯ menu to open VS Code or browser and run: copilot --headless">●</span>
                            }
                            else if (csState == CodespaceConnectionState.SetupRequired)
                            {
                                <span class="codespace-state-dot setup" title="Setup required — SSH not available. Click ⋯ for instructions.">●</span>
                            }
                            @if (renamingGroupId == group.Id)
                            {
                                var rgId = group.Id;
