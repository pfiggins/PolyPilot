    private RenderFragment RenderMultiAgentPresetPicker => __builder =>
    {
        <div class="worktree-picker sidebar-create-panel sidebar-create-panel-form" @onclick:stopPropagation="true">
            <div class="sidebar-create-section">
                <span class="sidebar-create-section-label">Repository</span>
                <div class="sidebar-create-static-value">@pendingMultiAgentRepo!.Name</div>
            </div>

            <div class="sidebar-create-section">
                <span class="sidebar-create-section-label">Team name</span>
                <input type="text" class="new-group-input sidebar-create-input" id="presetNameInput"
                       placeholder="Optional — uses the preset name by default" />
            </div>

            <div class="sidebar-create-section">
                <span class="sidebar-create-section-label">Worktree isolation</span>
                <select class="sidebar-create-select" @onchange="OnStrategyChanged">
                    <option value="" selected="@(selectedStrategy == null)">Preset default</option>
                    <option value="FullyIsolated" selected="@(selectedStrategy == WorktreeStrategy.FullyIsolated)">Each agent gets its own worktree</option>
                    <option value="OrchestratorIsolated" selected="@(selectedStrategy == WorktreeStrategy.OrchestratorIsolated)">Manager isolated, workers shared</option>
                    <option value="GroupShared" selected="@(selectedStrategy == WorktreeStrategy.GroupShared)">One worktree per group</option>
                    <option value="Shared" selected="@(selectedStrategy == WorktreeStrategy.Shared)">Everyone shares one worktree</option>
                </select>
            </div>
            @{
                var repoWorktree = RepoManager.Worktrees.FirstOrDefault(w => w.RepoId == pendingMultiAgentRepo?.Id);
                var allPresets = UserPresets.GetAll(CopilotService.BaseDir, repoWorktree?.Path);
                var repoPresets = allPresets.Where(p => p.IsRepoLevel).ToArray();
                var builtInPresets = allPresets.Where(p => !p.IsRepoLevel && !p.IsUserDefined).ToArray();
                var userPresets = allPresets.Where(p => p.IsUserDefined).ToArray();
            }
            @if (repoPresets.Any())
            {
                <div class="preset-section-header">From repo</div>
                @foreach (var preset in repoPresets)
                {
                    var p = preset;
                    <div class="preset-item-row">
                        <button class="preset-item preset-repo" @onclick="() => CreateFromPresetForRepo(p, pendingMultiAgentRepo)" title="@p.Description — 🎯 @p.OrchestratorModel · 👷 @string.Join(", ", p.WorkerModels)">
                            <span class="preset-emoji">@p.Emoji</span>
                            <span class="preset-name">@p.Name</span>
                            <span class="preset-badge">Repo</span>
                        </button>
                        <button class="preset-delete-btn" @onclick="() => DeleteRepoPreset(p, repoWorktree)" title="Delete repo preset">Delete</button>
                    </div>
                }
            }
            @if (builtInPresets.Any())
            {
                @if (repoPresets.Any())
                {
                    <div class="preset-section-header">Built-in</div>
                }
                @foreach (var preset in builtInPresets)
                {
                    var p = preset;
                    <button class="preset-item" @onclick="() => CreateFromPresetForRepo(p, pendingMultiAgentRepo)" title="@p.Description — 🎯 @p.OrchestratorModel · 👷 @string.Join(", ", p.WorkerModels)">
                        <span class="preset-emoji">@p.Emoji</span>
                        <span class="preset-name">@p.Name</span>
                    </button>
                }
            }
            @if (userPresets.Any())
            {
                <div class="preset-section-header">My presets</div>
                @foreach (var preset in userPresets)
                {
                    var p = preset;
                    <div class="preset-item-row">
                        <button class="preset-item" @onclick="() => CreateFromPresetForRepo(p, pendingMultiAgentRepo)" title="@p.Description — 🎯 @p.OrchestratorModel · 👷 @string.Join(", ", p.WorkerModels)">
                            <span class="preset-emoji">@p.Emoji</span>
                            <span class="preset-name">@p.Name</span>
                        </button>
                        <button class="preset-action-btn" @onclick="() => ExportPresetToFolder(p)" @onclick:stopPropagation="true" title="Export to .squad folder">📤</button>
                    </div>
                }
            }
            <div class="preset-import-row">
                <button class="preset-import-btn" @onclick="ImportPresetFromFolder" title="Import a preset from a .squad folder">📥 Import from .squad</button>
            </div>
            @if (!string.IsNullOrEmpty(importExportMessage))
            {
                <div class="preset-import-message">@importExportMessage</div>
            }
        </div>
    };

    private RenderFragment RenderAddRepoForm => __builder =>
    {
        <div class="add-repo-form sidebar-create-panel sidebar-create-panel-form">
            @if (PlatformHelper.IsDesktop && !confirmRepoReplace)
            {
                <div class="add-repo-mode-tabs sidebar-create-tabs">
                    <button class="add-repo-tab sidebar-create-tab @(addRepoFolderMode ? "" : "active")"
                            @onclick="() => { addRepoFolderMode = false; addRepoError = null; }">
                        URL
                    </button>
                    <button class="add-repo-tab sidebar-create-tab @(addRepoFolderMode ? "active" : "")"
                            @onclick="() => { addRepoFolderMode = true; addRepoError = null; }">
                        Existing folder
                    </button>
