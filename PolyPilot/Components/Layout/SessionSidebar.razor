                                        }
                                        @if (!string.IsNullOrEmpty(ext.GitBranch))
                                        {
                                            <span class="session-meta-branch"> @ext.GitBranch</span>
                                        }
                                    </div>
                                    <span class="session-meta-time">@GetSidebarRelativeAge(ext.LastEventTime)</span>
                                </div>
                                @if (ext.NeedsAttention)
                                {
                                    <div class="ext-sidebar-attention">💬 Awaiting response</div>
                                }

                                @if (ext.Tier != ExternalSessionTier.Active)
                                {
                                    <div class="ext-sidebar-send-row">
                                        <input type="text"
                                               class="ext-sidebar-input"
                                               placeholder="Send to reopen in PolyPilot…"
                                               value="@(_externalInputs.GetValueOrDefault(ext.SessionId, ""))"
