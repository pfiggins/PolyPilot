    private async Task FocusExternalTerminal(ExternalSessionInfo ext)
    {
        if (ext.ActiveLockPid is not { } pid) return;
        if (_focusingExternal == ext.SessionId) return; // debounce double-clicks
        _focusingExternal = ext.SessionId;
        StateHasChanged();
        try { await Task.Run(() => CopilotService.FocusExternalSessionTerminal(pid)); }
        finally { _focusingExternal = null; }
    }

    private static string GetSidebarRelativeAge(DateTimeOffset time)
    {
        var elapsed = DateTimeOffset.UtcNow - time;
        if (elapsed.TotalSeconds < 60) return "just now";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes}m ago";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours}h ago";
        return $"{(int)elapsed.TotalDays}d ago";
    }

