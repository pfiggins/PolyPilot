                    <div class="notifications-toggle" style="margin-left: 1.5em;">
                        <label class="toggle-label">
                            <input type="checkbox" checked="@settings.MuteWorkerNotifications"
                                   @onchange="ToggleMuteWorkerNotifications" />
                            <span class="toggle-text">🔇 Mute worker notifications</span>
                        </label>
                        <p class="toggle-hint">Don't send notifications for worker sessions in multi-agent groups</p>
