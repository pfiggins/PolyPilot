                            @if (csState == CodespaceConnectionState.Connected)
                            {
                                <span class="codespace-state-dot connected" title="Connected">●</span>
                            }
                            else if (csState == CodespaceConnectionState.Reconnecting)
                            {
                                var attempts = group.ReconnectAttempts;
                                <span class="codespace-state-dot reconnecting" title="Reconnecting... (attempt @attempts)">●</span>
                            }
                            else if (csState == CodespaceConnectionState.CodespaceStopped)
                            {
                                <span class="codespace-state-dot stopped" title="Codespace stopped">●</span>
                                <button class="codespace-play-btn" title="Start codespace" @onclick:stopPropagation="true" @onclick="() => StartCodespaceFromSidebar(group.Id)">▶</button>
                            }
                            else if (csState == CodespaceConnectionState.StartingCodespace)
                            {
                                <span class="codespace-state-dot starting" title="Starting codespace...">⏳</span>
                            }
                            else if (csState == CodespaceConnectionState.WaitingForCopilot)
                            {
                                <span class="codespace-state-dot waiting" title="Copilot not running — click ⋯ menu to open VS Code or browser and run: copilot --headless">●</span>
                            }
                            else if (csState == CodespaceConnectionState.SetupRequired)
                            {
                                <span class="codespace-state-dot setup" title="Setup required — SSH not available. Click ⋯ for instructions.">●</span>
                            }
                            @if (renamingGroupId == group.Id)
                            {
                                var rgId = group.Id;
