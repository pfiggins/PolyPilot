            var hostName = TryExtractHost(fiestaLinkUrl) ?? fiestaLinkName.Trim();
            var workerName = string.IsNullOrWhiteSpace(fiestaLinkName) ? hostName : fiestaLinkName.Trim();
            FiestaService.LinkWorker(workerName, hostName, fiestaLinkUrl, fiestaLinkToken);
            fiestaLinkName = "";
            fiestaLinkUrl = "";
            fiestaLinkToken = "";
            ShowStatus("Fiesta worker linked", "success", 2500);
        }
        catch (Exception ex)
