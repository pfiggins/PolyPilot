            @if (addRepoFolderMode && PlatformHelper.IsDesktop)
            {
                @if (addFolderMergedIntoGroupName != null)
                {
                    <div class="repo-confirm">
                        <span>✅ Registered as an existing worktree in the <strong>@addFolderMergedIntoGroupName</strong> group. Use its <strong>⋯ → New Session → 📂 Existing</strong> to open it.</span>
                    </div>
                    <div class="add-repo-actions">
                        <button class="btn-repo-cancel" @onclick="CloseAddRepoForm">Close</button>
                    </div>
                }
                else
                {
                    <div class="sidebar-create-section">
                        <span class="sidebar-create-section-label">Folder</span>
                        <div class="add-repo-folder-row">
                        <input type="text" @bind="addRepoFolderPath"
                                placeholder="Path to a cloned repository…"
                                class="repo-url-input sidebar-create-input" />
                        <button class="btn-repo-browse sidebar-create-button sidebar-create-button-secondary sidebar-create-browse" @onclick="BrowseExistingRepo"
                                title="Pick a folder">…</button>
                        </div>
                    </div>
                    <div class="add-repo-actions sidebar-create-actions">
                        <button class="btn-repo-cancel sidebar-create-button sidebar-create-button-secondary" @onclick="CloseAddRepoForm">Cancel</button>
                        <button class="btn-repo-add sidebar-create-button sidebar-create-button-primary"
                                 @onclick="AddRepositoryFromFolder"
                                 disabled="@(isAddingRepo || string.IsNullOrWhiteSpace(addRepoFolderPath))">
                            @(isAddingRepo ? "Adding..." : "Add")
                        </button>
