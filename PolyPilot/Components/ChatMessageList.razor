@using PolyPilot.Models
@using PolyPilot.Services

@* Shared chat message list — used by Dashboard.razor (grid=compact, expanded=full) *@

<div class="chat-message-list @(Compact ? "compact" : "full") @GetLayoutClass() @GetStyleClass()">
    @if (!Messages.Any() && string.IsNullOrEmpty(StreamingContent))
    {
        <p class="chat-empty">@(Compact ? "No messages yet" : "Start a conversation with Copilot!")</p>
    }
    else
    {
        var _seenFirstUserOriginal = false;
        var messageList = Messages.ToList();
        var groups = GroupMessages(messageList);
        @foreach (var group in groups)
        {
            @if (group.IsActivityGroup)
            {
                @if (Compact)
                {
                    @* In compact mode, show a single summary line for activity groups *@
                    var toolCount = group.Messages.Count(m => m.MessageType == ChatMessageType.ToolCall);
                    var thinkCount = group.Messages.Count(m => m.MessageType == ChatMessageType.Reasoning);
                    var parts = new List<string>();
                    if (toolCount > 0) parts.Add($"{toolCount} tool call{(toolCount != 1 ? "s" : "")}");
                    if (thinkCount > 0) parts.Add($"{thinkCount} thought{(thinkCount != 1 ? "s" : "")}");
                    <div class="chat-msg tool">
                        <span class="chat-msg-role">🔧</span>
                        <span class="chat-msg-text">@string.Join(", ", parts)</span>
                    </div>
                }
                else
                {
                    var isLastGroup = group == groups.Last(g => g.IsActivityGroup);
                    var toolCount = group.Messages.Count(m => m.MessageType == ChatMessageType.ToolCall);
                    var thinkCount = group.Messages.Count(m => m.MessageType == ChatMessageType.Reasoning);
                    var otherCount = group.Messages.Count - toolCount - thinkCount;
                    var summaryParts = new List<string>();
                    if (toolCount > 0) summaryParts.Add($"{toolCount} tool call{(toolCount != 1 ? "s" : "")}");
                    if (thinkCount > 0) summaryParts.Add($"{thinkCount} thought{(thinkCount != 1 ? "s" : "")}");
                    if (otherCount > 0) summaryParts.Add($"{otherCount} output{(otherCount != 1 ? "s" : "")}");
                    var summaryText = summaryParts.Count > 0 ? string.Join(", ", summaryParts) : $"{group.Messages.Count} activit{(group.Messages.Count != 1 ? "ies" : "y")}";

                    @if (isLastGroup)
                    {
                        <details class="activity-group" open>
                            <summary class="activity-group-summary">
                                <span class="activity-group-chevron"></span>
                                <span class="activity-group-label">@summaryText</span>
                            </summary>
                            <div class="activity-group-content">
                                @foreach (var msg in group.Messages)
                                {
                                    <ChatMessageItem @key="msg" Message="msg" Compact="Compact" CollapseOriginalContent="false" UserAvatarUrl="@UserAvatarUrl" RepoUrl="@RepoUrl" />
                                }
                            </div>
                        </details>
                    }
                    else
                    {
                        <details class="activity-group">
                            <summary class="activity-group-summary">
                                <span class="activity-group-chevron"></span>
                                <span class="activity-group-label">@summaryText</span>
                            </summary>
                            <div class="activity-group-content">
                                @foreach (var msg in group.Messages)
                                {
                                    <ChatMessageItem @key="msg" Message="msg" Compact="Compact" CollapseOriginalContent="false" UserAvatarUrl="@UserAvatarUrl" RepoUrl="@RepoUrl" />
                                }
                            </div>
                        </details>
                    }
                }
            }
            else
            {
                @foreach (var msg in group.Messages)
                {
                    var collapseOrig = false;
                    if (msg.MessageType == ChatMessageType.User && !string.IsNullOrEmpty(msg.OriginalContent))
                    {
                        collapseOrig = _seenFirstUserOriginal;
                        _seenFirstUserOriginal = true;
                    }
                    <ChatMessageItem @key="msg" Message="msg" Compact="Compact" CollapseOriginalContent="collapseOrig" UserAvatarUrl="@UserAvatarUrl" RepoUrl="@RepoUrl" />
                }
            }
        }

        @* Current turn tool activity feed — skip activities already in history *@
        var newActivities = GetNewActivities().ToList();
        @if (newActivities.Count > 0)
        {
            @if (Compact)
            {
                @foreach (var activity in newActivities.TakeLast(3))
                {
                    <div class="chat-msg tool">
                        <span class="chat-msg-role">🔧</span>
                        <span class="chat-msg-text">@FormatToolName(activity.Name) @(activity.IsComplete ? (activity.IsSuccess ? "✓" : "✗") : "…")</span>
                    </div>
                }
            }
            else
            {
                @foreach (var activity in newActivities)
                {
                    var activityInputCopyText = ChatCopyPayloads.GetToolInputCopyText(activity.Name, activity.Input);
                    <div class="action-item @(GetActionLabel(activity.Name).CssClass) @(activity.IsComplete ? (activity.IsSuccess ? "done" : "failed") : "running")">
                        <span class="action-dot"></span>
                        <span class="action-label">@(GetActionLabel(activity.Name).Label)</span>
                        <span class="action-desc">@FormatActionDescriptionCompact(activity.Name, activity.Input, activity.Result, activity.IsComplete)</span>
                        @if (!string.IsNullOrEmpty(activityInputCopyText))
                        {
                            <CopyToClipboardButton Text="@activityInputCopyText"
                                                   Title="Copy tool input"
                                                   CopiedTitle="Copied tool input"
                                                   CssClass="message-copy-btn action-copy-btn" />
                        }
                    </div>
                }
            }
        }
        else if (!string.IsNullOrEmpty(CurrentToolName))
        {
            @if (Compact)
            {
                <div class="chat-msg tool">
                    <span class="chat-msg-role">🔧</span>
                    <span class="chat-msg-text">@FormatToolName(CurrentToolName) …</span>
                </div>
            }
            else
            {
                <div class="action-item @(GetActionLabel(CurrentToolName).CssClass) running">
                    <span class="action-dot"></span>
                    <span class="action-label">@(GetActionLabel(CurrentToolName).Label)</span>
                </div>
            }
        }

        @* Streaming content — show while actively processing, or while remote streaming guard is active *@
        @if (ShouldShowStreamingContent())
        {
            <div class="chat-msg assistant streaming">
                @if (!Compact)
                {
                    <div class="chat-msg-avatar"><img src="PolyPilot_logo.png" width="22" height="22" alt="PolyPilot" /></div>
                }
                <div class="chat-msg-content">
                    @if (Compact)
                    {
                        <span class="chat-msg-role">AI</span>
                    }
                    <div class="chat-msg-text markdown-body">@((MarkupString)RenderMarkdown(StreamingContent, RepoUrl))</div>
                </div>
            </div>
        }

        @* Permission warning banner *@
        @if (HasPermissionIssue)
        {
            <div class="permission-warning">
                <span>⚠️ Tools are failing with permission errors.</span>
                <button class="reconnect-btn" @onclick="OnReconnectRequested">Reconnect</button>
            </div>
        }

        @* Activity indicator *@
        @if (IsProcessing && string.IsNullOrEmpty(StreamingContent) && string.IsNullOrEmpty(CurrentToolName) && !ToolActivities.Any())
        {
            @if (Compact)
            {
                <div class="chat-msg tool">
                    <span class="chat-msg-role">⏳</span>
                    <span class="chat-msg-text">@(string.IsNullOrEmpty(ActivityText) ? GetProcessingStatus() : ActivityText)</span>
                </div>
            }
            else
            {
                <div class="action-item action-default running">
                    <span class="action-dot"></span>
                    <span class="action-label">@GetProcessingStatus()</span>
                </div>
            }
        }
    }
</div>

@code {
    [Parameter] public List<ChatMessage> Messages { get; set; } = new();
    [Parameter] public string StreamingContent { get; set; } = "";
    [Parameter] public string CurrentToolName { get; set; } = "";
    [Parameter] public int ToolCount { get; set; }
    [Parameter] public List<ToolActivity> ToolActivities { get; set; } = new();
    [Parameter] public string ActivityText { get; set; } = "";
    [Parameter] public bool IsProcessing { get; set; }
    [Parameter] public bool IsRemoteStreaming { get; set; }
    [Parameter] public bool Compact { get; set; }
    [Parameter] public string? UserAvatarUrl { get; set; }
    [Parameter] public ChatLayout Layout { get; set; } = ChatLayout.Default;
    [Parameter] public ChatStyle Style { get; set; } = ChatStyle.Normal;
    [Parameter] public DateTime? ProcessingStartedAt { get; set; }
    [Parameter] public int ToolCallCount { get; set; }
    [Parameter] public int ProcessingPhase { get; set; }
    [Parameter] public DateTime? LastActivityAt { get; set; }
    [Parameter] public string? RepoUrl { get; set; }
    [Parameter] public bool HasPermissionIssue { get; set; }
    [Parameter] public EventCallback OnReconnectRequested { get; set; }

    private string GetProcessingStatus()
    {
        // Phase 0: Sending, 1: Server connected, 2: Thinking, 3: Working (tools)
        if (ProcessingPhase == 0)
            return "Sending…";
        if (ProcessingPhase == 1)
            return "Server connected…";
        if (ProcessingPhase == 2 && ToolCallCount == 0)
            return AppendLastActivity("Thinking…");

        var parts = new List<string> { "Working" };
        if (ProcessingStartedAt.HasValue)
        {
            var elapsed = DateTime.UtcNow - ProcessingStartedAt.Value;
            if (elapsed.TotalMinutes >= 1)
                parts.Add($"{(int)elapsed.TotalMinutes}m {elapsed.Seconds}s");
            else if (elapsed.TotalSeconds >= 5)
                parts.Add($"{(int)elapsed.TotalSeconds}s");
        }
        if (ToolCallCount > 0)
            parts.Add($"{ToolCallCount} tool call{(ToolCallCount != 1 ? "s" : "")}");
        return AppendLastActivity(string.Join(" · ", parts) + "…");
    }

    private string AppendLastActivity(string status)
    {
        if (!LastActivityAt.HasValue) return status;
        var sinceActivity = DateTime.Now - LastActivityAt.Value;
        if (sinceActivity.TotalSeconds >= 30)
        {
            var ago = sinceActivity.TotalMinutes >= 1
                ? $"{(int)sinceActivity.TotalMinutes}m ago"
                : $"{(int)sinceActivity.TotalSeconds}s ago";
            return $"{status} (last activity {ago})";
        }
        return status;
    }

    private string GetLayoutClass() => Layout switch
    {
        ChatLayout.Reversed => "layout-reversed",
        ChatLayout.BothLeft => "layout-both-left",
        _ => ""
    };

    private string GetStyleClass() => Style switch
    {
        ChatStyle.Minimal => "style-minimal",
        _ => ""
    };

    private static bool IsActivityMessage(ChatMessage msg) =>
        msg.MessageType is ChatMessageType.ToolCall or ChatMessageType.Reasoning
                        or ChatMessageType.ShellOutput or ChatMessageType.Diff;

    private sealed class MessageGroup
    {
        public List<ChatMessage> Messages { get; } = new();
        public bool IsActivityGroup { get; set; }
    }

    /// <summary>
    /// Groups consecutive activity messages (ToolCall, Reasoning, ShellOutput, Diff) together.
    /// Content messages (User, Assistant, System, etc.) stay in their own single-message groups.
    /// </summary>
    private static List<MessageGroup> GroupMessages(List<ChatMessage> messages)
    {
        var groups = new List<MessageGroup>();
        MessageGroup? currentActivity = null;

        foreach (var msg in messages)
        {
            if (IsActivityMessage(msg))
            {
                if (currentActivity == null)
                {
                    currentActivity = new MessageGroup { IsActivityGroup = true };
                    groups.Add(currentActivity);
                }
                currentActivity.Messages.Add(msg);
            }
            else
            {
                currentActivity = null;
                var content = new MessageGroup { IsActivityGroup = false };
                content.Messages.Add(msg);
                groups.Add(content);
            }
        }

        return groups;
    }

    private IEnumerable<ToolActivity> GetNewActivities()
    {
        var historyCallIds = Messages.ToList().Where(m => m.ToolCallId != null).Select(m => m.ToolCallId).ToHashSet();
        return ToolActivities.Where(a => !historyCallIds.Contains(a.CallId));
    }

    private bool ShouldShowStreamingContent()
    {
        if (string.IsNullOrWhiteSpace(StreamingContent) || (!IsProcessing && !IsRemoteStreaming))
            return false;

        // TurnEnd / IDLE-DEFER can flush the current assistant text into History while the
        // session stays "processing" for background tasks. Suppress the live bubble once the
        // same text is already present in History to avoid showing it twice.
        var lastAssistant = Messages.LastOrDefault(m =>
            m.Role == "assistant" &&
            m.MessageType != ChatMessageType.ToolCall &&
            m.MessageType != ChatMessageType.Reasoning &&
            m.MessageType != ChatMessageType.Image);

        return !string.Equals(NormalizeStreamingText(lastAssistant?.Content), NormalizeStreamingText(StreamingContent), StringComparison.Ordinal);
    }

    private static string NormalizeStreamingText(string? text) => string.IsNullOrWhiteSpace(text) ? "" : text.Trim();

    private static readonly Dictionary<string, string> _imageCache = new();
    // LRU markdown cache: uses content string as key (no hash collisions), with eviction at 1000 entries
    private static readonly Dictionary<string, string> _markdownCache = new();
    private static readonly LinkedList<string> _markdownCacheLru = new();
    private const int MarkdownCacheMaxSize = 1000;

    private static readonly System.Text.RegularExpressions.Regex ImagePathRegex = new(
        @"(?<!\(|""|\w)((?:/[\w\-. ]+)+\.(?:png|jpg|jpeg|gif|webp|svg|bmp|tiff))(?!\)|""|\w)",
        System.Text.RegularExpressions.RegexOptions.IgnoreCase | System.Text.RegularExpressions.RegexOptions.Compiled);

    private static readonly System.Text.RegularExpressions.Regex WorkerBlockRegex = new(
        @"^@worker:([^\n]+?)\s*\n([\s\S]*?)(?:@end|(?=^@worker:))",
        System.Text.RegularExpressions.RegexOptions.IgnoreCase | System.Text.RegularExpressions.RegexOptions.Compiled | System.Text.RegularExpressions.RegexOptions.Multiline);

    // Regex to match fenced code blocks (```...```) and inline code (`...`)
    private static readonly System.Text.RegularExpressions.Regex CodeBlockRegex = new(
        @"```[\s\S]*?```|`[^`\n]+`",
        System.Text.RegularExpressions.RegexOptions.Compiled);

    internal static string RenderMarkdown(string content, string? repoUrl = null)
    {
        if (string.IsNullOrEmpty(content)) return "";
        var cacheKey = repoUrl != null ? $"{repoUrl}\0{content}" : content;
        if (_markdownCache.TryGetValue(cacheKey, out var cached)) return cached;
        try
        {
            // Pre-process @worker:name...@end blocks into collapsible <details> elements.
            // Extract them before markdown rendering, replace with placeholders, then restore.
            // Placeholders use alphanumeric-only names to avoid markdown interpretation
            // (e.g., __X__ would become <strong>X</strong>).
            //
            // To avoid matching @worker: inside code blocks or inline code spans,
            // we first blank out code regions, run the regex on the blanked copy to
            // find match positions, then apply replacements to the original content.
            var workerBlocks = new Dictionary<string, string>();
            var blanked = CodeBlockRegex.Replace(content, m => new string(' ', m.Length));
            var matches = WorkerBlockRegex.Matches(blanked);
            var processed = content;
            // Apply replacements in reverse order to preserve indices
            for (int i = matches.Count - 1; i >= 0; i--)
            {
                var match = matches[i];
                var workerName = match.Groups[1].Value.Trim();
                var taskBody = match.Groups[2].Value.Trim();
                var id = $"PPWORKERBLK{workerBlocks.Count}ENDBLK";
                var bodyHtml = MarkdownRenderer.ToHtml(taskBody);
                workerBlocks[id] = $"<details class=\"worker-dispatch-details\">" +
                    $"<summary>📤 Task → <strong>{System.Net.WebUtility.HtmlEncode(workerName)}</strong></summary>" +
                    $"<div class=\"worker-dispatch-content\">{bodyHtml}</div></details>";
                processed = processed[..match.Index] + $"\n{id}\n" + processed[(match.Index + match.Length)..];
            }

            var html = MarkdownRenderer.ToHtml(processed);

            // Restore worker block placeholders with actual HTML
            foreach (var (placeholder, detailsHtml) in workerBlocks)
            {
                html = html.Replace($"<p>{placeholder}</p>", detailsHtml);
                html = html.Replace(placeholder, detailsHtml);
            }

            html = ImagePathRegex.Replace(html, match =>
            {
                var path = match.Value;
                var dataUri = FileToDataUri(path);
                if (dataUri != null)
                    return $"<img src=\"{dataUri}\" alt=\"{System.IO.Path.GetFileName(path)}\" />";
                return match.Value;
            });
            html = PolyPilot.Services.GitHubReferenceLinker.LinkifyReferences(html, repoUrl);
            // LRU eviction: remove oldest when at capacity
            if (_markdownCache.Count >= MarkdownCacheMaxSize)
            {
                var oldest = _markdownCacheLru.First;
                if (oldest != null)
                {
                    _markdownCache.Remove(oldest.Value);
                    _markdownCacheLru.RemoveFirst();
                }
            }
            _markdownCache[cacheKey] = html;
            _markdownCacheLru.AddLast(cacheKey);
            return html;
        }
        catch { return System.Net.WebUtility.HtmlEncode(content).Replace("\n", "<br/>"); }
    }

    internal static string FormatUserMessage(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        var lines = content.Split('\n');
        var sb = new System.Text.StringBuilder();
        var hasText = false;
        foreach (var line in lines)
        {
            var trimmed = line.Trim();
            if (trimmed.StartsWith('/') && ImageExtensions.Any(ext => 
                trimmed.EndsWith(ext, StringComparison.OrdinalIgnoreCase)) &&
                System.IO.File.Exists(trimmed))
            {
                if (hasText) { sb.Append("</p>"); hasText = false; }
                var dataUri = FileToDataUri(trimmed);
                var fileName = System.IO.Path.GetFileName(trimmed);
                var safeName = System.Net.WebUtility.HtmlEncode(fileName);
                if (dataUri != null)
                {
                    sb.Append($"<div class=\"user-image-attachment\"><img src=\"{dataUri}\" alt=\"{safeName}\" /><span class=\"user-image-name\">📷 {safeName}</span></div>");
                    continue;
                }
            }
            if (!hasText) { sb.Append("<p>"); hasText = true; }
            else sb.Append("<br/>");
            sb.Append(System.Net.WebUtility.HtmlEncode(line));
        }
        if (hasText) sb.Append("</p>");
        return sb.ToString();
    }

    internal static int LineCount(string? text)
    {
        if (string.IsNullOrEmpty(text)) return 0;
        var count = 1;
        foreach (var c in text) { if (c == '\n') count++; }
        return count;
    }

    // Known orchestrator top-level section headers and display mode:
    //   "expanded"   — collapsible, starts open (novel per-message content)
    //   "collapsed"  — collapsible, starts closed, standalone (lengthy but potentially useful content)
    //   "boilerplate" — collapsed and grouped together (repetitive orchestrator scaffolding)
    // Only these headers trigger section splits — unknown ## headers
    // within worker output or other content stay inside their parent section.
    private static readonly Dictionary<string, string> OrchestratorSectionMap = new(StringComparer.OrdinalIgnoreCase)
    {
        // Collapsed standalone — content is long but potentially interesting; user can expand
        { "Worker Results", "collapsed" },
        // Boilerplate sections — collapsed and grouped together
        { "Your Task", "boilerplate" },
        { "Previous Iteration", "boilerplate" },
        { "Evaluation Check", "boilerplate" },
        { "Work Routing", "boilerplate" },
        { "Instructions", "boilerplate" },
        { "Original Request", "boilerplate" },
        { "User Request", "boilerplate" },
        { "Additional Orchestration Instructions", "boilerplate" },
        { "Independent Quality Evaluation", "boilerplate" },
        { "Original User Request", "boilerplate" },
    };

    // Worker prompt section headers — used when the message is an orchestrator dispatch to a worker.
    // "Your Assigned Task" is expanded by default; everything else is collapsed as context.
    private static readonly Dictionary<string, string> WorkerPromptSectionMap = new(StringComparer.OrdinalIgnoreCase)
    {
        { "Your Assigned Task", "expanded" },
        { "Original User Request", "boilerplate" },
        { "CRITICAL: Tool Usage", "boilerplate" },
        { "Team Context", "boilerplate" },
        { "Your Worktree", "boilerplate" },
        { "Multi-Agent Workflow Protocol", "boilerplate" },
    };

    /// <summary>
    /// Returns true if content is a worker prompt (dispatched from orchestrator to worker).
    /// Worker prompts always contain "## Your Assigned Task" near the end.
    /// </summary>
    internal static bool IsWorkerPrompt(string? content)
    {
        if (string.IsNullOrEmpty(content)) return false;
        return content.Contains("## Your Assigned Task");
    }

    // Section headers characteristic of orchestrator-generated prompts.
    // Any single match is sufficient — normal user messages never contain these headers.
    // NOTE: @worker: and [[GROUP_REFLECT_COMPLETE]] are NOT included here because they
    // can appear inside backtick/code spans in regular discussion text (e.g., "the
    // `@worker:` blocks"). The ## headers are reliable orchestrator-only markers.
    private static readonly string[] OrchestratorMarkers = new[]
    {
        "## Work Routing",
        "## Worker Results",
        "## Instructions",
        "## Your Task",
        "## Original Request",
        "## Evaluation Check",
        "## Previous Iteration",
        "## User Request",
        "## Additional Orchestration Instructions",
    };

    /// <summary>
    /// Returns true if the header matches a known orchestrator section.
    /// </summary>
    private static bool IsKnownOrchestratorHeader(string headerText)
    {
        foreach (var key in OrchestratorSectionMap.Keys)
            if (headerText.StartsWith(key, StringComparison.OrdinalIgnoreCase))
                return true;
        return false;
    }

    /// <summary>
    /// Detects if content is an orchestrator prompt (synthesis, replan, etc.)
    /// by looking for characteristic section headers or orchestrator markers.
    /// A single marker match is enough — these strings never appear in normal user messages.
    /// </summary>
    internal static bool IsOrchestratorPrompt(string? content)
    {
        if (string.IsNullOrEmpty(content)) return false;
        foreach (var marker in OrchestratorMarkers)
            if (content.Contains(marker)) return true;
        return false;
    }

    /// <summary>
    /// Renders an orchestrator prompt with section-aware collapsing.
    /// Dynamic sections (Worker Results) are collapsible but start open;
    /// boilerplate sections (Instructions, Work Routing, etc.) are collapsed.
    /// Only known orchestrator headers trigger section splits — unknown ## headers
    /// (e.g., from worker output) stay within their parent section.
    /// When originalContent is provided, it's shown as a brief user prompt label.
    /// When collapseOriginal is true, the original prompt is rendered in a collapsed
    /// details element (for re-dispatch messages where the prompt repeats).
    /// </summary>
    internal static string RenderOrchestratorPromptSections(string content, string? originalContent = null, bool collapseOriginal = false)
    {
        if (string.IsNullOrEmpty(content)) return "";

        // Split content into sections by known orchestrator ## headers only
        var sections = new List<(string? header, string body)>();
        var lines = content.Split('\n');
        string? currentHeader = null;
        var currentBody = new System.Text.StringBuilder();
        bool hasAnySections = false;

        foreach (var line in lines)
        {
            var trimmed = line.TrimStart();
            if (trimmed.StartsWith("## "))
            {
                var headerText = trimmed.Substring(3).Trim();
                if (IsKnownOrchestratorHeader(headerText))
                {
                    hasAnySections = true;
                    if (currentHeader != null || currentBody.Length > 0)
                        sections.Add((currentHeader, currentBody.ToString().TrimEnd()));
                    currentHeader = headerText;
                    currentBody.Clear();
                    continue;
                }
            }
            currentBody.AppendLine(line);
        }
        if (currentHeader != null || currentBody.Length > 0)
            sections.Add((currentHeader, currentBody.ToString().TrimEnd()));

        // If no ## sections found, fall back to a single collapsed panel
        if (!hasAnySections)
        {
            var fallback = new System.Text.StringBuilder();
            // Show original user message at top — but skip if it's itself an orchestrator prompt
            if (!string.IsNullOrEmpty(originalContent) && !IsOrchestratorPrompt(originalContent))
            {
                if (collapseOriginal)
                    AppendCollapsedOriginalContent(fallback, originalContent);
                else
                {
                    fallback.Append("<div class=\"chat-msg-text\">");
                    fallback.Append(FormatUserMessage(originalContent));
                    fallback.Append("</div>");
                }
            }
            fallback.Append("<details class=\"orchestration-prompt-details\">");
            fallback.Append("<summary>Full orchestration prompt</summary>");
            fallback.Append("<div class=\"orchestration-prompt-content\">");
            fallback.Append(System.Net.WebUtility.HtmlEncode(content).Replace("\n", "<br/>"));
            fallback.Append("</div></details>");
            return fallback.ToString();
        }

        var sb = new System.Text.StringBuilder();

        // Show original user message at top — but skip if it's itself an orchestrator prompt
        if (!string.IsNullOrEmpty(originalContent) && !IsOrchestratorPrompt(originalContent))
        {
            if (collapseOriginal)
                AppendCollapsedOriginalContent(sb, originalContent);
            else
            {
                sb.Append("<div class=\"chat-msg-text\">");
                sb.Append(FormatUserMessage(originalContent));
                sb.Append("</div>");
            }
        }

        // Group consecutive boilerplate sections into a single collapsible panel
        var boilerplateBuffer = new List<(string label, string body)>();

        void FlushBoilerplate()
        {
            if (boilerplateBuffer.Count == 0) return;
            if (boilerplateBuffer.Count == 1)
            {
                sb.Append("<details class=\"orchestration-prompt-details\">");
                sb.Append($"<summary>{System.Net.WebUtility.HtmlEncode(boilerplateBuffer[0].label)}</summary>");
                sb.Append("<div class=\"orchestration-prompt-content\">");
                sb.Append(System.Net.WebUtility.HtmlEncode(boilerplateBuffer[0].body).Replace("\n", "<br/>"));
                sb.Append("</div></details>");
            }
            else
            {
                sb.Append("<details class=\"orchestration-prompt-details\">");
                sb.Append($"<summary>Orchestration context ({boilerplateBuffer.Count} sections)</summary>");
                sb.Append("<div class=\"orchestration-prompt-content\">");
                foreach (var (label, body) in boilerplateBuffer)
                {
                    sb.Append($"<div class=\"orchestration-boilerplate-section\">");
                    sb.Append($"<strong>{System.Net.WebUtility.HtmlEncode(label)}</strong><br/>");
                    sb.Append(System.Net.WebUtility.HtmlEncode(body).Replace("\n", "<br/>"));
                    sb.Append("</div>");
                }
                sb.Append("</div></details>");
            }
            boilerplateBuffer.Clear();
        }

        foreach (var (header, body) in sections)
        {
            if (string.IsNullOrEmpty(header) && string.IsNullOrWhiteSpace(body))
                continue;

            // Preamble (null header) is always boilerplate. Known headers use the map.
            // Unknown headers (shouldn't happen with the new splitter) default to expanded.
            string mode;
            if (header == null)
                mode = "boilerplate";
            else
            {
                var matchingKey = OrchestratorSectionMap.Keys
                    .FirstOrDefault(k => header.StartsWith(k, StringComparison.OrdinalIgnoreCase));
                mode = matchingKey != null ? OrchestratorSectionMap[matchingKey] : "expanded";
            }

            if (mode == "expanded")
            {
                FlushBoilerplate();
                // Dynamic sections are collapsible but start open
                sb.Append("<details class=\"orchestrator-dynamic-details\" open>");
                sb.Append($"<summary class=\"orchestrator-section-header\">📋 {System.Net.WebUtility.HtmlEncode(header)}</summary>");
                sb.Append("<div class=\"orchestrator-dynamic-content\">");
                sb.Append(MarkdownRenderer.ToHtml(body));
                sb.Append("</div></details>");
            }
            else if (mode == "collapsed")
            {
                FlushBoilerplate();
                // For "Worker Results", split into per-worker collapsible sections
                if (header!.StartsWith("Worker Results", StringComparison.OrdinalIgnoreCase))
                {
                    RenderPerWorkerSections(sb, header, body);
                }
                else
                {
                    // Other collapsed sections — single collapsible block
                    var summary = BuildCollapsedSummary(header!, body);
                    sb.Append("<details class=\"orchestrator-dynamic-details\">");
                    sb.Append($"<summary class=\"orchestrator-section-header\">📋 {System.Net.WebUtility.HtmlEncode(summary)}</summary>");
                    sb.Append("<div class=\"orchestrator-dynamic-content\">");
                    sb.Append(MarkdownRenderer.ToHtml(body));
                    sb.Append("</div></details>");
                }
            }
            else
            {
                var label = !string.IsNullOrEmpty(header) ? header : "Preamble";
                boilerplateBuffer.Add((label, body));
            }
        }
        FlushBoilerplate();
        return sb.ToString();
    }

    /// <summary>
    /// Renders a worker prompt (orchestrator dispatch to a worker) with section-aware collapsing.
    /// "Your Assigned Task" is shown expanded by default; all other sections (identity preamble,
    /// Original User Request, Tool Usage Policy, Team Context, etc.) are collapsed into a single
    /// "Orchestration context" panel.
    /// </summary>
    internal static string RenderWorkerPromptSections(string content, string? originalContent = null, bool collapseOriginal = false)
    {
        if (string.IsNullOrEmpty(content)) return "";

        // Split content into sections by ## headers that are in the worker prompt map
        var sections = new List<(string? header, string body)>();
        var lines = content.Split('\n');
        string? currentHeader = null;
        var currentBody = new System.Text.StringBuilder();

        foreach (var line in lines)
        {
            var trimmed = line.TrimStart();
            if (trimmed.StartsWith("## "))
            {
                var headerText = trimmed.Substring(3).Trim();
                // Check if this header matches any worker prompt section key
                bool isKnown = false;
                foreach (var key in WorkerPromptSectionMap.Keys)
                    if (headerText.StartsWith(key, StringComparison.OrdinalIgnoreCase))
                    { isKnown = true; break; }

                if (isKnown)
                {
                    if (currentHeader != null || currentBody.Length > 0)
                        sections.Add((currentHeader, currentBody.ToString().TrimEnd()));
                    currentHeader = headerText;
                    currentBody.Clear();
                    continue;
                }
            }
            currentBody.AppendLine(line);
        }
        if (currentHeader != null || currentBody.Length > 0)
            sections.Add((currentHeader, currentBody.ToString().TrimEnd()));

        var sb = new System.Text.StringBuilder();

        // Collect boilerplate sections (everything except "Your Assigned Task")
        var boilerplateBuffer = new List<(string label, string body)>();

        void FlushWorkerBoilerplate()
        {
            if (boilerplateBuffer.Count == 0) return;
            sb.Append("<details class=\"orchestration-prompt-details\">");
            if (boilerplateBuffer.Count == 1)
                sb.Append($"<summary>Orchestration context</summary>");
            else
                sb.Append($"<summary>Orchestration context ({boilerplateBuffer.Count} sections)</summary>");
            sb.Append("<div class=\"orchestration-prompt-content\">");
            foreach (var (label, body) in boilerplateBuffer)
            {
                sb.Append("<div class=\"orchestration-boilerplate-section\">");
                sb.Append($"<strong>{System.Net.WebUtility.HtmlEncode(label)}</strong><br/>");
                sb.Append(System.Net.WebUtility.HtmlEncode(body).Replace("\n", "<br/>"));
                sb.Append("</div>");
            }
            sb.Append("</div></details>");
            boilerplateBuffer.Clear();
        }

        // Process sections: expanded sections get their own collapsible (open by default),
        // everything else goes into the boilerplate group.
        foreach (var (header, body) in sections)
        {
            if (string.IsNullOrEmpty(header) && string.IsNullOrWhiteSpace(body))
                continue;

            string mode;
            if (header == null)
                mode = "boilerplate"; // Preamble (identity, charter text, etc.)
            else
            {
                var matchingKey = WorkerPromptSectionMap.Keys
                    .FirstOrDefault(k => header.StartsWith(k, StringComparison.OrdinalIgnoreCase));
                mode = matchingKey != null ? WorkerPromptSectionMap[matchingKey] : "boilerplate";
            }

            if (mode == "expanded")
            {
                // Flush any boilerplate accumulated before this section
                FlushWorkerBoilerplate();
                // Render expanded section (open by default)
                sb.Append("<details class=\"orchestrator-dynamic-details\" open>");
                sb.Append($"<summary class=\"orchestrator-section-header\">📋 {System.Net.WebUtility.HtmlEncode(header)}</summary>");
                sb.Append("<div class=\"orchestrator-dynamic-content\">");
                sb.Append(MarkdownRenderer.ToHtml(body));
                sb.Append("</div></details>");
            }
            else
            {
                var label = !string.IsNullOrEmpty(header) ? header : "Preamble";
                boilerplateBuffer.Add((label, body));
            }
        }
        FlushWorkerBoilerplate();
        return sb.ToString();
    }

    /// <summary>
    /// Builds a brief summary for a collapsed orchestrator section header.
    /// For "Worker Results", extracts worker names and their ✅/❌ status.
    /// For other sections, returns the header as-is.
    /// </summary>
    private static string BuildCollapsedSummary(string header, string body)
    {
        if (!header.StartsWith("Worker Results", StringComparison.OrdinalIgnoreCase))
            return header;

        // Extract ### WorkerName (✅ completed, Xs) / (❌ failed, Xs) lines
        var workers = new List<string>();
        foreach (var line in body.Split('\n'))
        {
            var trimmed = line.TrimStart();
            if (trimmed.StartsWith("### "))
            {
                var entry = trimmed.Substring(4).Trim();
                // Shorten to just "WorkerName ✅" or "WorkerName ❌"
                var parenIdx = entry.IndexOf('(');
                if (parenIdx > 0)
                {
                    var name = entry[..parenIdx].Trim();
                    // Extract just the short group-relative worker name (after last dash-prefix)
                    var lastDash = name.LastIndexOf('-');
                    var shortName = lastDash >= 0 && lastDash < name.Length - 1 ? name[(lastDash + 1)..] : name;
                    var status = entry.Contains("✅") ? "✅" : entry.Contains("❌") ? "❌" : "⏳";
                    workers.Add($"{shortName} {status}");
                }
            }
        }

        if (workers.Count == 0)
            return header;

        return $"Worker Results — {string.Join(", ", workers)}";
    }

    /// <summary>
    /// Renders Worker Results by splitting on ### WorkerName headers so each worker gets
    /// its own collapsible section. Each section shows the worker name and status (✅/❌)
    /// in the summary, collapsed by default.
    /// </summary>
    private static void RenderPerWorkerSections(System.Text.StringBuilder sb, string sectionHeader, string body)
    {
        // Split the body by ### headers to get individual worker results
        var workerSections = new List<(string header, string body)>();
        string? preamble = null;
        var bodyLines = body.Split('\n');
        string? currentWorkerHeader = null;
        var currentWorkerBody = new System.Text.StringBuilder();

        foreach (var line in bodyLines)
        {
            var trimmed = line.TrimStart();
            if (trimmed.StartsWith("### "))
            {
                // Save previous worker section
                if (currentWorkerHeader != null)
                    workerSections.Add((currentWorkerHeader, currentWorkerBody.ToString().TrimEnd()));
                else if (currentWorkerBody.Length > 0)
                    preamble = currentWorkerBody.ToString().TrimEnd();

                currentWorkerHeader = trimmed.Substring(4).Trim();
                currentWorkerBody.Clear();
                continue;
            }
            currentWorkerBody.AppendLine(line);
        }
        if (currentWorkerHeader != null)
            workerSections.Add((currentWorkerHeader, currentWorkerBody.ToString().TrimEnd()));
        else if (currentWorkerBody.Length > 0 && preamble == null)
            preamble = currentWorkerBody.ToString().TrimEnd();

        // If no worker subsections found, fall back to rendering as a single block
        if (workerSections.Count == 0)
        {
            var summary = BuildCollapsedSummary(sectionHeader, body);
            sb.Append("<details class=\"orchestrator-dynamic-details\">");
            sb.Append($"<summary class=\"orchestrator-section-header\">📋 {System.Net.WebUtility.HtmlEncode(summary)}</summary>");
            sb.Append("<div class=\"orchestrator-dynamic-content\">");
            sb.Append(MarkdownRenderer.ToHtml(body));
            sb.Append("</div></details>");
            return;
        }

        // Render an outer label showing the overall summary
        var overallSummary = BuildCollapsedSummary(sectionHeader, body);
        sb.Append($"<div class=\"worker-results-header\">📋 {System.Net.WebUtility.HtmlEncode(overallSummary)}</div>");

        // Render any preamble text before the first worker
        if (!string.IsNullOrWhiteSpace(preamble))
        {
            sb.Append("<div class=\"worker-results-preamble\">");
            sb.Append(MarkdownRenderer.ToHtml(preamble));
            sb.Append("</div>");
        }

        // Render each worker as its own collapsible section
        foreach (var (workerHeader, workerBody) in workerSections)
        {
            // Extract status icon from header like "srdev-1 (✅ completed, 45.2s)"
            var statusIcon = workerHeader.Contains("✅") ? "✅" : workerHeader.Contains("❌") ? "❌" : "⏳";
            var workerDisplayName = workerHeader;
            var parenIdx = workerHeader.IndexOf('(');
            if (parenIdx > 0)
                workerDisplayName = workerHeader[..parenIdx].Trim();

            sb.Append("<details class=\"worker-result-details\">");
            sb.Append($"<summary class=\"worker-result-header\">{statusIcon} {System.Net.WebUtility.HtmlEncode(workerDisplayName)}</summary>");
            sb.Append("<div class=\"worker-result-content\">");
            sb.Append(MarkdownRenderer.ToHtml(workerBody));
            sb.Append("</div></details>");
        }
    }

    /// <summary>
    /// Appends originalContent as a collapsed details element with a truncated summary.
    /// Used for re-dispatch messages where the original prompt repeats.
    /// </summary>
    private static void AppendCollapsedOriginalContent(System.Text.StringBuilder sb, string originalContent)
    {
        var summary = originalContent.Length > 100
            ? originalContent[..100].Replace("\n", " ").Replace("\r", "") + "…"
            : originalContent.Replace("\n", " ").Replace("\r", "");
        sb.Append("<details class=\"orchestration-prompt-details\">");
        sb.Append($"<summary>Original prompt: {System.Net.WebUtility.HtmlEncode(summary)}</summary>");
        sb.Append("<div class=\"chat-msg-text\">");
        sb.Append(FormatUserMessage(originalContent));
        sb.Append("</div></details>");
    }

    internal static string FirstLines(string? text, int lines)
    {
        if (string.IsNullOrEmpty(text)) return "";
        var idx = 0;
        for (var i = 0; i < lines && idx < text.Length; i++)
        {
            var next = text.IndexOf('\n', idx);
            if (next < 0) break;
            idx = next + 1;
        }
        if (idx <= 0 || idx >= text.Length) return text;
        return text[..idx] + "…";
    }

    internal static string FormatToolName(string toolName)
    {
        if (string.IsNullOrEmpty(toolName)) return "";
        return string.Join(" ", toolName.Split('_').Select(w =>
            w.Length > 0 ? char.ToUpperInvariant(w[0]) + w[1..].ToLowerInvariant() : w));
    }

    internal static (string Label, string CssClass) GetActionLabel(string toolName)
    {
        return toolName switch
        {
            "edit" => ("Edit", "action-edit"),
            "create" => ("Create", "action-create"),
            "view" => ("Read", "action-read"),
            "bash" => ("Run", "action-run"),
            "read_bash" => ("Read", "action-read"),
            "write_bash" => ("Write", "action-run"),
            "stop_bash" => ("Stop", "action-stop"),
            "grep" => ("Search", "action-search"),
            "glob" => ("Search", "action-search"),
            "web_fetch" => ("Fetch", "action-fetch"),
            "web_search" => ("Search", "action-search"),
            "sql" => ("Query", "action-query"),
            "task" => ("Agent", "action-agent"),
            "ask_user" => ("Ask", "action-ask"),
            "task_complete" => ("Done", "action-done"),
            "store_memory" => ("Memory", "action-memory"),
            "report_intent" => ("Intent", "action-intent"),
            "skill" => ("Skill", "action-agent"),
            "show_image" or "ShowImageAsync" => ("Preview", "action-read"),
            _ when toolName.StartsWith("github-mcp") => ("GitHub", "action-fetch"),
            _ when toolName.StartsWith("context7") => ("Docs", "action-read"),
            _ => (FormatToolName(toolName), "action-default"),
        };
    }

    internal static string FormatActionDescription(string toolName, string? toolInput, string? result, bool isComplete)
    {
        var summary = !string.IsNullOrEmpty(toolInput) ? SummarizeToolInput(toolName, toolInput) : "";
        
        if (toolName == "edit" && !string.IsNullOrEmpty(toolInput))
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(toolInput);
                var root = doc.RootElement;
                var path = (ExtractJsonPropFull(root, "path") ?? "").TrimStart('/');
                if (!string.IsNullOrEmpty(path))
                {
                    var oldStr = ExtractJsonProp(root, "old_str");
                    var newStr = ExtractJsonProp(root, "new_str");
                    var added = newStr?.Split('\n').Length ?? 0;
                    var removed = oldStr?.Split('\n').Length ?? 0;
                    var delta = "";
                    if (added > 0 || removed > 0)
                        delta = $" (+{added} -{removed})";
                    return $"{path}{delta}";
                }
            }
            catch { }
        }
        
        if (toolName == "bash" && !string.IsNullOrEmpty(summary))
        {
            return $"$ {summary}";
        }

        if (toolName == "view" && !string.IsNullOrEmpty(toolInput))
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(toolInput);
                var root = doc.RootElement;
                var path = (ExtractJsonPropFull(root, "path") ?? "").TrimStart('/');
                if (root.TryGetProperty("view_range", out var range))
                {
                    var rangeStr = range.ToString();
                    return $"{path} lines {rangeStr}";
                }
                return path;
            }
            catch { }
        }

        if (toolName == "create" && !string.IsNullOrEmpty(toolInput))
        {
            try
            {
                using var doc = System.Text.Json.JsonDocument.Parse(toolInput);
                var root = doc.RootElement;
                return (ExtractJsonPropFull(root, "path") ?? "").TrimStart('/');
            }
            catch { }
        }

        if (toolName == "grep" && !string.IsNullOrEmpty(toolInput))
        {
            return summary;
        }

        if (!string.IsNullOrEmpty(summary)) return summary;
        if (isComplete && !string.IsNullOrEmpty(result) && !IsUnusableResult(result))
        {
            var lines = LineCount(result);
            return $"↳ {lines} line{(lines != 1 ? "s" : "")}";
        }
        return "";
    }

    /// <summary>Compact version for the mobile header line — just the path/command, no metadata suffixes like "(+3 -2)" or "lines [1,5]".</summary>
    internal static string FormatActionDescriptionCompact(string toolName, string? toolInput, string? result, bool isComplete)
    {
        if (!string.IsNullOrEmpty(toolInput))
        {
            // For path-based tools, return just the path
            if (toolName is "edit" or "view" or "create")
            {
                try
                {
                    using var doc = System.Text.Json.JsonDocument.Parse(toolInput);
                    var root = doc.RootElement;
                    return (ExtractJsonPropFull(root, "path") ?? "").TrimStart('/');
                }
                catch { }
            }

            var summary = SummarizeToolInput(toolName, toolInput);
            if (toolName == "bash" && !string.IsNullOrEmpty(summary))
                return $"$ {summary}";
            if (toolName == "grep" && !string.IsNullOrEmpty(summary))
                return summary;
            if (!string.IsNullOrEmpty(summary))
                return summary;
        }

        if (isComplete && !string.IsNullOrEmpty(result) && !IsUnusableResult(result))
        {
            var lines = LineCount(result);
            return $"↳ {lines} line{(lines != 1 ? "s" : "")}";
        }
        return "";
    }

    /// <summary>Returns true for tools whose description is a file path (truncate from head).</summary>
    internal static bool IsPathTool(string toolName) =>
        toolName is "edit" or "create" or "view";

    internal static string TruncateResult(string result, int maxLength = 1500)
    {
        if (string.IsNullOrEmpty(result) || result.Length <= maxLength) return result ?? "";
        return result[..maxLength] + "\n… (truncated)";
    }

    internal static bool IsUnusableResult(string? content)
    {
        if (string.IsNullOrEmpty(content)) return true;
        if (content.StartsWith("GitHub.Copilot.SDK.")) return true;
        if (content is "(no result)" or "Intent logged") return true;
        return false;
    }

    private static readonly string[] ImageExtensions = { ".png", ".jpg", ".jpeg", ".gif", ".webp", ".svg", ".bmp", ".tiff" };

    internal static string? GetImagePath(string? content)
    {
        if (string.IsNullOrWhiteSpace(content)) return null;
        var trimmed = content.Trim();
        foreach (var ext in ImageExtensions)
        {
            var idx = trimmed.LastIndexOf(ext, StringComparison.OrdinalIgnoreCase);
            if (idx < 0) continue;
            var endIdx = idx + ext.Length;
            var pathStart = trimmed.LastIndexOf(' ', idx) + 1;
            if (pathStart < 0) pathStart = 0;
            var path = trimmed[pathStart..endIdx];
            if (path.StartsWith('/'))
                return path;
        }
        return null;
    }

    internal static string? FileToDataUri(string path)
    {
        if (_imageCache.TryGetValue(path, out var cached)) return cached;
        try
        {
            if (!System.IO.File.Exists(path)) return null;
            var bytes = System.IO.File.ReadAllBytes(path);
            var ext = System.IO.Path.GetExtension(path).ToLowerInvariant();
            var mime = ext switch
            {
                ".png" => "image/png",
                ".jpg" or ".jpeg" => "image/jpeg",
                ".gif" => "image/gif",
                ".webp" => "image/webp",
                ".svg" => "image/svg+xml",
                ".bmp" => "image/bmp",
                ".tiff" or ".tif" => "image/tiff",
                _ => "application/octet-stream"
            };
            var dataUri = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
            _imageCache[path] = dataUri;
            return dataUri;
        }
        catch { return null; }
    }

    /// <summary>Copies an image to ~/.polypilot/images/ for persistence, returns data URI. Caches on the ChatMessage.</summary>
    internal static string? PersistAndLoadImage(string path, ChatMessage msg)
    {
        // Already loaded?
        if (!string.IsNullOrEmpty(msg.ImageDataUri)) return msg.ImageDataUri;

        var dataUri = FileToDataUri(path);
        if (dataUri == null) return null;

        // Copy to persistent storage
        try
        {
            var imagesDir = System.IO.Path.Combine(
                Environment.GetFolderPath(Environment.SpecialFolder.UserProfile), ".polypilot", "images");
            System.IO.Directory.CreateDirectory(imagesDir);
            var ext = System.IO.Path.GetExtension(path);
            var persistentPath = System.IO.Path.Combine(imagesDir, $"{Guid.NewGuid()}{ext}");
            System.IO.File.Copy(path, persistentPath);
            msg.ImagePath = persistentPath;
        }
        catch { /* persistence is best-effort */ }

        msg.ImageDataUri = dataUri;
        return dataUri;
    }

    internal static string SummarizeToolInput(string toolName, string? input)
    {
        if (string.IsNullOrEmpty(input)) return "";
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(input);
            var root = doc.RootElement;
            // Tool-specific summaries
            return toolName switch
            {
                "bash" => ExtractJsonProp(root, "command") ?? Truncate(input, 120),
                "read_bash" or "write_bash" => ExtractJsonProp(root, "shellId") is string sid ? $"shell: {sid}" : Truncate(input, 120),
                "edit" or "create" => ExtractJsonProp(root, "path") ?? Truncate(input, 120),
                "view" => ExtractJsonProp(root, "path") ?? Truncate(input, 120),
                "grep" => $"{ExtractJsonProp(root, "pattern") ?? "?"} in {ExtractJsonProp(root, "glob") ?? ExtractJsonProp(root, "path") ?? "."}",
                "glob" => ExtractJsonProp(root, "pattern") ?? Truncate(input, 120),
                "web_fetch" => ExtractJsonProp(root, "url") ?? Truncate(input, 120),
                "web_search" => ExtractJsonProp(root, "query") ?? Truncate(input, 120),
                "task" => ExtractJsonProp(root, "description") ?? Truncate(input, 120),
                "ask_user" => ExtractJsonProp(root, "question") ?? Truncate(input, 120),
                "sql" => ExtractJsonProp(root, "query") ?? Truncate(input, 120),
                _ => Truncate(input, 120)
            };
        }
        catch
        {
            return Truncate(input, 120);
        }
    }

    private static string? ExtractJsonProp(System.Text.Json.JsonElement root, string prop)
    {
        if (root.TryGetProperty(prop, out var val) && val.ValueKind == System.Text.Json.JsonValueKind.String)
        {
            var s = val.GetString();
            return string.IsNullOrEmpty(s) ? null : Truncate(s, 120);
        }
        return null;
    }

    internal static string FormatToolInputExpanded(string toolName, string input)
    {
        if (string.IsNullOrEmpty(input)) return "";
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(input);
            var root = doc.RootElement;
            switch (toolName)
            {
                case "bash":
                    return $"$ {ExtractJsonPropFull(root, "command") ?? input}";
                case "edit":
                {
                    var path = ExtractJsonPropFull(root, "path") ?? input;
                    var oldStr = ExtractJsonProp(root, "old_str");
                    var newStr = ExtractJsonProp(root, "new_str");
                    var added = newStr?.Split('\n').Length ?? 0;
                    var removed = oldStr?.Split('\n').Length ?? 0;
                    if (added > 0 || removed > 0)
                        return $"{path} (+{added} -{removed})";
                    return path;
                }
                case "create":
                    return ExtractJsonPropFull(root, "path") ?? input;
                case "view":
                {
                    var path = ExtractJsonPropFull(root, "path") ?? input;
                    if (root.TryGetProperty("view_range", out var range))
                        return $"{path} lines {range}";
                    return path;
                }
                case "grep":
                    return $"grep '{ExtractJsonPropFull(root, "pattern")}' {ExtractJsonPropFull(root, "glob") ?? ExtractJsonPropFull(root, "path") ?? "."}";
                case "sql":
                    return ExtractJsonPropFull(root, "query") ?? input;
                default:
                    return input.Length > 2000 ? input[..2000] + "…" : input;
            }
        }
        catch { return input.Length > 2000 ? input[..2000] + "…" : input; }
    }

    private static string? ExtractJsonPropFull(System.Text.Json.JsonElement root, string prop)
    {
        if (root.TryGetProperty(prop, out var val) && val.ValueKind == System.Text.Json.JsonValueKind.String)
            return val.GetString();
        return null;
    }

    private static string Truncate(string s, int max)
    {
        if (s.Length <= max) return s;
        return s[..max] + "…";
    }
}
