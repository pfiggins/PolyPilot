                                                disabled="@(!HasExternalInput(ext.SessionId) || isExternalResuming)">↑</button>
                                    </div>
                                    @if (confirmExternalResumeId == ext.SessionId && !string.IsNullOrEmpty(externalResumeError))
                                    {
                                        <div class="resume-error">⚠ @externalResumeError</div>
                                    }
                                }
                                else if (ext.ActiveLockPid.HasValue && WindowFocusHelper.IsSupported)
                                {
