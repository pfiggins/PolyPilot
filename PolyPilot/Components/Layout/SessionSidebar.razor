                                        <input type="text"
                                               class="ext-sidebar-input"
                                               placeholder="Send to reopen in PolyPilot…"
                                               value="@(_externalInputs.GetValueOrDefault(ext.SessionId, ""))"
                                               @oninput="e => _externalInputs[ext.SessionId] = e.Value?.ToString() ?? string.Empty"
                                               @onkeyup="e => HandleExternalKeyUp(e, ext)"
