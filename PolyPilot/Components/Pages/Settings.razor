    private void LinkFiestaWorker()
    {
        fiestaLinkError = null;
        try
        {
            if (string.IsNullOrWhiteSpace(fiestaLinkUrl) || string.IsNullOrWhiteSpace(fiestaLinkToken))
            {
                fiestaLinkError = "Worker URL and token are required.";
                return;
            }

            var hostName = TryExtractHost(fiestaLinkUrl) ?? fiestaLinkName.Trim();
            var workerName = string.IsNullOrWhiteSpace(fiestaLinkName) ? hostName : fiestaLinkName.Trim();
            FiestaService.LinkWorker(workerName, hostName, fiestaLinkUrl, fiestaLinkToken);
            fiestaLinkName = "";
            fiestaLinkUrl = "";
            fiestaLinkToken = "";
            ShowStatus("Fiesta worker linked", "success", 2500);
        }
        catch (Exception ex)
        {
            fiestaLinkError = ex.Message;
        }
    }

    private void RemoveFiestaWorker(string workerId)
    {
        FiestaService.RemoveLinkedWorker(workerId);
        ShowStatus("Fiesta worker removed", "success", 2000);
    }

    private static string? TryExtractHost(string url)
    {
        try
        {
            var normalized = url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
                             url.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
                ? url
                : "http://" + url;
            return new Uri(normalized).Host;
        }
        catch
        {
            return null;
        }
    }

