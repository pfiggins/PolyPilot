                            _ => "ext-ended"
                        };
                        var extBadge = ext.Tier switch
                        {
                            ExternalSessionTier.Active => "🟢",
                            ExternalSessionTier.Idle => "💤",
                            _ => "⏹"
                        };
                        var extBadgeTitle = ext.Tier switch
                        {
                            ExternalSessionTier.Active => "Running — CLI process is active",
                            ExternalSessionTier.Idle => "Idle — no recent activity, process may still be open",
                            _ => "Exited — CLI has closed, click send to reopen in PolyPilot"
