@inherits LayoutComponentBase
@using PolyPilot.Services
@using PolyPilot.Models
@implements IDisposable

<div class="page @(flyoutOpen ? "flyout-open" : "")">
    <div class="sidebar desktop-only">
        <SessionSidebar OnToggleStatistics="ToggleStatistics" />
        <div class="sidebar-resize-handle" @onmousedown="StartResize"></div>
    </div>

    <div class="mobile-top-bar mobile-only">
        <SessionSidebar IsMobileTopBar="true" OnToggleFlyout="ToggleFlyout" FontSize="fontSize" OnFontSizeChange="HandleFontSizeChange" OnToggleStatistics="ToggleStatistics" />
    </div>

    <main>
        <article class="content">
            @Body
        </article>
    </main>

    <div class="flyout-backdrop mobile-only @(flyoutOpen ? "open" : "")" @onclick="CloseFlyout"></div>
    <div class="flyout-panel mobile-only @(flyoutOpen ? "open" : "")">
        <SessionSidebar IsFlyoutPanel="true" OnToggleFlyout="CloseFlyout" OnSessionSelected="CloseFlyout" OnToggleStatistics="ToggleStatistics" />
    </div>

    <PolyPilot.Components.Tutorial.TutorialOverlay />
    <PolyPilot.Components.Layout.StatisticsPopup Visible="showStatistics" OnClose="CloseStatistics" />
</div>

@code {
    private bool flyoutOpen;
    private bool showStatistics;
    private int fontSize = 20;
    private Timer? _holidayTimer;
    private bool _lastHolidayCheck;
    private bool _disposed;

    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private CopilotService CopilotService { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private TutorialService TutorialService { get; set; } = default!;

    private DotNetObjectReference<MainLayout>? _navRef;

    [JSInvokable]
    public void NavigateToSettings()
    {
        CopilotService.SaveUiState("/settings");
        NavManager.NavigateTo("/settings");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Apply holiday theme if active (before user theme, so it takes precedence)
            var effectiveTheme = CopilotService.Theme;
            var holidayTheme = HolidayThemeHelper.GetActiveHolidayTheme();
            _lastHolidayCheck = holidayTheme.HasValue;
            if (holidayTheme.HasValue && !CopilotService.HolidayThemeDismissed)
            {
                effectiveTheme = holidayTheme.Value;
                CopilotService.Theme = effectiveTheme;
            }

            var dataTheme = HolidayThemeHelper.GetDataThemeString(effectiveTheme);
            await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{dataTheme}')");

            // Start timer to detect date transitions (e.g., midnight crossing into/out of March 8)
            _holidayTimer = new Timer(OnHolidayTimerTick, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));

            // Register nav ref for global keyboard shortcuts (Cmd+,)
            _navRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("eval", "window.__setNavRef = function(ref) { window._navRef = ref; };");
            await JS.InvokeVoidAsync("__setNavRef", _navRef);

            // Load saved font size and navigate to last page
            var uiState = CopilotService.LoadUiState();
            if (uiState != null)
            {
                if (uiState.FontSize > 0)
                {
                    fontSize = uiState.FontSize;
                    await ApplyFontSize();
                }

                TutorialService.LoadCompleted(uiState.CompletedTutorials);
                
                // Navigate to the last page if not already there
                var currentUri = new Uri(NavManager.Uri);
                var currentPath = currentUri.LocalPath;
                if (currentPath == "/" && !string.IsNullOrEmpty(uiState.CurrentPage) && uiState.CurrentPage != "/" && uiState.CurrentPage != "/dashboard")
                {
                    NavManager.NavigateTo(uiState.CurrentPage);
                }
                
                StateHasChanged();
            }
        }
    }

    private void OnHolidayTimerTick(object? state)
    {
        if (_disposed) return;

        var holidayTheme = HolidayThemeHelper.GetActiveHolidayTheme();
        var isHoliday = holidayTheme.HasValue;

        if (isHoliday && !_lastHolidayCheck && !CopilotService.HolidayThemeDismissed)
        {
            _ = InvokeAsync(async () =>
            {
                if (_disposed) return;
                try
                {
                    // Just crossed into a holiday — activate theme
                    _lastHolidayCheck = true;
                    CopilotService.HolidayThemeDismissed = false;
                    CopilotService.Theme = holidayTheme!.Value;
                    var dt = HolidayThemeHelper.GetDataThemeString(holidayTheme!.Value);
                    await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{dt}')");
                    StateHasChanged();
                }
                catch (Exception ex)
                {
                    Console.Error.WriteLine($"Error activating holiday theme: {ex.Message}");
                }
            });
        }
        else if (!isHoliday && _lastHolidayCheck)
        {
            _ = InvokeAsync(async () =>
            {
                if (_disposed) return;
                try
                {
                    // Holiday ended — revert to user's saved theme
                    _lastHolidayCheck = false;
                    CopilotService.HolidayThemeDismissed = false;
                    var saved = ConnectionSettings.Load();
                    CopilotService.Theme = saved.Theme;
                    var dt = HolidayThemeHelper.GetDataThemeString(saved.Theme);
                    await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{dt}')");
                    StateHasChanged();
                }
                catch (Exception ex)
                {
                    Console.Error.WriteLine($"Error reverting holiday theme: {ex.Message}");
                }
            });
        }
    }

    private async Task HandleFontSizeChange(int delta)
    {
        fontSize = Math.Clamp(fontSize + delta, 12, 24);
        await ApplyFontSize();
        CopilotService.SaveUiState("/", fontSize: fontSize);
    }

    private async Task ApplyFontSize()
    {
        await JS.InvokeVoidAsync("eval", $"document.documentElement.style.setProperty('--app-font-size', '{fontSize}px')");
    }

    private async Task StartResize(MouseEventArgs e)
    {
        await JS.InvokeVoidAsync("eval", $@"
            (function() {{
                var sidebar = document.querySelector('.sidebar.desktop-only');
                if (!sidebar) return;
                var startX = {e.ClientX};
                var startW = sidebar.offsetWidth;
                function onMove(e) {{
                    var w = Math.min(Math.max(startW + e.clientX - startX, 200), 600);
                    sidebar.style.width = w + 'px';
                }}
                function onUp() {{
                    document.removeEventListener('mousemove', onMove);
                    document.removeEventListener('mouseup', onUp);
                    document.body.style.userSelect = '';
                    document.body.style.cursor = '';
                }}
                document.body.style.userSelect = 'none';
                document.body.style.cursor = 'col-resize';
                document.addEventListener('mousemove', onMove);
                document.addEventListener('mouseup', onUp);
            }})();
        ");
    }

    private void ToggleFlyout()
    {
        flyoutOpen = !flyoutOpen;
    }

    private void CloseFlyout()
    {
        flyoutOpen = false;
    }

    private void ToggleStatistics()
    {
        showStatistics = !showStatistics;
    }

    private void CloseStatistics()
    {
        showStatistics = false;
    }

    public void Dispose()
    {
        _disposed = true;
        _holidayTimer?.Dispose();
        _navRef?.Dispose();
    }
}
